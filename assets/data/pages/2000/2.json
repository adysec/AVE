lob/9b79b5eac5a874eeb91f0d9e37084feed8b830f5/CVE/data/2000/CVE-2000-0394.json","https://github.com/github/advisory-database/blob/cdfc8886d71af7ef3bdab3e4db46753ff8af6538/advisories/unreviewed/2022/04/GHSA-xh9x-3wgg-3wwg/GHSA-xh9x-3wgg-3wwg.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/olbat/nvdcve/blob/39f1db26eec9899ab2f8110ab3b45424c6fe9ec2/nvdcve/CVE-2000-0394.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_152400_152500.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_4.list.dict","https://github.com/nomi-sec/CVE-Easy-List/blob/839e2559933f5ff6cd50b4768fd382827d790668/2000.tsv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0324.toml"},{"ave_id":"AVE-2000-0342","file_name":"2000/AVE-2000-0342.toml","cve_id":"CVE-2000-0417","title":"Cayman 3220-H DSL Router HTTP管理接口拒绝服务漏洞","description":"Cayman 3220-H DSL 路由器与 GatorSurf 5.3 的 HTTP 管理接口存在拒绝服务漏洞。远程攻击者可通过向管理接口提交超长用户名或密码，导致路由器服务崩溃或无法响应正常请求。该漏洞无需身份认证即可触发，攻击门槛低，影响使用该设备的网络环境稳定性和可用性。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2000-0417"],"sources":["exploitdb"],"published":"2000-05-17T04:00:00.000","updated":"2026-06-16T21:51:40.330","remediation":"将路由器固件升级至最新版本；如厂商已停止支持，建议更换受支持的设备。在管理界面配置访问控制列表（ACL），限制仅允许可信 IP 段访问 HTTP 管理端口（默认 80）。同时设置强密码策略，避免使用过长或异常字符的凭据触发缓冲区异常。","status":"completed","collected_at":"2026-07-20T00:00:00Z","references":["http://archives.neohapsis.com/archives/bugtraq/2000-05/0075.html","http://archives.neohapsis.com/archives/bugtraq/2000-05/0280.html","http://www.securityfocus.com/bid/1219","https://www.exploit-db.com/exploits/19923","https://github.com/CVEProject/cvelistV5/blob/24df5d59670dfe04b9c86de11fa86df63c0d28f7/cves/2000/0xxx/CVE-2000-0417.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0417","https://github.com/yarencheng/cve-devops-playground/blob/470a5f1c0d1bd36cd0a6327cda49cf96a1474588/content/CVE-2000-0417.md","https://github.com/Patrowl/PatrowlHearsData/blob/228df6a85079f5c6b1ecdfb3d41be685458438ef/CVE/data/2000/CVE-2000-0417.json","https://github.com/github/advisory-database/blob/4544d3857250fe21711ce8febf38e8822729678f/advisories/unreviewed/2022/04/GHSA-c62h-wfv7-hw42/GHSA-c62h-wfv7-hw42.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/2000/CVE-2000-0417.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_152400_152500.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_3.list.dict","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001388.txt","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--a8de6680-f4ba-4315-95ac-f367e3dcd504.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/2000/POC-AVE-2000-0342.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/2000/EXP-AVE-2000-0342.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0342.toml"},{"ave_id":"AVE-2000-0304","file_name":"2000/AVE-2000-0304.toml","cve_id":"CVE-2000-0350","title":"NetworkICE ICEcap Manager 默认用户名和密码漏洞","description":"NetworkICE ICEcap 2.0.23 及更早版本中存在默认启用的调试功能，该功能允许远程攻击者绕过脆弱的身份验证机制，向目标系统发送未加密的事件数据。攻击者无需认证即可利用此功能，影响系统日志与事件的完整性和机密性，CVSS 评分 5.0，危害等级中危。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2000-0350"],"sources":["cve"],"published":"2000-05-17T04:00:00.000","updated":"2026-06-16T21:51:32.053","remediation":"立即升级 NetworkICE ICEcap 至 2.0.24 或更高版本，该版本已禁用调试功能并修复了弱认证问题。如无法升级，在 ICEcap 管理控制台中手动关闭调试模式（Debug Mode = Off），并在防火墙上限制仅允许受信任管理 IP 访问 ICEcap 服务端口（默认 5000/TCP），同时启用 TLS 加密通信以防止事件数据明文传输。","status":"completed","collected_at":"2026-07-20T00:00:00Z","references":["http://advice.networkice.com/advice/Support/KB/q000166/","http://www.osvdb.org/312","http://www.securityfocus.com/bid/1216","http://www.securityfocus.com/templates/advisory.html?id=2220","https://www.exploit-db.com/exploits/19922","https://github.com/CVEProject/cvelistV5/blob/4e8d44fc9434dcaf08511a3267e0bf049a6756de/cves/2000/0xxx/CVE-2000-0350.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0350","https://github.com/yarencheng/cve-devops-playground/blob/470a5f1c0d1bd36cd0a6327cda49cf96a1474588/content/CVE-2000-0350.md","https://github.com/Patrowl/PatrowlHearsData/blob/f9199c6ea2112c9d2536a126688b640a45f0982a/CVE/data/2000/CVE-2000-0350.json","https://github.com/github/advisory-database/blob/4544d3857250fe21711ce8febf38e8822729678f/advisories/unreviewed/2022/04/GHSA-3xrw-8rrf-5qr9/GHSA-3xrw-8rrf-5qr9.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/2000/CVE-2000-0350.json","https://github.com/Freem93/grammar_nasl_v2/blob/63834ebb8cd6e97050e155291c7500ad53bb20c6/plugins/icecap_default_pw.nasl","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_152300_152400.json","https://github.com/Yuning-J/VulnerabilityClassifier/blob/c0f06c21b73c26b5ee2b75c21a498eb04eada4b5/threatPrediction/cveIDThreatType/cve_idbypass"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/2000/POC-AVE-2000-0304.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/2000/EXP-AVE-2000-0304.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0304.toml"},{"ave_id":"AVE-2000-0331","file_name":"2000/AVE-2000-0331.toml","cve_id":"CVE-2000-0405","title":"L0pht AntiSniff DNS 响应缓冲区溢出远程代码执行漏洞","description":"L0pht AntiSniff（后更名为 @stake AntiSniff）DNS 响应处理组件存在缓冲区溢出漏洞。远程攻击者可向运行 AntiSniff 的目标主机发送特制的 DNS 响应数据包，触发堆栈缓冲区溢出，从而以系统权限执行任意命令。该漏洞影响 AntiSniff 1.0 及 Researchers 1.0 版本，CVSS 评分 10.0，危害等级严重，攻击者无需认证即可远程利用。","severity":"CRITICAL","score":10.0,"aliases":["CVE-2000-0405"],"sources":["exploitdb"],"published":"2000-05-16T04:00:00.000","updated":"2026-06-16T21:51:38.847","remediation":"立即升级到 @Stake 官方发布修复的 AntiSniff 版本（1.0.2 或更高），原补丁曾发布于 http://www.l0pht.com/advisories/asniff_advisory.txt。由于该产品已停止维护，建议迁移至仍受支持的替代网络监控工具。临时缓解措施可在防火墙上限制仅允许与受信 DNS 服务器通信，并部署 IDS 规则检测异常大尺寸的 DNS 响应包，防止恶意 DNS 响应触发溢出。","status":"completed","collected_at":"2026-07-20T00:00:00Z","references":["http://www.l0pht.com/advisories/asniff_advisory.txt","http://www.osvdb.org/3179","http://www.securityfocus.com/bid/1207","https://www.exploit-db.com/exploits/19918","https://github.com/trickest/cve/blob/b4f1378756fd26f414d09a97dc81126672830951/2000/CVE-2000-0405.md","https://github.com/CVEProject/cvelistV5/blob/30c3a896d257362f7419b0c772be2f3dd063ccaa/cves/2000/0xxx/CVE-2000-0405.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0405","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/2000/CVE-2000-0405.json","https://github.com/mabitoski/cve_submodules/blob/44ad7e2705b3aef1b2ffaf64bd47596c10a6c2e4/2000/CVE-2000-0405.md","https://github.com/github/advisory-database/blob/cdfc8886d71af7ef3bdab3e4db46753ff8af6538/advisories/unreviewed/2022/04/GHSA-xvhj-83gv-vjmg/GHSA-xvhj-83gv-vjmg.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/olbat/nvdcve/blob/39f1db26eec9899ab2f8110ab3b45424c6fe9ec2/nvdcve/CVE-2000-0405.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001385.txt","https://github.com/hungryfoolou/Vulnerability_Mining/blob/3df1d8ed0489ae1228f975ae1f58a690aae53886/craw/cveid_craw/cveid_craw/data/cveid_by_kind/cveid_overflow.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0331.toml"},{"ave_id":"AVE-2000-0325","file_name":"2000/AVE-2000-0325.toml","cve_id":"CVE-2000-0395","title":"Computalynx CProxy Server 缓冲区溢出拒绝服务漏洞","description":"Computalynx CProxy Server 3.3 SP2 存在缓冲区溢出漏洞。远程攻击者可通过向目标服务发送超长的 HTTP 请求触发缓冲区溢出，导致服务进程崩溃，造成拒绝服务。该漏洞影响 CProxy Server 3.3 SP2 版本，攻击者无需身份认证即可通过网络远程利用，危害等级中危。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2000-0395"],"sources":["exploitdb"],"published":"2000-05-16T04:00:00.000","updated":"2026-06-16T21:51:37.593","remediation":"Computalynx CProxy Server 3.3 SP2 已停止维护，官方不再提供安全更新。建议立即升级至受支持的代理服务器软件（如 Squid、HAProxy 等）。如无法替换，可在防火墙层面限制仅允许可信 IP 访问 CProxy 监听端口（默认 8080），并配置入侵检测规则拦截超长 HTTP 请求作为临时缓解措施。","status":"completed","collected_at":"2026-07-20T00:00:00Z","references":["http://www.securityfocus.com/bid/1213","http://www.securityfocus.com/templates/archive.pike?list=1&msg=007d01bfbf48%24e44f0e40%2401dc11ac%40peopletel.org","https://www.exploit-db.com/exploits/19920","https://github.com/CVEProject/cvelistV5/blob/30c3a896d257362f7419b0c772be2f3dd063ccaa/cves/2000/0xxx/CVE-2000-0395.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0395","https://github.com/yarencheng/cve-devops-playground/blob/470a5f1c0d1bd36cd0a6327cda49cf96a1474588/content/CVE-2000-0395.md","https://github.com/Patrowl/PatrowlHearsData/blob/9b79b5eac5a874eeb91f0d9e37084feed8b830f5/CVE/data/2000/CVE-2000-0395.json","https://github.com/github/advisory-database/blob/cdfc8886d71af7ef3bdab3e4db46753ff8af6538/advisories/unreviewed/2022/04/GHSA-g5p4-qw97-m7r5/GHSA-g5p4-qw97-m7r5.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/olbat/nvdcve/blob/39f1db26eec9899ab2f8110ab3b45424c6fe9ec2/nvdcve/CVE-2000-0395.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_152400_152500.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001384.txt","https://github.com/nomi-sec/CVE-Easy-List/blob/839e2559933f5ff6cd50b4768fd382827d790668/2000.tsv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0325.toml"},{"ave_id":"AVE-2000-0323","file_name":"2000/AVE-2000-0323.toml","cve_id":"CVE-2000-0393","title":"KDE kscd SHELL 环境变量未丢弃特权导致本地权限提升漏洞","description":"KDE 桌面环境中的 kscd（CD 播放器）程序存在权限提升漏洞。该程序在执行用户 SHELL 环境变量中指定的程序时，未正确丢弃其特权（setuid 权限），导致本地用户可通过将 SHELL 环境变量设置为恶意程序来获取提升后的权限。攻击者只需拥有本地系统访问权限，即可利用此漏洞以 kscd 程序的权限执行任意代码，实现本地权限提升。该漏洞影响 KDE 1.1、1.1.1、1.2 及 2.0 版本，CVSS 评分 7.2，危害等级高。","severity":"HIGH","score":7.2,"aliases":["CVE-2000-0393"],"sources":["exploitdb"],"published":"2000-05-16T04:00:00.000","updated":"2026-06-16T21:51:37.347","remediation":"升级 KDE 至 2.1 及以上版本，或移除 kscd 二进制文件的 setuid 特权位（chmod u-s /usr/bin/kscd）。如无法升级，可通过在 /etc/profile 中过滤 SHELL 环境变量或限制 kscd 仅允许受信任用户执行来缓解。","status":"completed","collected_at":"2026-07-20T00:00:00Z","references":["http://archives.neohapsis.com/archives/bugtraq/2000-05/0172.html","http://www.novell.com/linux/security/advisories/suse_security_announce_50.html","http://www.securityfocus.com/bid/1206","https://www.exploit-db.com/exploits/19915","https://github.com/CVEProject/cvelistV5/blob/d00c4bdddf18e05c46df568e8ae91e7912ce321c/cves/2000/0xxx/CVE-2000-0393.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0393","https://github.com/yarencheng/cve-devops-playground/blob/470a5f1c0d1bd36cd0a6327cda49cf96a1474588/content/CVE-2000-0393.md","https://github.com/Patrowl/PatrowlHearsData/blob/9b79b5eac5a874eeb91f0d9e37084feed8b830f5/CVE/data/2000/CVE-2000-0393.json","https://github.com/github/advisory-database/blob/cdfc8886d71af7ef3bdab3e4db46753ff8af6538/advisories/unreviewed/2022/04/GHSA-ph8q-v7mf-3mfr/GHSA-ph8q-v7mf-3mfr.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_152400_152500.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_3.list.dict","https://github.com/olbat/nvdcve/blob/39f1db26eec9899ab2f8110ab3b45424c6fe9ec2/nvdcve/CVE-2000-0393.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001383.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0323.toml"},{"ave_id":"AVE-2000-0320","file_name":"2000/AVE-2000-0320.toml","cve_id":"CVE-2000-0389","title":"{\"_meta\":{},\"stopReason\":\"end_turn\",\"usage\":{\"inputTokens\":10913,\"outputTokens\":34,\"totalTokens\":10947}}","description":"Kerberos 4 与 5 的 krb_rd_req() 函数存在缓冲区溢出漏洞。该函数在处理远程认证请求时未对输入长度做边界校验，导致攻击者可通过向运行 Kerberos 服务的目标主机发送特制的畸形 Kerberos 请求数据包，触发栈缓冲区溢出并覆盖返回地址。受影响产品包括 Cygnus Network Security 4.0、KerbNet 5.0、MIT Kerberos 4/5 及 RedHat 6.2 等启用了 Kerberos 兼容性的系统。未经身份认证的远程攻击者利用此漏洞可成功执行任意代码，进而获取目标系统的 root 权限，实现完全控制。","severity":"CRITICAL","score":10.0,"aliases":["CVE-2000-0389"],"sources":["exploitdb"],"published":"2000-05-16T04:00:00.000","updated":"2026-06-16T21:51:36.847","remediation":"升级到 MIT Kerberos 5 1.1.1 及以上修复版本（或 Cygnus 发布的补丁版），RedHat 6.2 用户执行 `up2date krb5` 安装 RHSA-2000:025 安全更新。在无法立即升级时，通过防火墙/ACL 限制 88、749、750 等 Kerberos 端口仅对受信任网段开放，并关闭不必要的 krb4 兼容服务，以缓解远程溢出风险。","status":"completed","collected_at":"2026-07-20T00:00:00Z","references":["http://archives.neohapsis.com/archives/bugtraq/2000-05/0184.html","http://archives.neohapsis.com/archives/freebsd/2000-05/0295.html","http://www.cert.org/advisories/CA-2000-06.html","http://www.redhat.com/support/errata/RHSA-2000-025.html","http://www.securityfocus.com/bid/1220","https://www.exploit-db.com/exploits/19926","https://github.com/CVEProject/cvelistV5/blob/d00c4bdddf18e05c46df568e8ae91e7912ce321c/cves/2000/0xxx/CVE-2000-0389.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0389","https://github.com/yarencheng/cve-devops-playground/blob/1fe9b156eeeb72b8f8baa50bbe7bc0d9806e8c64/content/CVE-2000-0389.md","https://github.com/Patrowl/PatrowlHearsData/blob/24512263eb77d6af2cecd67bd2460f761fc94bea/CVE/data/2000/CVE-2000-0389.json","https://github.com/github/advisory-database/blob/cdfc8886d71af7ef3bdab3e4db46753ff8af6538/advisories/unreviewed/2022/04/GHSA-4jvw-4fhr-v7mv/GHSA-4jvw-4fhr-v7mv.json","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/K/kerberos_overflow.nasl","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_152400_152500.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_1.list.dict","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001381.txt","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--f31f31af-8610-4da2-9ce2-4cc8bbb2bc13.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0320.toml"},{"ave_id":"AVE-2000-0312","file_name":"2000/AVE-2000-0312.toml","cve_id":"CVE-2000-0379","title":"Netopia R9100 路由器 SNMP 配置绕过未授权修改漏洞","description":"Netopia R9100 路由器 SNMP 表格写入权限绕过漏洞。该设备在管理员已配置禁止修改 SNMP 表格的情况下，仍无法阻止已认证用户通过 SNMP 协议对设备 MIB 表格执行写入操作，导致 SNMP 访问控制策略被绕过。影响范围为运行 4.6.2 版本的 Netopia R 系列路由器（含 R9100 等型号）。攻击条件为攻击者需先通过 Telnet 或 SSH 等途径获得设备的本地认证权限，随后即可利用 SNMP SET 请求篡改 SNMP 表格中的配置项，造成路由器配置信息被非法修改，潜在影响网络设备的正常运行与安全管理。CVSS 评分为 3.6，危害等级低。","severity":"LOW","score":3.6,"aliases":["CVE-2000-0379"],"sources":["exploitdb"],"published":"2000-05-16T04:00:00.000","updated":"2026-06-16T21:51:35.633","remediation":"Netopia R9100 路由器已于 2004 年随 Netopia 被 Motorola 收购后停止维护，厂商已不再提供固件更新。建议立即升级到最新可用固件版本（如有），并在 SNMP 配置中设置严格的访问控制列表（ACL），仅允许受信管理 IP 访问 UDP 161/162 端口；将 SNMP 默认 community 字符串从 public/private 改为强随机字符串；禁用 SNMP 写操作（set 操作）或降级为只读模式；如条件允许，建议更换为仍在厂商支持周期内的路由器设备。作为临时缓解措施，可在网络边界防火墙封禁对 SNMP 端口的外部访问。","status":"completed","collected_at":"2026-07-20T00:00:00Z","references":["http://www.netopia.com/equipment/purchase/fmw_update.html","http://www.securityfocus.com/bid/1177","http://www.securityfocus.com/templates/archive.pike?list=1&msg=200005082054.NAA32590%40linux.mtndew.com","https://www.exploit-db.com/exploits/19901","https://github.com/CVEProject/cvelistV5/blob/712a40967986b700313860b08048435be4fa9839/cves/2000/0xxx/CVE-2000-0379.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0379","https://github.com/yarencheng/cve-devops-playground/blob/1fe9b156eeeb72b8f8baa50bbe7bc0d9806e8c64/content/CVE-2000-0379.md","https://github.com/Patrowl/PatrowlHearsData/blob/248c2167e720df96125f6ac9925793063a207510/CVE/data/2000/CVE-2000-0379.json","https://github.com/github/advisory-database/blob/cdfc8886d71af7ef3bdab3e4db46753ff8af6538/advisories/unreviewed/2022/04/GHSA-p59f-g5mj-4hqq/GHSA-p59f-g5mj-4hqq.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/olbat/nvdcve/blob/63d4031680b3d3fa77b826660a1e30ffc70ff5cd/nvdcve/CVE-2000-0379.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_152300_152400.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_2.list.dict","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001380.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0312.toml"}]