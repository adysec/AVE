ata/1999/CVE-1999-0027.json","https://github.com/mabitoski/cve_submodules/blob/44ad7e2705b3aef1b2ffaf64bd47596c10a6c2e4/1999/CVE-1999-0027.md","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0027.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_5.list.dict","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--60ca74b6-b0cd-4c03-8943-6965af58ba33.json","https://github.com/UNCG-CSE/Open_Source_Vul_Metrics/blob/a2633869ec2973f7b8a97d5de72093cc36ac02d8/src/NVD/NVD_JSONtoCSV.ipynb"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0083.toml"},{"ave_id":"AVE-1999-0089","file_name":"1999/AVE-1999-0089.toml","cve_id":"CVE-1999-0029","title":"SGI IRIX ordist 本地权限提升漏洞","description":"SGI IRIX 5.3 及 6.2 系统中的 ordist 命令存在缓冲区溢出漏洞，本地攻击者可向 ordist 命令提交特制请求触发缓冲区越界读取，从而获取系统 root 权限。该漏洞影响 SGI IRIX 5.3 和 6.2 版本，利用前提是攻击者拥有本地系统访问权限，属于本地权限提升漏洞。","severity":"HIGH","score":8.4,"aliases":["CVE-1999-0029"],"sources":["exploitdb"],"published":"1997-07-16T04:00:00.000","updated":"2026-06-16T21:47:23.303","remediation":"安装 SGI 于 1997 年发布的 ordist 安全补丁（SGI Security Advisory 19970701），或升级到 IRIX 6.3 及以上版本。如无法升级，建议移除 ordist 的 setuid root 权限：chmod u-s /usr/sbin/ordist，并限制仅授信用户可本地登录系统。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0029","https://www.exploit-db.com/exploits/19317","https://github.com/CVEProject/cvelistV5/blob/dc83b9e6d88de194a14e3020b4e71ac42054e609/cves/1999/0xxx/CVE-1999-0029.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0029","https://github.com/cisagov/vulnrichment/blob/f47735aa52980ccd9473e