eX 及 EMBED 标签的调用权限。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://support.microsoft.com/default.aspx?scid=kb%3B%5BLN%5D%3BQ185959","http://support.microsoft.com/support/kb/articles/q176/6/97.asp"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1106.toml"}]