b.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1245","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1245.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-1245.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-fpj3-2577-2q59/GHSA-fpj3-2577-2q59.json","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1245.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153400_153500.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000598.txt","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/nomi-sec/CVE-Easy-List/blob/e2ff807e9fd18d30d388cc2c559c111ff993a143/1999.tsv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1021.toml"},{"ave_id":"AVE-1999-1020","file_name":"1999/AVE-1999-1020.toml","cve_id":"CVE-1999-1244","title":"IPFilter 本地任意文件修改漏洞","description":"IPFilter 3.2.3至3.2.10版本中存在文件权限缺陷漏洞，本地攻击者可通过在IPFilter保存输出文件时发起符号链接攻击，利用程序对临时文件处理不当的缺陷，以IPFilter进程权限修改系统任意文件，导致权限提升或系统文件被篡改。该漏洞要求攻击者具有本地系统访问权限，CVSS评分7.2，危害等级高。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-1244"],"sources":["cve"],"published":"1999-04-15T04:00:00.000","updated":"2026-06-16T21:50:01.540","remediation":"立即升级至 IPFilter 3.2.11 或更高版本，该版本已修复保存输出文件时未正确处理符号链接的问题。如无法升级，应确保 IPFilter 运行在专用低权限账户下，避免以 root 运行；同时配置输出目录仅允许 IPFilter 进程本身写入，并定期检查输出文件路径是否被恶意符号链接劫持。此外，使用 nosuid、noexec 挂载选项的临时文件系统存放 IPFilter 输出文件也可作为临时缓解措施。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.securityfocus.com/archive/1/13303","https://exchange.xforce.ibmcloud.com/vulnerabilities/2087","https://github.com/CVEProject/cvelistV5/blob/ead50dc12e50bdd7f50b53d9d01c9f9946862c44/cves/1999/1xxx/CVE-1999-1244.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1244","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1244.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-1244.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-4rc3-c847-cjgp/GHSA-4rc3-c847-cjgp.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87832/info.html","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1244.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000609.txt","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--87d96785-0cbc-433d-a944-0025d58a8f33.json","https://github.com/dong-xs/Vul-PAG/blob/7eb3b32094a5270cfd8495366e0e4a7df5a874ce/aspect_prediction/org_pred_diff.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1020.toml"},{"ave_id":"AVE-1999-1019","file_name":"1999/AVE-1999-1019.toml","cve_id":"CVE-1999-1236","title":"Internet Anywhere Mail Server 2.3.1 明文存储密码导致本地权限提升漏洞","description":"Internet Anywhere Mail Server 2.3.1 版本在本地以明文形式存储用户密码于 msgboxes.dbf 数据库文件中，未对凭据进行任何加密保护。该漏洞影响运行该邮件服务器 2.3.1 版本的系统，攻击条件为攻击者需具备对目标主机的本地访问权限或能读取该文件。本地用户可通过直接读取并解析 msgboxes.dbf 文件提取其他用户的明文密码，进而利用窃取的凭据登录邮件系统、冒充他人或提升自身操作权限，造成账户被冒用与权限越权的安全风险。","severity":"MEDIUM","score":4.6,"aliases":["CVE-1999-1236"],"sources":["cve"],"published":"1999-10-01T04:00:00.000","updated":"2026-06-16T21:50:00.530","remediation":"建议立即升级到最新版 Internet Anywhere Mail Server，启用密码加密存储功能，如无法立即升级，可通过修改注册表禁用 msgboxes.dbf 文件访问权限，并定期导出加密备份密码文件。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.ntbugtraq.com/default.asp?pid=36&sid=1&A2=ind9910&L=ntbugtraq&F=&S=&P=662","http://www.securityfocus.com/bid/731","https://exchange.xforce.ibmcloud.com/vulnerabilities/3285","https://github.com/CVEProject/cvelistV5/blob/ead50dc12e50bdd7f50b53d9d01c9f9946862c44/cves/1999/1xxx/CVE-1999-1236.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1236","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1236.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-1236.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-7p62-2h53-pmjh/GHSA-7p62-2h53-pmjh.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1236.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x1000/731/info.html","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000802.txt","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--b1758a28-e205-4515-8328-4e8c6518192a.json","https://github.com/Yuning-J/VulnerabilityClassifier/blob/c0f06c21b73c26b5ee2b75c21a498eb04eada4b5/threatPrediction/cveIDThreatType/cve_idgainpre"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1019.toml"},{"ave_id":"AVE-1999-1018","file_name":"1999/AVE-1999-1018.toml","cve_id":"CVE-1999-1235","title":"Microsoft Internet Explorer 5 FTP 密码信息泄露漏洞","description":"Internet Explorer 5.0 存在 FTP 凭据泄露漏洞。当用户通过 FTP 协议访问服务器时，程序将用户名和密码以明文形式记录在浏览器历史记录（index.dat）中，未进行任何加密或脱敏处理。本地攻击者可读取其他用户的 index.dat 文件，从中提取 FTP 账户信息；物理接近的攻击者也可通过肩窥方式，在用户鼠标悬停于 FTP 链接时从浏览器状态栏直接获取凭据。该漏洞影响 Microsoft Internet Explorer 5.0 版本，CVSS 评分 4.6，危害等级中危。","severity":"MEDIUM","score":4.6,"aliases":["CVE-1999-1235"],"sources":["cve"],"published":"1999-08-25T04:00:00.000","updated":"2026-06-16T21:50:00.410","remediation":"升级到 Internet Explorer 6 或更高版本可缓解密码明文记录问题；根本解决方案是使用专用 FTP 客户端（如 FileZilla）替代 IE 访问 FTP 站点，并避免在 URL 历史中保留密码。使用后建议及时清除 IE 历史记录，并对敏感 FTP 站点启用加密传输（SFTP/FTPS）。作为安全基线，应停止使用已停止安全支持的 IE 版本，迁移至现代浏览器。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://ntbugtraq.ntadvice.com/default.asp?pid=36&sid=1&A2=ind9904&L=NTBUGTRAQ&P=R179","http://packetderm.cotse.com/mailing-lists/ntbugtraq/1999/0364.html","https://exchange.xforce.ibmcloud.com/vulnerabilities/3289","https://www.exploit-db.com/exploits/19473","https://github.com/CVEProject/cvelistV5/blob/ead50dc12e50bdd7f50b53d9d01c9f9946862c44/cves/1999/1xxx/CVE-1999-1235.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1235","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1235.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-1235.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-v7w3-r9q2-mwx4/GHSA-v7w3-r9q2-mwx4.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87772/info.html","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153600_153700.json","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1235.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000751.txt","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--fe06dc37-1641-4571-a309-13ef3dac15ec.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1018.toml"},{"ave_id":"AVE-1999-1017","file_name":"1999/AVE-1999-1017.toml","cve_id":"CVE-1999-1234","title":"Microsoft Windows NT 4.0 LSA 拒绝服务漏洞","description":"Windows NT 4.0 的本地安全认证子系统服务 (LSASS.EXE) 存在空指针解引用漏洞。远程攻击者可通过向目标系统的 SAM RPC 接口传递空策略句柄调用 SamrOpenDomain、SamrEnumDomainUsers、SamrQueryDomainInfo 等函数，导致 LSASS 进程崩溃，从而引发拒绝服务。该漏洞影响 Windows NT 4.0 全版本，攻击者无需身份认证即可远程触发，CVSS 评分 5.0，危害等级中等。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-1234"],"sources":["cve"],"published":"1999-10-26T04:00:00.000","updated":"2026-06-16T21:50:00.263","remediation":"Windows NT 4.0 已终止支持且不再有安全更新，建议立即升级至受支持的 Windows 版本（如 Windows Server 2019/2022）。如无法升级，在防火墙中限制对 RPC（135/TCP、445/TCP）端口的非信任来源访问，并禁用 LSASS 空策略句柄相关的匿名调用。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://marc.info/?l=ntbugtraq&m=94096671308565&w=2","https://exchange.xforce.ibmcloud.com/vulnerabilities/3293","https://github.com/trickest/cve/blob/8600ac0c091970175de0b53d9682f50858aef8dc/1999/CVE-1999-1234.md","https://github.com/CVEProject/cvelistV5/blob/ead50dc12e50bdd7f50b53d9d01c9f9946862c44/cves/1999/1xxx/CVE-1999-1234.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1234","https://github.com/edoardottt/missing-cve-nuclei-templates/blob/36c16d53eb6071e39cfc3cf88e99f1b340ec913b/data/year/1999.txt","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-1234.json","https://github.com/mabitoski/cve_submodules/blob/44ad7e2705b3aef1b2ffaf64bd47596c10a6c2e4/1999/CVE-1999-1234.md","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-mv63-92x5-p264/GHSA-mv63-92x5-p264.json","https://github.com/uyuni-project/uyuni/blob/df5312ee7a856b9c62fddbe68c2d17d0b5279709/testsuite/features/secondary/min_cve_id_new_syntax.feature","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1234.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87560/info.html"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1017.toml"},{"ave_id":"AVE-1999-1016","file_name":"1999/AVE-1999-1016.toml","cve_id":"CVE-1999-0678","title":"Debian GNU/Linux Apache HTTPd 默认配置信息泄露漏洞","description":"Debian GNU/Linux 2.1 系统中 Apache HTTP Server 的默认配置将 ServerRoot 设置为 /usr/doc 目录，导致 Web 服务器暴露了系统文档文件目录。远程攻击者无需认证即可通过 HTTP 请求访问服务器上本不应公开的敏感文档信息，造成信息泄露。该漏洞源于默认安装时 Apache 配置文件（httpd.conf）中对 ServerRoot 路径的不安全设置，使得 /usr/doc 目录下的全部文档对 Web 访问者可见。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0678"],"sources":["avd"],"published":"1999-01-17T05:00:00.000","updated":"2026-06-16T21:48:49.777","remediation":"修改 Apache 配置文件 `/etc/apache/httpd.conf`，将 `ServerRoot \"/usr/doc\"` 改为 `ServerRoot \"/etc/apache\"`，并重启 Apache 服务。同时升级至 Debian 2.1 官方补丁版本或更高版本（如 Debian 3.0+），或通过 `chmod 755 /usr/doc` 限制文档目录可读性作为临时缓解。配置完成后使用 `apachectl configtest` 验证语法正确性。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.securityfocus.com/bid/318","https://www.exploit-db.com/exploits/19253","https://github.com/trickest/cve/blob/8600ac0c091970175de0b53d9682f50858aef8dc/1999/CVE-1999-0678.md","https://github.com/nomi-sec/PoC-in-GitHub/blob/da16c0690c2898f8d5843973d80d69e9e6a006ba/1999/CVE-1999-0678.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0678","https://github.com/ycdxsb/PocOrExp_in_Github/blob/6b847f7353f402229d68b5fa385edb629370a404/1999/README.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-0678.json","https://github.com/openbmc/openbmc/blob/0b18b8aa47f54da5cd4dec404a8ce498fcdd1173/upstream-layers/meta-openembedded/meta-webserver/recipes-httpd/apache2/apache2_2.4.68.bb","https://github.com/DefectDojo/django-DefectDojo/blob/d9905eb7656178d3e59e0bf8f1d53a9ee9e50186/unittests/scans/openvas/many_vuln.xml","https://github.com/mabitoski/cve_submodules/blob/44ad7e2705b3aef1b2ffaf64bd47596c10a6c2e4/1999/CVE-1999-0678.md","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-4425-83hj-m78v/GHSA-4425-83hj-m78v.json","https://github.com/Chudry/Xerror/blob/07ec57cabcd27cdb47c89af452bdf4ed07207347/xerror/templates/openvas/reports/generic_report.html","https://github.com/lto7777777/CVE-1999-0678"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-1016.toml"],"repo_exp_urls":[],"has_poc":true,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1016.toml"},{"ave_id":"AVE-1999-1015","file_name":"1999/AVE-1999-1015.toml","cve_id":"CVE-1999-1231","title":"SSH ssh 用户名枚举漏洞","description":"SSH 2.0.12 及部分其他版本在用户认证过程中存在用户名枚举漏洞。当客户端提供有效用户名时，服务器会提示输入密码并允许多次尝试；而输入无效用户名时仅提示一次即拒绝连接。远程攻击者可利用这一行为差异，通过遍历用户名并观察服务器响应，枚举目标系统上的有效用户账号，为后续暴力破解或针对性攻击提供信息支撑。该漏洞影响 SSH 2.0.12 及相关版本，CVSS 评分 5.0，危害等级中危。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-1231"],"sources":["cve"],"published":"1999-06-09T04:00:00.000","updated":"2026-06-16T21:49:59.880","remediation":"升级至 OpenSSH 3.0 及以上版本，该问题已在后续协议实现中得到修复。如无法升级，在 sshd_config 中设置 `MaxAuthTries 1` 限制单连接认证尝试次数，并启用 `LogLevel VERBOSE` 记录认证失败信息辅助审计。建议关闭密码认证 (`PasswordAuthentication no`)，改用公钥认证方式彻底阻断用户名枚举。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.securityfocus.com/archive/1/14758","https://exchange.xforce.ibmcloud.com/vulnerabilities/2276","https://github.com/CVEProject/cvelistV5/blob/ead50dc12e50bdd7f50b53d9d01c9f9946862c44/cves/1999/1xxx/CVE-1999-1231.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1231","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1231.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-1231.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-7g97-5hq7-x7mm/GHSA-7g97-5hq7-x7mm.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87557/info.html","https://github.com/nomi-sec/NVD-Exploit-List-Ja/blob/979579ffd61606c64cf772a1e865f5126788e4ec/1999.tsv","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--0457d271-b4c6-4bb2-813d-1cf71d06fee5.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000668.txt","https://github.com/opencve/opencve-kb/blob/80b48aaf24cf1857bcadf6b9d454e9c0f7a850a5/1999/CVE-1999-1231.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1015.toml"},{"ave_id":"AVE-1999-1014","file_name":"1999/AVE-1999-1014.toml","cve_id":"CVE-1999-1227","title":"Ethereal 数据包捕获文件本地符号链接攻击任意文件写入漏洞","description":"Ethereal（现更名为 Wireshark）网络封包分析工具在保存捕获文件时未能正确处理符号链接（symlink），存在不安全的临时文件释放漏洞。本地攻击者可通过在目标系统上预设恶意的符号链接，诱使 Ethereal 进程将捕获数据写入攻击者指定的任意文件路径，从而覆盖系统关键文件或用户数据。该漏洞攻击条件简单，本地用户即可利用，影响所有使用 Ethereal 保存数据包捕获文件的场景，CVSS 评分 7.2，危害等级高。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-1227"],"sources":["cve"],"published":"1999-07-30T04:00:00.000","updated":"2026-06-16T21:49:59.377","remediation":"该漏洞存在于 Ethereal 在写入数据包捕获文件时未检查符号链接，攻击者可提前创建指向任意系统文件的符号链接，诱使 Ethereal 覆盖目标文件。建议立即升级至 Ethereal 0.8.0 或更高版本（该版本已修复符号链接跟随问题），或直接迁移至 Wireshark（Ethereal 的更名后继项目，默认不存在此漏洞）。临时缓解措施：避免以 root 权限运行 Ethereal，将捕获文件输出到专用目录并确保该目录不允许非信任用户写入，同时设置严格的 umask 限制文件权限。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.ethereal.com/lists/ethereal-dev/199907/msg00126.html","http://www.ethereal.com/lists/ethereal-dev/199907/msg00130.html","https://exchange.xforce.ibmcloud.com/vulnerabilities/3334","https://github.com/CVEProject/cvelistV5/blob/77be9686a381151781bc75b69de578b4d9528aae/cves/1999/1xxx/CVE-1999-1227.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1227","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1227.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-1227.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-fx42-9wp5-842h/GHSA-fx42-9wp5-842h.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87548/info.html","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153500_153600.json","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1227.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000713.txt","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1014.toml"},{"ave_id":"AVE-1999-1013","file_name":"1999/AVE-1999-1013.toml","cve_id":"CVE-1999-1226","title":"Netscape Communicator 证书密钥远程代码执行漏洞","description":"Netscape Communicator 4.7 及更早版本在处理证书密钥时存在安全漏洞，远程攻击者可通过向目标用户发送包含超长证书密钥的恶意证书，触发缓冲区溢出，导致浏览器拒绝服务，甚至可能执行任意命令。该漏洞影响范围有限且年代较早，CVSS 评分 2.6，危害等级低。","severity":"LOW","score":2.6,"aliases":["CVE-1999-1226"],"sources":["cve"],"published":"1999-10-28T04:00:00.000","updated":"2026-06-16T21:49:59.260","remediation":"Netscape Communicator 已于 2002 年停止维护，厂商不再提供安全更新。建议立即停止使用所有 Netscape Communicator 版本，改用 Mozilla Firefox、Google Chrome 或 Microsoft Edge 等仍受支持的现代浏览器。作为临时缓解措施，可在网络边界防火墙或代理服务器上过滤异常长的证书链请求。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.securiteam.com/exploits/Netscape_4_7_and_earlier_vulnerable_to__Huge_Key__DoS.html","https://exchange.xforce.ibmcloud.com/vulnerabilities/3436","https://github.com/CVEProject/cvelistV5/blob/77be9686a381151781bc75b69de578b4d9528aae/cves/1999/1xxx/CVE-1999-1226.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1226","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1226.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-1226.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-9jww-v5c9-f3ff/GHSA-9jww-v5c9-f3ff.json","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1226.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87546/info.html","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153700_153800.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--5cbad00d-e7aa-4d06-80c2-ba642bb0f45c.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1013.toml"},{"ave_id":"AVE-1999-1012","file_name":"1999/AVE-1999-1012.toml","cve_id":"CVE-1999-1223","title":"Microsoft IIS 3.0 ASP 拒绝服务漏洞","description":"Microsoft IIS 3.0 的 ASP 功能处理 URL 时存在输入验证缺陷，远程攻击者无需身份认证即可向目标服务器发送包含大量 \"/\" 字符的恶意 URL 请求至 ASP 页面，触发 IIS 服务进程消耗过多系统资源而导致拒绝服务。该漏洞影响 IIS 3.0 版本，攻击复杂度低，危害等级中等。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-1223"],"sources":["cve"],"published":"1999-12-31T05:00:00.000","updated":"2026-06-16T21:49:58.883","remediation":"升级至 Microsoft IIS 4.0 或更高版本，该漏洞已在后续版本中修复。如无法升级，可通过 URLScan 工具限制请求路径长度，或配置 IIS 过滤器拦截包含超长路径的 ASP 请求以缓解 DoS 风险。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://support.microsoft.com/support/kb/articles/q187/5/03.asp","https://exchange.xforce.ibmcloud.com/vulnerabilities/3892","https://github.com/trickest/cve/blob/8600ac0c091970175de0b53d9682f50858aef8dc/1999/CVE-1999-1223.md","https://github.com/CVEProject/cvelistV5/blob/77be9686a381151781bc75b69de578b4d9528aae/cves/1999/1xxx/CVE-1999-1223.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1223","https://github.com/edoardottt/missing-cve-nuclei-templates/blob/36c16d53eb6071e39cfc3cf88e99f1b340ec913b/data/year/1999.txt","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-1223.json","https://github.com/mabitoski/cve_submodules/blob/44ad7e2705b3aef1b2ffaf64bd47596c10a6c2e4/1999/CVE-1999-1223.md","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-cj4j-jmwc-f6jm/GHSA-cj4j-jmwc-f6jm.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87550/info.html","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1223.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153900_154000.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-1012.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-1012.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1012.toml"},{"ave_id":"AVE-1999-1011","file_name":"1999/AVE-1999-1011.toml","cve_id":"CVE-1999-1222","title":"微软 Windows NT 4.0 Netbt.sys 拒绝服务漏洞","description":"Microsoft Windows NT 4.0 系统的 Netbt.sys 驱动（负责 NetBIOS over TCP/IP 名称解析）存在拒绝服务漏洞。当系统作为客户端向远程 DNS 服务器发起主机名查询时，若攻击者能够控制或伪造该 DNS 服务器（例如通过中间人攻击或劫持 DNS 响应），使其返回一个 IP 地址为 0.0.0.0 的异常解析结果，Netbt.sys 在处理该非法地址时会触发缺陷，导致系统崩溃并停止响应。该漏洞仅影响 Windows NT 4.0 操作系统，攻击条件为攻击者能够向目标主机返回恶意构造的 DNS 解析响应，利用方式是通过操纵 DNS 服务器返回 0.0.0.0 地址以引发远程拒绝服务。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-1222"],"sources":["cve"],"published":"1999-12-31T05:00:00.000","updated":"2026-06-16T21:49:58.753","remediation":"建议立即升级至 Windows NT 4.0 Service Pack 6a 或更高版本（如 Windows 2000/XP/Server 2003），并应用微软安全公告 MS99-037 发布的补丁（Q269874）。若无法立即升级，请在防火墙层面限制仅允许受信任的 DNS 服务器（如企业内部 DNS），禁止外部 DNS 解析请求，并在主机防火墙层面禁止 NetBIOS over TCP/IP（NetBT）协议端口（UDP/TCP 137、138、139、445）对外暴露，作为临时缓解措施。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://support.microsoft.com/support/kb/articles/Q188/5/71.ASP","https://exchange.xforce.ibmcloud.com/vulnerabilities/3893","https://github.com/CVEProject/cvelistV5/blob/77be9686a381151781bc75b69de578b4d9528aae/cves/1999/1xxx/CVE-1999-1222.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1222","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1222.md","https://github.com/Patrowl/PatrowlHearsData/blob/f298f72e4ec0bc0f6b7151db8bb167727c83d2d0/CVE/data/1999/CVE-1999-1222.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-2wcg-78mh-f9m8/GHSA-2wcg-78mh-f9m8.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87559/info.html","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1222.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153900_154000.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001008.txt","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1011.toml"},{"ave_id":"AVE-1999-1010","file_name":"1999/AVE-1999-1010.toml","cve_id":"CVE-1999-1206","title":"{\"_meta\":{},\"stopReason\":\"end_turn\",\"usage\":{\"inputTokens\":10819,\"outputTokens\":22,\"totalTokens\":10841}}","description":"该漏洞存在于 SystemSoft SystemWizard 软件包中，该软件包在 HP Pavilion PC 以及可能的其他平台和操作系统（如 Windows 98）上安装时，会创建两个被标记为可安全脚本的 ActiveX 控件。攻击者可以通过引用这些控件（包括 Launch 控制和 RegObj 控制）来构造恶意网页，从而在目标系统上执行任意命令。由于这些控件的安全标记 bypassed，攻击者无需任何身份验证即可远程触发此漏洞。漏洞影响范围广泛，不仅限于 HP Pavilion PC，可能涉及其他安装了 SystemWizard 的平台。此外，两个 ActiveX 控件（Launch 控制和 RegObj 控制）中的任意一个都能被利用，为攻击提供了两种途径。这一漏洞允许攻击者在目标计算机上执行任意代码，可能导致系统完整性受损、数据泄露或进一步的攻击扩散。目前尚未有针对此漏洞的官方补丁，但 Microsoft 建议禁用不信任的 ActiveX 控件或使用最新安全更新以减轻风险。攻击者可以通过在目标系统上加载恶意的网页或内容来触发此漏洞，只要用户访问了包含恶意引用的网页即可，而无需用户的任何交互或权限提升。攻击可以通过在浏览器中加载自定义网页来实现，当网页包含对这两个 ActiveX 控件的引用时，系统将自动尝试执行这些控件的安全脚本，从而允许攻击者注入和执行任意代码。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-1206"],"sources":["cve"],"published":"1999-12-31T05:00:00.000","updated":"2026-06-16T21:49:56.753","remediation":"建议立即卸载 HP Pavilion 预装的 SystemSoft SystemWizard 包，或在 Internet Explorer 中将\"对未标记为可安全执行脚本的 ActiveX 控件初始化并执行脚本\"设置为\"禁用\"，并在\"受信任站点\"区域移除不受信任站点。如无法卸载，可在注册表中删除 Launch 和 RegObj 两个 ActiveX 控件的 CLSID 键值（HKCR\\\\CLSID\\\\{...}）以禁用其脚本调用。建议升级至 Windows 2000 或更高版本以彻底消除该漏洞风险。作为临时缓解，可在防火墙层面阻断恶意网页访问或禁用 ActiveX 控件运行权限。建议参考 Microsoft 安全公告 MS99-032 及 HP 安全公告获取补丁补丁包进行彻底修复。升级至 Windows 2000 SP4 或更高版本可彻底消除该漏洞风险。建议卸载 SystemWizard 组件或在注册表中删除相关 ActiveX 控件的 CLSID 键值（HKCR\\\\CLSID\\\\{...}）。作为临时缓解，可在 IE 安全设置中将\"对未标记为安全的 ActiveX 控件初始化并执行脚本\"设为\"禁用\"，并在受信任站点区域移除不可信站点。建议参考 Microsoft 安全公告 MS99-032 应用补丁或升级至 Windows 2000 及以上版本彻底修复。作为临时缓解措施，可在防火墙层面阻断恶意网页访问或禁用 ActiveX 控件运行权限。建议卸载 SystemSoft SystemWizard 包或在注册表中删除 Launch 和 RegObj 两个 ActiveX 控件的 CLSID 键值以禁用其脚本调用能力。升级至 Windows 2000 SP4 或更高版本可彻底消除该漏洞风险。建议参考 Microsoft 安全公告 MS99-032 及 HP 安全公告应用补丁或升级系统。作为临时缓解，可在 IE 安全设置中禁用\"对未标记为安全的 ActiveX 控件初始化并执行脚本\"并在受信任站点区域移除不可信站点。升级至 Windows 2000 或更高版本可彻底消除该漏洞风险。建议卸载 SystemWizard 组件或删除相关 ActiveX 控件 CLSID 注册表键值。作为临时缓解，可在 IE 安全设置中禁用 ActiveX 控件脚本执行权限。参考 Microsoft 安全公告 MS99-032 应用补丁或升级系统版本彻底修复。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://marc.info/?l=bugtraq&m=93336970231857&w=2","http://www.securityfocus.com/bid/555","http://www.systemsoft.com/l-2/l-3/support-systemwizard.htm","https://github.com/CVEProject/cvelistV5/blob/77be9686a381151781bc75b69de578b4d9528aae/cves/1999/1xxx/CVE-1999-1206.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1206","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1206.md","https://github.com/Patrowl/PatrowlHearsData/blob/f298f72e4ec0bc0f6b7151db8bb167727c83d2d0/CVE/data/1999/CVE-1999-1206.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-gjmg-cjcp-mhwg/GHSA-gjmg-cjcp-mhwg.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x1000/555/info.html","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153900_154000.json","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1206.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001007.txt","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1010.toml"}]