[{"ave_id":"AVE-1999-0847","file_name":"1999/AVE-1999-0847.toml","cve_id":"CVE-1999-1004","title":"Symantec Norton AntiVirus NAV2000 POProxy POP服务器缓冲区溢出漏洞","description":"Norton AntiVirus 2000 (NAV2000) 附带的 POP3 代理服务器 POProxy 组件存在缓冲区溢出漏洞。未经认证的远程攻击者可通过向目标 POP3 服务发送精心构造的超长 USER 命令，触发缓冲区溢出，导致服务崩溃或可能执行任意代码。该漏洞影响安装 NAV2000 的 Windows 系统，CVSS 评分 5.0，危害等级中等，需升级至不受影响版本。","severity":"MEDIUM","score":5,"aliases":["CVE-1999-1004"],"sources":["cve"],"published":"1999-12-16T05:00:00.000","updated":"2026-06-16T21:49:30.250","remediation":"立即安装 Symantec 为 NAV2000 发布的 POProxy 安全补丁（文档 ID: 6206f660a1f2516a882568660082c930），或升级到 Norton AntiVirus 2001 及以上版本。如暂时无法更新，可禁用 POP3 邮件扫描功能以关闭 POProxy 服务，或在防火墙中限制对 TCP 110 端口的非信任来源访问作为临时缓解措施。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://service1.symantec.com/SUPPORT/nav.nsf/df0a595864594c86852567ac0063608c/6206f660a1f2516a882568660082c930?OpenDocument&Highlight=0%2Cpoproxy","http://www.osvdb.org/6267","http://www.securityfocus.com/archive/1/38970","http://www.securityfocus.com/archive/1/39194","https://github.com/CVEProject/cvelistV5/blob/b78238ce198ba9bb84cf32286dd81a9973f793b6/cves/1999/1xxx/CVE-1999-1004.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1004","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-1004.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-1004.md","https://github.com/Patrowl/PatrowlHearsData/blob/04a84e78299e2aeaab4d2594fc26f920778c7b06/CVE/data/1999/CVE-1999-1004.json","https://github.com/github/advisory-database/blob/1b2e09705f0816776a0a8a0cd6fc1208d25f09b2/advisories/unreviewed/2022/04/GHSA-4gvq-7hq9-g637/GHSA-4gvq-7hq9-g637.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https: