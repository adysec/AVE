[{"ave_id":"AVE-1999-0741","file_name":"1999/AVE-1999-0741.toml","cve_id":"CVE-1999-0947","title":"AN-HTTPd 1.2b CGI 远程命令执行漏洞","description":"AN-HTTPd 1.2b 自带的示例 CGI 脚本（test.bat、input.bat、input2.bat、envout.bat）未对用户输入进行有效过滤，远程攻击者可通过向这些脚本提交包含 shell 元字符（如管道符、分号等）的恶意请求，在服务器端执行任意系统命令。该漏洞影响 AN-HTTPd 1.2b 版本，CVSS 评分 7.5，危害等级高，攻击无需身份认证，利用难度低。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0947"],"sources":["epss"],"published":"1999-11-02T05:00:00.000","updated":"2026-06-16T21:49:23.150","remediation":"立即删除 AN-HTTPd 安装目录下的 test.bat、input.bat、input2.bat、envout.bat 等示例 CGI 脚本，或升级到已修复该问题的最新版本。如无法升级，在 Web 服务器配置中禁止 .bat 文件作为 CGI 执行，并限制 CGI 目录仅允许必要的脚本运行。","status":"completed","collected_at":"2026-07-19T00:00:00Z","references":["http://marc.info/?l=bugtraq&m=94157187815629&w=2","http://www.securityfocus.com/bid/762","https://www.exploit-db.com/exploits/19587","https://github.com/CVEProject/cvelistV5/blob/58316128f65d22a226717ff1f92ebf2058e46bc6/cves/1999/0xxx/CVE-1999-0947.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0947","https://github.com/yarencheng/cve-devops-playground/blob/1fe9b156eeeb72b8f8baa50bbe7bc0d9806e8c64/content/CVE-1999-0947.md","https://github.com/Patrowl/PatrowlHearsData/blob/4d2ed764072119c12b6f84e6ee4e0df62586a8c4/CVE/data/1999/CVE-1999-0947.json","https://github.com/github/advisory-database/blob/95e6ff620d5494b93ba2234edfcf6a45187dc0a8/advisories/unreviewed/2022/04/GHSA-gf4v-c89c-j9v4/GHSA-gf4v-c89c-j9v4.json","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/snort/drop-rules/sid-msg.map","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/A/an_httpd_cgis.nasl","https://github.com/jdkoftinoff/mb-linux-msli/blob/8adb103e34af9ff1d8d122e9ee2a1808836f0a14/uClinux-dist/user/snort/drop-rules/web-cgi.rules","https://github.com/olbat/nvdcve/blob/63d4031680b3d3fa77b826660a1e30ffc70ff5cd/nvdcve/CVE-1999-0947.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0741.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0741.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0741.toml"},{"ave_id":"AVE-1999-0740","file_name":"1999/AVE-1999-0740.toml","cve_id":"CVE-1999-0946","title":"Yamaha MidiPlug 缓冲区溢出漏洞","description":"Yamaha MidiPlug 1.1 b-j 版本存在缓冲区溢出漏洞，攻击者可通过向 EMBED 标签中的 Text 变量传递超长字符串触发该漏洞，导致目标系统拒绝服务或执行任意代码。该漏洞影响 Yamaha MidiPlug 1.1 b-j 版本，CVSS 评分 5.1，危害等级中危。攻击者需诱使用户访问包含恶意 EMBED 标签的页面以完成利用。","severity":"MEDIUM","score":5.1,"aliases":["CVE-1999-0946"],"sources":["epss"],"published":"1999-11-02T05:00:00.000","updated":"2026-06-16T21:49:23.023","remediation":"立即卸载 Yamaha MidiPlug 1.1 b-j 组件，通过控制面板\"添加/删除程序\"执行卸载。如无法卸载，手动删除注册表 HKEY_LOCAL_MACHINE\\SOFTWARE\\Yamaha\\MidiPlug 项及浏览器插件目录中的 MidiPlug.dll 文件。临时缓解措施：在浏览器中禁用 ActiveX 控件执行权限，或使用组策略阻止 EMBED 标签加载 MidiPlug 插件。建议迁移至 Web MIDI API 等现代方案替代该过时组件。","status":"completed","collected_at":"2026-07-19T00:00:00Z","references":["http://marc.info/?l=bugtraq&m=94157187815629&w=2","http://www.securityfocus.com/bid/760","https://www.exploit-db.com/exploits/19585","https://github.com/CVEProject/cvelistV5/blob/58316128f65d22a226717ff1f92ebf2058e46bc6/cves/1999/0xxx/CVE-1999-0946.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0946","https://github.com/yarencheng/cve-devops-playground/blob/1fe9b156eeeb72b8f8baa50bbe7bc0d9806e8c64/content/CVE-1999-0946.md","https://github.com/Patrowl/PatrowlHearsData/blob/4d2ed764072119c12b6f84e6ee4e0df62586a8c4/CVE/data/1999/CVE-1999-0946.json","https://github.com/github/advisory-database/blob/95e6ff620d5494b93ba2234edfcf6a45187dc0a8/advisories/unreviewed/2022/04/GHSA-56v6-ch4g-8qmx/GHSA-56v6-ch4g-8qmx.json","https://github.com/mitre/cti/blob/ea1adfe1a68ca3dcfe2dd883180b8cf10a988824/capec/2.1/attack-pattern/attack-pattern--8e403d18-af4e-4abd-bd38-0f99f74b4636.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/olbat/nvdcve/blob/63d4031680b3d3fa77b826660a1e30ffc70ff5cd/nvdcve/CVE-1999-0946.json","https://github.com/karimsammouri/capec_threat_modeling/blob/bec278e83cd0bd379b9e82a38e87b0be5fbd86d3/capec/46.csv","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153700_153800.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0740.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0740.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0740.toml"},{"ave_id":"AVE-1999-0743","file_name":"1999/AVE-1999-0743.toml","cve_id":"CVE-1999-0949","title":"Canna canuum 程序本地缓冲区溢出漏洞","description":"Canna 日文输入系统的 canuum 程序存在本地缓冲区溢出漏洞。攻击者可通过 -k、-c 和 -n 选项传入超长参数触发溢出，由于 canuum 以 SUID root 权限安装，本地低权限用户可利用此漏洞获得 root 权限，完全控制系统。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0949"],"sources":["cve","avd","exploitdb"],"published":"1999-11-02","updated":"1999-11-02","remediation":"临时缓解措施：移除 canuum 的 SUID 权限，执行 chmod u-s /usr/jp/canna/bin/canuum。长期修复：升级 Canna 输入系统至修复该缓冲区溢出的版本，或重新编译安装最新稳定版。","status":"completed","collected_at":"2026-07-18T00:00:00Z","references":["https://nvd.nist.gov/vuln/detail/CVE-1999-0949","https://cve.mitre.org/cgi-bin/cvename.cgi?name=CVE-1999-0949","http://www.securityfocus.com/bid/758","https://www.exploit-db.com/exploits/19583"],"poc_urls":["https://www.exploit-db.com/exploits/19583"],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0743.toml"},{"ave_id":"AVE-1999-1149","file_name":"1999/AVE-1999-1149.toml","cve_id":"CVE-1999-1517","title":"Amanda 备份系统 runtar 本地权限提升漏洞","description":"Amanda 备份系统（广泛用于多种 UNIX 操作系统，包括 FreeBSD）中的 runtar 组件会以 root 权限执行 tar 命令。由于权限控制不当，本地普通用户可通过向 runtar 提供特制的目标文件参数，使其以 root 身份读取或覆盖系统中的任意文件。该漏洞影响使用 Amanda 备份软件且未修复的 UNIX/Linux 系统，攻击条件为攻击者需拥有目标系统的本地低权限账户，利用方式是通过构造恶意参数调用 runtar 触发越权文件访问，可能导致敏感信息泄露或系统完整性被破坏。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-1517"],"sources":["cve"],"published":"1999-11-01T05:00:00.000","updated":"2026-06-16T21:50:36.593","remediation":"tags. Let me provide that.<value>升级 Amanda 到包含修复的版本（社区版 3.5 及以上），或限制 runtar 的 setuid 权限，确保只有授权管理员可执行 Amanda 管理命令。同时建议使用最小权限原则运行备份服务。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://marc.info/?l=bugtraq&m=94148942818975&w=2","http://www.securityfocus.com/bid/750","https://github.com/CVEProject/cvelistV5/blob/c271719fd48dcc28619dc324e441b822d7b4bace/cves/1999/1xxx/CVE-1999-1517.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1517","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1517.md","https://github.com/Patrowl/PatrowlHearsData/blob/1e2d061a60b9c6823d20cc72e51f709fadad54d2/CVE/data/1999/CVE-1999-1517.json","https://github.com/github/advisory-database/blob/34b62e277bf442e4eb38ef0850d7b24d296e6a74/advisories/unreviewed/2022/04/GHSA-5j68-mxr4-4v27/GHSA-5j68-mxr4-4v27.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x1000/750/info.html","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1517.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153800_153900.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/nomi-sec/CVE-Easy-List/blob/8200d63179d89b9076027cd96356d55ef8a5349e/1999.tsv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1149.toml"},{"ave_id":"AVE-1999-0653","file_name":"1999/AVE-1999-0653.toml","cve_id":"CVE-1999-0854","title":"Ultimate Bulletin Board cgi-bin 目录敏感信息泄露漏洞","description":"Ultimate Bulletin Board 将数据文件存储在 cgi-bin 可执行目录中，当 HTTP 服务器尝试执行这些数据文件时触发执行错误，导致文件内容以明文形式返回给远程攻击者，造成敏感数据（如用户帐号、密码哈希、配置信息）泄露。攻击者无需认证即可远程直接访问 cgi-bin 目录下的数据文件触发错误泄露，影响 Ultimate Bulletin Board 5.x 等版本，攻击者可直接获取敏感数据库文件，导致论坛用户数据泄露及后台接管风险。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0854"],"sources":["epss"],"published":"1999-11-01T05:00:00.000","updated":"2026-06-16T21:49:11.770","remediation":"建议升级 Ultimate Bulletin Board 至 5.0 或更高版本（已将数据文件移出 cgi-bin 目录）。若无法升级，请在 Web 服务器配置中禁止直接访问 cgi-bin 目录下的数据文件（如配置 Apache 的 ScriptAlias 仅执行 CGI 脚本，禁止静态文件访问），或将 UBB 数据文件目录移至 Web 根目录之外，并设置正确的文件系统权限限制 Web 进程读取权限。","status":"completed","collected_at":"2026-07-18T00:00:00Z","references":["http://www.securityfocus.com/templates/archive.pike?list=1&date=2000-02-22&msg=NDBBLKOPOLNKELHPDEFKIEPGCAAA.renzo.toma%40veronica.nl","http://www.ultimatebb.com/home/versions.shtml","https://github.com/CVEProject/cvelistV5/blob/e2218edc43f34225d168835de417dff40749bef5/cves/1999/0xxx/CVE-1999-0854.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0854","https://github.com/yarencheng/cve-devops-playground/blob/5cf8ba64f356efe9269b21eca2f657231acd746c/content/CVE-1999-0854.md","https://github.com/Patrowl/PatrowlHearsData/blob/2119b082f4927b0a9c902ed9fe95efb3b301cb81/CVE/data/1999/CVE-1999-0854.json","https://github.com/github/advisory-database/blob/645f3b3aab113438413618cef41319453f39d643/advisories/unreviewed/2022/04/GHSA-g7j6-6964-v5qv/GHSA-g7j6-6964-v5qv.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x89000/88370/info.html","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0854.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153700_153800.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000843.txt","https://github.com/nomi-sec/CVE-Easy-List/blob/44b40554314aa90807d3ddee27488f8c21cbcd40/1999.tsv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0653.toml"],"repo_exp_urls":[],"has_poc":true,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0653.toml"},{"ave_id":"AVE-1999-0615","file_name":"1999/AVE-1999-0615.toml","cve_id":"CVE-1999-0829","title":"HP Secure Web Console 弱加密漏洞","description":"HP Secure Web Console 使用弱加密算法保护敏感数据传输，导致攻击者可通过中间人攻击或密文分析破解加密通信，窃取或篡改管理控制台传输的敏感信息（如管理凭据、配置数据）。该漏洞影响 HP Secure Web Console 早期版本，攻击者需处于网络中间位置（如同一局域网、ARP 欺骗、路由劫持）即可实施被动窃听或主动篡改攻击，利用弱加密算法的已知弱点（如密钥长度过短、算法已知漏洞）还原明文，进而获取管理控制台权限或窃取敏感配置数据。建议升级至修复版本并强制启用强加密套件（如 TLS 1.2+、AES-GCM）。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0829"],"sources":["epss"],"published":"1999-11-01T05:00:00.000","updated":"2026-06-16T21:49:08.690","remediation":"升级到 HP Secure Web Console 1.0 之后修复该弱加密问题的固件版本（具体以 HP 官方发布的安全补丁为准）；在无法立即升级前，应禁用通过 Web Console 的远程明文管理访问，改为通过本地串口或带外管理网络访问，并在边界防火墙限制仅允许受信任管理 IP 访问 443 端口，同时强制启用强密码认证以缓解弱加密带来的信息泄露风险。","status":"completed","collected_at":"2026-07-18T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0829","https://github.com/CVEProject/cvelistV5/blob/8d7a64f7f43d1af6189d4f7237515b997555b777/cves/1999/0xxx/CVE-1999-0829.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0829","https://github.com/yarencheng/cve-devops-playground/blob/5cf8ba64f356efe9269b21eca2f657231acd746c/content/CVE-1999-0829.md","https://github.com/Patrowl/PatrowlHearsData/blob/be19cdaa6196942fd4096a42a1eaf047a8584298/CVE/data/1999/CVE-1999-0829.json","https://github.com/github/advisory-database/blob/90b464bbc2d1b64270a5771429f96b67fbe9e79b/advisories/unreviewed/2022/04/GHSA-j4xq-4vj2-xm3m/GHSA-j4xq-4vj2-xm3m.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0829.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87996/info.html","https://github.com/olbat/nvdcve/blob/134977c5f4ce4f427a914ca161b4f075e34b560b/nvdcve/CVE-1999-0829.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0615.toml"},{"ave_id":"AVE-1999-0605","file_name":"1999/AVE-1999-0605.toml","cve_id":"CVE-1999-0827","title":"Microsoft Internet Explorer 跨域框架导航漏洞","description":"Internet Explorer 5.0及更早版本默认启用\"跨不同域的导航子框架\"选项，导致攻击者可通过构造恶意网页嵌入跨域框架，实施框架欺骗攻击。攻击者可利用该漏洞在受害者浏览器中伪造合法网站的框架内容，窃取用户敏感信息或实施钓鱼攻击。该漏洞影响IE 5.0及更早版本，CVSS评分2.6，属低危漏洞，攻击者需诱导用户访问恶意页面方可触发。","severity":"LOW","score":2.6,"aliases":["CVE-1999-0827"],"sources":["epss"],"published":"1999-11-01T05:00:00.000","updated":"2026-06-16T21:49:08.450","remediation":"在IE浏览器注册表中禁用\"Navigate sub-frames across different domains\"功能（HKEY_CURRENT_USER\\Software\\Microsoft\\Internet Explorer\\Main\\FeatureControl\\FEATURE_WINDOW_RESTRICTIONS），防止iframe劫持攻击。","status":"completed","collected_at":"2026-07-18T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0827","https://github.com/CVEProject/cvelistV5/blob/d08a5c34806fec51f3d6c8b496ad617d8294f215/cves/1999/0xxx/CVE-1999-0827.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0827","https://github.com/yarencheng/cve-devops-playground/blob/5cf8ba64f356efe9269b21eca2f657231acd746c/content/CVE-1999-0827.md","https://github.com/Patrowl/PatrowlHearsData/blob/c8b0fec8b23470355b47059dbab5d2ebdfa2ac94/CVE/data/1999/CVE-1999-0827.json","https://github.com/github/advisory-database/blob/90b464bbc2d1b64270a5771429f96b67fbe9e79b/advisories/unreviewed/2022/04/GHSA-j8g6-fjj9-gc55/GHSA-j8g6-fjj9-gc55.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0827.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000842.txt","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x89000/88097/info.html"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0605.toml"},{"ave_id":"AVE-1999-0024","file_name":"1999/AVE-1999-0024.toml","cve_id":"CVE-1999-0354","title":"Microsoft Internet Explorer 与 Word 97 模板 Visual Basic 任意代码执行漏洞","description":"Microsoft Internet Explorer 4.x/5.x 与 Word 97 集成时存在安全漏洞。当用户通过 IE 浏览包含恶意 Word 97 模板的网页时，浏览器不会对模板中内嵌的可执行 Visual Basic 代码发出安全警告，导致攻击者可在用户 IE 客户端上下文中执行任意 VBA 程序。该漏洞也影响 Microsoft Outlook 客户端，当用户预览或打开包含恶意 Word 模板附件的邮件时同样会触发。攻击者可通过构造特制的 Word 文档或 HTML 邮件诱使用户打开，从而在目标系统上执行任意代码，完全控制受影响的系统。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0354"],"sources":["cve"],"published":"1999-11-01","updated":"2026-06-16","remediation":"安装 Microsoft 提供的安全公告 MS99-002 对应补丁程序，该补丁可在文档基于含宏的模板启动时弹出安全警告。同时建议在 Word 中将宏安全级别设置为「高」或「禁用所有宏并发出通知」，并避免打开来自不受信任来源的 Office 文档。对于 Outlook，建议禁用预览窗格或使用受保护的视图功能。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["https://docs.microsoft.com/en-us/security-updates/securitybulletins/1999/ms99-002"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0024.toml"},{"ave_id":"AVE-1999-1195","file_name":"1999/AVE-1999-1195.toml","cve_id":"CVE-1999-1577","title":"{\"_meta\":{},\"stopReason\":\"end_turn\",\"usage\":{\"cachedReadTokens\":1664,\"inputTokens\":9178,\"outputTokens\":22,\"totalTokens\":10864}}","description":"Microsoft Internet Explorer 4.01 和 5.0 中的 HHOpen ActiveX 控件 (hhopen.ocx 1.0.0.1) 存在缓冲区溢出漏洞。远程攻击者可通过向 OpenHelp 方法传递超长参数触发缓冲区溢出，进而远程执行任意命令。该漏洞影响 IE 4.01 和 5.0 版本，CVSS 评分 5.1（中等严重度），攻击者无需认证即可远程利用，微软已发布安全更新修复该漏洞。","severity":"MEDIUM","score":5.1,"aliases":["CVE-1999-1577"],"sources":["exploitdb"],"published":"1999-10-31T04:00:00.000","updated":"2026-06-16T21:50:45.543","remediation":"升级到 Internet Explorer 5.5 或更高版本（含 2000-08-15 的累积安全补丁），或通过 Windows Update 安装微软安全更新修复 hhopen.ocx ActiveX 控件溢出。临时缓解措施：在 IE 安全设置中将 ActiveX 控件与插件设为「禁用」，并限制对 hhopen.ocx（1.0.0.1）的访问权限。","status":"completed","collected_at":"2026-07-18T00:00:00Z","references":["http://www.kb.cert.org/vuls/id/29795","http://www.securityfocus.com/archive/1/28719","http://www.securityfocus.com/bid/669","https://exchange.xforce.ibmcloud.com/vulnerabilities/3314","https://www.exploit-db.com/exploits/19521","https://github.com/CVEProject/cvelistV5/blob/e2218edc43f34225d168835de417dff40749bef5/cves/1999/1xxx/CVE-1999-1577.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1577","https://github.com/yarencheng/cve-devops-playground/blob/5cf8ba64f356efe9269b21eca2f657231acd746c/content/CVE-1999-1577.md","https://github.com/Patrowl/PatrowlHearsData/blob/2119b082f4927b0a9c902ed9fe95efb3b301cb81/CVE/data/1999/CVE-1999-1577.json","https://github.com/github/advisory-database/blob/d94ad47d0f2016e121b6d251f490e890714f8916/advisories/unreviewed/2022/04/GHSA-hc2h-vv8g-pjcj/GHSA-hc2h-vv8g-pjcj.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1577.json","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--f14bb3bf-ccb1-4061-8ce5-1ea255ae4ec9.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x1000/669/info.html","https://github.com/Vasileios-Mavroeidis/semantic-stix-vulnerability/blob/30f07606133364b9623f401bc306c8c9cbcf9386/vulnerability/vulnerability--f14bb3bf-ccb1-4061-8ce5-1ea255ae4ec9.owl"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-1195.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-1195.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1195.toml"},{"ave_id":"AVE-1999-1008","file_name":"1999/AVE-1999-1008.toml","cve_id":"CVE-1999-0873","title":"Sky Communications Skyfull 1.1.4 Mail Server MAIL FROM 命令缓冲区溢出漏洞","description":"Sky Communications Skyfull 1.1.4 邮件服务器在处理 MAIL FROM 命令时存在缓冲区溢出漏洞，远程攻击者可通过向 SMTP 服务发送超长特制的 MAIL FROM 参数触发该漏洞，导致服务崩溃或任意代码执行。该漏洞影响 Skyfull 1.1.4 及更早版本，CVSS 评分 7.5，危害等级高，无需身份认证即可远程利用。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0873"],"sources":["epss"],"published":"1999-10-30T04:00:00.000","updated":"2026-06-16T21:49:14.123","remediation":"Sky Communications 已停止维护 Skyfull Mail Server，官方不再提供安全补丁。建议立即迁移至受支持的邮件服务器（如 Postfix 3.x 或 Exim 4.x），并在迁移完成前在边界防火墙上限制对 SMTP 25/TCP 端口的访问，仅允许受信任的内部 IP 连接，同时配置入侵检测系统监控异常 SMTP 命令流量作为临时缓解措施。","status":"completed","collected_at":"2026-07-18T00:00:00Z","references":["http://www.securityfocus.com/bid/759","https://www.exploit-db.com/exploits/19584","https://github.com/CVEProject/cvelistV5/blob/42b5b7a8a9b34b1b292b9bfd27242e499ccb6cb9/cves/1999/0xxx/CVE-1999-0873.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0873","https://github.com/yarencheng/cve-devops-playground/blob/5cf8ba64f356efe9269b21eca2f657231acd746c/content/CVE-1999-0873.md","https://github.com/Patrowl/PatrowlHearsData/blob/21d84550d4f5d6b78cac9f7c41b1b20a874c9f15/CVE/data/1999/CVE-1999-0873.json","https://github.com/github/advisory-database/blob/d94ad47d0f2016e121b6d251f490e890714f8916/advisories/unreviewed/2022/04/GHSA-8483-grf5-r2r3/GHSA-8483-grf5-r2r3.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0873.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x1000/759/info.html","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153600_153700.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1008.toml"},{"ave_id":"AVE-1999-1165","file_name":"1999/AVE-1999-1165.toml","cve_id":"CVE-1999-1532","title":"Netscape Messaging Server 3.6/3.54/3.55 RCPT TO 拒绝服务漏洞","description":"网易邮件服务 3.6/3.54/3.55 版本存在 'RCPT TO' 命令解析漏洞，攻击者可通过发送大量或过长的 RCPT TO 命令导致服务器内存异常分配和泄漏，最终引发拒绝服务。该漏洞影响网易邮政服务 3.6、3.54 和 3.55 多个版本，攻击者无需身份验证即可远程触发利用，导致服务器服务不可用及资源耗尽。漏洞原因为邮件服务器对 RCPT TO 命令的长度和数量缺乏有效限制，攻击者可利用此缺陷对目标服务器发起持续的内存耗尽攻击，无法为正常邮件处理提供服务。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-1532"],"sources":["exploitdb"],"published":"1999-10-29T04:00:00.000","updated":"2026-06-16T21:50:38.627","remediation":"建议升级 Netscape Messaging Server 至 4.x 或更高版本以彻底修复该内存耗尽漏洞。若无法升级，可在 SMTP 网关或防火墙上限制单个连接的 RCPT TO 命令数量及命令长度，并对异常 SMTP 会话设置连接速率限制和超时策略，同时启用邮件服务器进程的内存使用监控与自动重启机制以缓解拒绝服务风险。","status":"completed","collected_at":"2026-07-18T00:00:00Z","references":["http://marc.info/?l=bugtraq&m=94117465014255&w=2","http://www.securityfocus.com/bid/748","https://www.exploit-db.com/exploits/19571","https://github.com/CVEProject/cvelistV5/blob/a3a08d51f200d453300fca8b852aada6b8c5985a/cves/1999/1xxx/CVE-1999-1532.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1532","https://github.com/yarencheng/cve-devops-playground/blob/5cf8ba64f356efe9269b21eca2f657231acd746c/content/CVE-1999-1532.md","https://github.com/Patrowl/PatrowlHearsData/blob/44e56ab96b4cc04024678e20a1f15145c3b3cc59/CVE/data/1999/CVE-1999-1532.json","https://github.com/stg-tud/cveenhance/blob/6476e73d87cdc9cf610342ef15d131432ab41588/Annotations/Schmidt/CVE-1999-1532.xml","https://github.com/github/advisory-database/blob/b1dd20ab76cf8f3afbe611ea8133362b0532868d/advisories/unreviewed/2022/04/GHSA-hhr5-xxj8-pvc5/GHSA-hhr5-xxj8-pvc5.json","https://github.com/dionmulaj/Boryoku/blob/2a1a981471c9b917512f28da1fa5c59c009329cd/cve-check/web/http_cve_check.py","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1532.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000839.txt","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--5da1d144-5ed3-431e-bae9-beec89545bf9.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1165.toml"},{"ave_id":"AVE-1999-1013","file_name":"1999/AVE-1999-1013.toml","cve_id":"CVE-1999-1226","title":"Netscape Communicator 长证书密钥远程拒绝服务漏洞","description":"Netscape Communicator 4.7 及更早版本在处理过长证书密钥时存在缓冲区溢出漏洞，远程攻击者可通过发送超长证书密钥触发拒绝服务，甚至可能执行任意代码。该漏洞影响所有使用受影响版本 Communicator 的客户端系统，攻击者无需身份认证即可远程利用，CVSS 评分 2.6，属于低危漏洞。","severity":"LOW","score":2.6,"aliases":["CVE-1999-1226"],"sources":["avd"],"published":"1999-10-28T04:00:00.000","updated":"2026-06-16T21:49:59.260","remediation":"升级到 Netscape Communicator 4.7 以上的修复版本（如 4.75 及后续 4.x 版本），或迁移至已修复该证书密钥处理缺陷的 Mozilla/Netscape 6 系列。在无法立即升级时，应在邮件客户端与浏览器中禁用对远程站点的 SSL 证书自动获取与处理，并通过防火墙/代理过滤异常超长证书请求，避免接收构造的恶意证书以缓解拒绝服务风险。","status":"completed","collected_at":"2026-07-19T00:00:00Z","references":["http://www.securiteam.com/exploits/Netscape_4_7_and_earlier_vulnerable_to__Huge_Key__DoS.html","https://exchange.xforce.ibmcloud.com/vulnerabilities/3436","https://github.com/CVEProject/cvelistV5/blob/7481e97cf7b60a5b982d99d7dad1ea61174940fb/cves/1999/1xxx/CVE-1999-1226.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1226","https://github.com/yarencheng/cve-devops-playground/blob/1fe9b156eeeb72b8f8baa50bbe7bc0d9806e8c64/content/CVE-1999-1226.md","https://github.com/Patrowl/PatrowlHearsData/blob/bc48b6c04c59ceff2d71da45cd843fc1d449dc48/CVE/data/1999/CVE-1999-1226.json","https://github.com/github/advisory-database/blob/cdfc8886d71af7ef3bdab3e4db46753ff8af6538/advisories/unreviewed/2022/04/GHSA-9jww-v5c9-f3ff/GHSA-9jww-v5c9-f3ff.json","https://github.com/olbat/nvdcve/blob/63d4031680b3d3fa77b826660a1e30ffc70ff5cd/nvdcve/CVE-1999-1226.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87546/info.html","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153700_153800.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--5cbad00d-e7aa-4d06-80c2-ba642bb0f45c.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1013.toml"},{"ave_id":"AVE-1999-0713","file_name":"1999/AVE-1999-0713.toml","cve_id":"CVE-1999-0915","title":"Pacific Software URL Live! 1.0 目录遍历漏洞","description":"Pacific Software URL Live! 1.0 Web 服务器存在目录遍历漏洞，远程攻击者可通过向目标服务器发送包含 `..`（点点）序列的恶意 HTTP 请求，绕过路径限制读取服务器上的任意文件。该漏洞影响 URL Live! 1.0 版本，攻击者无需身份认证即可利用，可能导致敏感信息泄露，CVSS 评分 5.0，危害等级中危。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0915"],"sources":["epss"],"published":"1999-10-28T04:00:00.000","updated":"2026-06-16T21:49:19.300","remediation":"该漏洞存在于已停止维护的 Pacific Software URL Live! 1.0 中，厂商已不再提供安全更新。建议立即迁移至受支持的 Web 服务器（如 Apache HTTP Server 2.4.x 或 Nginx 最新稳定版）。如无法迁移，可在反向代理或 WAF 层面添加规则拦截包含 `../` 或 `..\\` 的 URL 请求路径，并禁用目录列表功能作为临时缓解措施。","status":"completed","collected_at":"2026-07-19T00:00:00Z","references":["http://www.osvdb.org/1129","http://www.securityfocus.com/bid/746","https://www.exploit-db.com/exploits/19568","https://github.com/CVEProject/cvelistV5/blob/94380d498cb52b65d051c9bd443b6f2aa85bf8ec/cves/1999/0xxx/CVE-1999-0915.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0915","https://github.com/yarencheng/cve-devops-playground/blob/5cf8ba64f356efe9269b21eca2f657231acd746c/content/CVE-1999-0915.md","https://github.com/Patrowl/PatrowlHearsData/blob/cdbbe57bd34c799f670485304ef54912650bf03b/CVE/data/1999/CVE-1999-0915.json","https://github.com/github/advisory-database/blob/bf2339193e1c10dc2db330718adeb8cc8d88c4dd/advisories/unreviewed/2022/04/GHSA-6c27-6r97-2xgw/GHSA-6c27-6r97-2xgw.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0915.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_3.list.dict","https://github.com/akabe1/windows_exploit_dowser/blob/11b24e36173cd382721db28581e575faf687d06b/cve_from_exploitdb_website.csv","https://github.com/nomi-sec/CVE-Easy-List/blob/542ccf7ca1980a320a4dc1c4f0821b498d3bc23b/1999.tsv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0713.toml"},{"ave_id":"AVE-1999-0673","file_name":"1999/AVE-1999-0673.toml","cve_id":"CVE-1999-0882","title":"{\"_meta\":{},\"stopReason\":\"end_turn\",\"usage\":{\"cachedReadTokens\":1664,\"inputTokens\":9113,\"outputTokens\":18,\"totalTokens\":10795}}","description":"Falcon Web 服务器在处理文件名请求时存在信息泄露漏洞。远程攻击者无需身份认证，只需向服务器请求一个超长文件名的资源（例如超过系统路径长度限制的 URL），服务器在返回错误响应时会将 Web 根目录的绝对路径一同暴露出来。该漏洞影响运行 Falcon Web 服务器的系统，攻击条件为攻击者能够网络访问目标 Web 服务并发送构造的超长文件名请求。利用方式简单，通过普通 HTTP 请求即可触发，攻击者借此可获取服务器文件系统目录结构信息，为后续进一步攻击提供路径情报，CVSS 评分约为 5.0，危害等级中等。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0882"],"sources":["epss"],"published":"1999-10-28T04:00:00.000","updated":"2026-06-16T21:49:15.210","remediation":"建议将 Falcon Web Server 升级到修复了 CVE-1999-0882 的最新版本，或替换为持续维护的 Web 服务器（如 Apache 或 Nginx）以彻底消除风险。临时缓解措施：在 Falcon 配置文件中启用自定义错误页面，将 404、403 等错误响应中的服务器绝对路径信息替换为通用提示文本，避免向攻击者泄露 Web 根目录路径。同时，在服务器前端部署 WAF 规则，拦截包含超长文件名的异常请求，阻断路径探测攻击面。","status":"completed","collected_at":"2026-07-18T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0882","https://github.com/CVEProject/cvelistV5/blob/edbb10deb36e9400fcd245fdb6d1781b6f0ae700/cves/1999/0xxx/CVE-1999-0882.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0882","https://github.com/yarencheng/cve-devops-playground/blob/5cf8ba64f356efe9269b21eca2f657231acd746c/content/CVE-1999-0882.md","https://github.com/Patrowl/PatrowlHearsData/blob/af2c3b5adc3ff9dc412f664a188835d908ce9d5f/CVE/data/1999/CVE-1999-0882.json","https://github.com/github/advisory-database/blob/d94ad47d0f2016e121b6d251f490e890714f8916/advisories/unreviewed/2022/04/GHSA-ww4w-m2mr-8x97/GHSA-ww4w-m2mr-8x97.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0882.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x89000/88397/info.html","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000836.txt","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--5c8580dc-f42b-479f-817d-d00539e4cba0.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0673.toml"},{"ave_id":"AVE-1999-1408","file_name":"1999/AVE-1999-1408.toml","cve_id":"CVE-1999-0950","title":"Texas Imperial Software WFTPD FTP服务器 远程缓冲区溢出漏洞","description":"WFTPD FTP服务器在处理MKD（创建目录）和CWD（切换目录）命令时存在缓冲区溢出漏洞。远程攻击者无需身份认证，通过向目标FTP服务器发送特制的MKD和CWD命令序列创建深层嵌套目录，可触发栈缓冲区溢出，导致以root权限执行任意代码，完全控制受影响系统。该漏洞影响WFTPD 2.34/2.40/3.0版本，CVSS v2评分10.0，危害等级严重。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0950"],"sources":["cve","exploitdb"],"published":"1999-10-28","updated":"2024-11-20","remediation":"WFTPD已停止维护多年，官方不再提供安全更新。建议立即将FTP服务迁移至仍在维护的FTP服务器软件（如vsftpd、ProFTPD或FileZilla Server），并配置防火墙限制FTP服务仅对可信网络开放，同时禁用匿名登录和危险FTP命令。","status":"completed","collected_at":"2026-07-19T00:00:00Z","references":["http://www.securityfocus.com/bid/747","https://nvd.nist.gov/vuln/detail/CVE-1999-0950","https://www.exploit-db.com/exploits/19570"],"poc_urls":[],"exp_urls":["https://www.exploit-db.com/exploits/19570"],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1408.toml"}]