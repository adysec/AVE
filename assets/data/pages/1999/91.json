ity.org/advisories/hpalert/019","https://exchange.xforce.ibmcloud.com/vulnerabilities/2058","https://github.com/trickest/cve/blob/b4f1378756fd26f414d09a97dc81126672830951/1999/CVE-1999-1248.md","https://github.com/CVEProject/cvelistV5/blob/e25ede9c3545efaa8ff0b393e30e48edb07502a8/cves/1999/1xxx/CVE-1999-1248.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1248","https://github.com/Patrowl/PatrowlHearsData/blob/248c2167e720df96125f6ac9925793063a207510/CVE/data/1999/CVE-1999-1248.json","https://github.com/mabitoski/cve_submodules/blob/44ad7e2705b3aef1b2ffaf64bd47596c10a6c2e4/1999/CVE-1999-1248.md","https://github.com/github/advisory-database/blob/cdfc8886d71af7ef3bdab3e4db46753ff8af6538/advisories/unreviewed/2022/04/GHSA-rw37-8gqf-wrj9/GHSA-rw37-8gqf-wrj9.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87787/info.html","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1248.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000059.txt","https://github.com/Yuning-J/VulnerabilityClassifier/blob/c0f06c21b73c26b5ee2b75c21a498eb04eada4b5/threatPrediction/cveIDThreatType/cve_idgainpre"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1423.toml"},{"ave_id":"AVE-1999-1472","file_name":"1999/AVE-1999-1472.toml","cve_id":"CVE-1999-1310","title":"SGI IRIX serial_ports 本地权限提升漏洞","description":"CVE-1999-1310 已被 NVD 标记为 REJECT（拒绝），原因是该编号与 CVE-1999-1022 重复，属于重复分配。NVD 已清除该条目的所有描述信息及参考链接，以防止用户误用此编号。建议直接参考 CVE-1999-1022 获取实际漏洞详情，本条目不包含任何有效漏洞信息。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-1310"],"sources":["avd"],"published":"1994-11-04T05:00:00.000","updated":"2023-11-07T01:55:08.250","remed