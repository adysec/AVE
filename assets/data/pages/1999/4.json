c0/cve-list/CVE-1999/CVE-1999-1300","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1300.md","https://github.com/Patrowl/PatrowlHearsData/blob/58eef6eedd760f280b47bfb4c94db9995b29c5a0/CVE/data/1999/CVE-1999-1300.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-9226-8p5v-w2mm/GHSA-9226-8p5v-w2mm.json","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1300.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153900_154000.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001018.txt","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--d8fd4edc-ae2f-41cf-85a2-4016ce7faf61.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1034.toml"},{"ave_id":"AVE-1999-1032","file_name":"1999/AVE-1999-1032.toml","cve_id":"CVE-1999-1290","title":"nftp FTP 客户端缓冲区溢出漏洞","description":"nftp FTP 客户端 1.40 版本存在缓冲区溢出漏洞。远程攻击者可通过搭建恶意 FTP 服务器，向连接至此服务器的客户端发送超长响应字符串触发缓冲区溢出，导致客户端拒绝服务，在特定条件下可能实现任意代码执行。攻击者需要诱导目标用户主动连接至恶意 FTP 服务器进行利用，属于客户端侧漏洞。","severity":"MEDIUM","score":5.1,"aliases":["CVE-1999-1290"],"sources":["cve"],"published":"1999-12-31T05:00:00.000","updated":"2026-06-16T21:50:07.313","remediation":"升级至 nftp 1.41 或更高版本（1.41 版本已明确修复该安全漏洞），建议直接使用最终版本 1.71。nftp 项目已于 2002 年停止维护，建议迁移至仍在维护的 FTP 客户端（如 lftp、curl）作为长期方案。临时缓解措施：避免使用 nftp 连接不可信的 FTP 服务器。","status":"completed","collected_at":"2026-07-16T00:00:00Z","referenc