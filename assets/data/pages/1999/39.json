http://www.ciac.org/ciac/bulletins/j-027.shtml","http://www.securityfocus.com/archive/1/12121"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0590.toml"}]