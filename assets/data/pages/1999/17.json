ayground/blob/5cf8ba64f356efe9269b21eca2f657231acd746c/content/CVE-1999-0904.md","https://github.com/Patrowl/PatrowlHearsData/blob/03324c0426abad4e55ae7c73b0bba67b9c87e4ea/CVE/data/1999/CVE-1999-0904.json","https://github.com/github/advisory-database/blob/799c403529fad0f67d5473eea397e9968232a5ec/advisories/unreviewed/2022/04/GHSA-98xh-mmww-3qq6/GHSA-98xh-mmww-3qq6.json","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/B/bftelnet.nasl","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/fkie-cad/nvd-json-data-feeds/blob/c9a52e4626751d35022482b24e543cc1d039fc40/CVE-1999/CVE-1999-09xx/CVE-1999-0904.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153700_153800.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_3.list.dict"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0703.toml"},{"ave_id":"AVE-1999-0677","file_name":"1999/AVE-1999-0677.toml","cve_id":"CVE-1999-0885","title":"Computer Software Manufaktur Alibaba 2.0 多个CGI远程命令执行漏洞","description":"Computer Software Manufaktur Alibaba 2.0 Web 服务器存在多个 CGI 漏洞，远程攻击者可通过向 URL 中注入管道符（|）等特殊字符，绕过输入验证执行任意系统命令。该漏洞影响 Alibaba 2.0 版本，攻击者无需身份认证即可利用，可能导致服务器被完全控制。CVSS 评分 3.6，危害等级低。","severity":"LOW","score":3.6,"aliases":["CVE-1999-0885"],"sources":["epss"],"published":"1999-11-03T05:00:00.000","updated":"2026-06-16T21:49:15.570","remediation":"建议立即停止使用已停止维护的 Alibaba 2.0 Web 服务器，迁移至 Apache HTTP Server 或 Nginx 等受支持的现代 Web 服务器。如无法立即迁移，可在反向代理或 WAF 层面过滤 URL 请求中的管道符 `|` 及其他 shell 元字符，并严格限制对服务器的网络访问来源。","status":"completed","collected_at":"2026-07-18T00:00:00Z","references":["http://www.securityfocus.com/bid/770","http://www.securityfocus.com/templa