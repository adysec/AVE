[{"ave_id":"AVE-2007-0006","file_name":"2007/AVE-2007-0006.toml","cve_id":"CVE-2007-5728","title":"phpPgAdmin redirect.php 跨站脚本漏洞","description":"phpPgAdmin 3.5 至 4.1.1（可能包括 4.1.2）版本中的 redirect.php 文件存在跨站脚本（XSS）漏洞。远程攻击者可通过 PHP_SELF 变量中的特定输入注入任意 Web 脚本或 HTML 代码，在用户浏览器中执行恶意脚本，导致敏感信息泄露或会话劫持。该漏洞利用无需认证，攻击复杂度较低，影响范围涵盖多个 phpPgAdmin 版本，与 CVE-2007-2865 的攻击向量不同。","severity":"MEDIUM","score":4.3,"aliases":["CVE-2007-5728"],"sources":["nuclei"],"published":"2007-10-30T21:46:00.000","updated":"2026-06-16T22:46:42.930","remediation":"立即升级 phpPgAdmin 至 4.1.3 或更高版本，该版本已修复 redirect.php 和 login.php 中 PHP_SELF 输入的 XSS 问题。Debian Etch 用户应安装 DSA-1693 提供的 4.0.1-3.1+etch1 安全更新。若无法立即升级，可在 Web 服务器（Apache/Nginx）中限制对 redirect.php 的访问，或在 php.ini 中启用 `session.cookie_httponly` 和 `session.cookie_secure` 作为临时缓解措施。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://lists.grok.org.uk/pipermail/full-disclosure/2007-May/063617.html","http://osvdb.org/36699","http://secunia.com/advisories/25446","http://secunia.com/advisories/27756","http://secunia.com/advisories/33263","http://www.debian.org/security/2008/dsa-1693","http://www.novell.com/linux/security/advisories/2007_24_sr.html","http://www.securityfocus.com/bid/24182","https://exchange.xforce.ibmcloud.com/vulnerabilities/34550","https://www.exploit-db.com/exploits/30090","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2007/CVE-2007-5728.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2007/CVE-2007-5728.md","https://github.com/projectdiscovery/nuclei-templates/blob/69a5a3cf926251a00061ec14d208b227367df73d/http/cves/2007/CVE-2007-5728.yaml","https://github.com/ExpLangcn/NucleiTP/blob/2b7ecb9031a6eda4f272793045f29b339d8e0cce/CVES/medium/cve-2007-5728-1349.yaml","https://github.com/CVEProject/cvelistV5/blob/8aea42c71147e21c6d32b71ffce877107de995c6/cves/2007/5xxx/CVE-2007-5728.json","https://github.com/0xKayala/Custom-Nuclei-Templates/blob/1940dfd29577590f076c89dec5c30d809d68f210/5001-to-6000-templates/cve-2007-5728-1350.yaml","https://github.com/linuxadi/40k-nuclei-templates/blob/542be6820c801c02a33aee60f1c05ca7b0b5005f/aditya/folder5/cve-2007-5728-1351.yaml","https://github.com/Akash-Trimbake/scanner/blob/9fff4016ff4aff22c37dc2e17bcc5aaab86b3b49/src/Components/data.js","https://github.com/mssalvatore/ubuntu-cve-tracker-mirror/blob/393245887b9fdc3ecd3096a44e0373d9fb7038a6/retired/CVE-2007-5728","https://github.com/rix4uni/nucleihub-templates/blob/579a0234551b9e0e322460a62dc77bd6109e4aff/nucleihub-templates/CVE-2007-5728-1349.yaml","https://github.com/VulnerabilityHistoryProject/mega-foss/blob/4829eeb7b0101570abbc87d2a697f2c0c2f4e5c3/output/repos_match_cve.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2007/AVE-2007-0006.toml"},{"ave_id":"AVE-2007-0003","file_name":"2007/AVE-2007-0003.toml","cve_id":"CVE-2007-3010","title":"阿尔卡特朗讯 OmniPCX Enterprise 通信服务器 7.1 masterCGI 命令注入漏洞","description":"Alcatel-Lucent OmniPCX Enterprise Communication Server R7.1及之前版本的 Unified Maintenance Tool 中 masterCGI 存在命令注入漏洞。远程攻击者无需认证即可通过向 ping 功能提交包含 shell 元字符的特制 user 参数注入任意系统命令，导致目标系统被完全控制。该漏洞已有 Metasploit 利用模块，被 CISA 列入已知被利用漏洞目录，CVSS 评分 9.8，危害等级严重。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2007-3010"],"sources":["nuclei"],"published":"2007-09-19","updated":"2007-09-19","remediation":"将 Alcatel-Lucent OmniPCX Enterprise Communication Server 升级至 7.1 之后的安全版本，或安装厂商提供的 masterCGI 补丁。临时缓解措施：在反向代理或防火墙上限制对 masterCGI 接口的访问，仅允许受信任管理 IP 通过，并禁用不必须的 CGI 功能。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["https://www.exploit-db.com/exploits/10031","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2007/CVE-2007-3010.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2007/CVE-2007-3010.md","https://github.com/projectdiscovery/nuclei-templates/blob/69a5a3cf926251a00061ec14d208b227367df73d/http/cves/2007/CVE-2007-3010.yaml","https://github.com/CVEProject/cvelistV5/blob/8aea42c71147e21c6d32b71ffce877107de995c6/cves/2007/3xxx/CVE-2007-3010.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2007/CVE-2007-3010","https://github.com/ARPSyndicate/suricata-vedas/blob/fe24794ad36564b5bbc7c69101525011387b8650/2007/CVE-2007-3010.rules","https://github.com/rix4uni/nucleihub-templates/blob/579a0234551b9e0e322460a62dc77bd6109e4aff/nucleihub-templates/CVE-2007-3010_1.yaml","https://github.com/Patrowl/PatrowlHearsData/blob/e64e866f5c799abe7f39eba36818200f3831f1cb/SSVC/data/2007/CVE-2007-3010.json","https://github.com/adampielak/nuclei-templates/blob/ac9605f5a915670fd80cb4e1904f4435f1835b65/nuclei-v3/C/CVE-2007-3010_2.yaml","https://github.com/rokkamvamshi/attack-surface-management/blob/c988ba43c9b670a9983bbc30e2493422ae577605/nuclei-templates/http/cves/2007/CVE-2007-3010.yaml","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--a6e08878-3805-4cb5-a01f-992ab2f8b7eb.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2007/AVE-2007-0003.toml"},{"ave_id":"AVE-2007-0005","file_name":"2007/AVE-2007-0005.toml","cve_id":"CVE-2007-4556","title":"Apache Struts2 远程命令执行漏洞","description":"Apache Struts2 框架 2.0.9 及更早版本存在 OGNL 表达式注入漏洞（S2-001）。攻击者无需身份认证即可通过向目标服务器发送特制的 HTTP 请求，在表单字段中注入恶意 OGNL 表达式。由于框架在处理用户提交的表单参数时未对输入进行充分过滤，导致 OGNL 表达式被服务器解析执行，最终造成远程代码执行。攻击者可借此完全控制目标服务器，执行任意系统命令。该漏洞影响范围广泛，危害严重。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2007-4556"],"sources":["nuclei"],"published":"2007-08-28","updated":"2007-08-28","remediation":"升级 Apache Struts2 至 2.0.11.1 或更高版本。该漏洞源于 XWork 的 OGNL 表达式解析器未正确过滤用户输入，攻击者可通过构造特殊参数执行任意系统命令。临时缓解措施：在应用中禁用对 OGNL 表达式的直接解析，或在 Web 服务器层面过滤包含 OGNL 特征（如 %{、#{} 等）的请求参数。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2007/CVE-2007-4556.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2007/CVE-2007-4556.md","https://github.com/projectdiscovery/nuclei-templates/blob/69a5a3cf926251a00061ec14d208b227367df73d/http/cves/2007/CVE-2007-4556.yaml","https://github.com/ExpLangcn/NucleiTP/blob/2b7ecb9031a6eda4f272793045f29b339d8e0cce/CVES/critical/cve-2007-4556-1347.yaml","https://github.com/sepehrdaddev/zap-scripts/blob/2b63b02ca79cc7f0023cdbab72c5c6c774354b07/active/CVE-2007-4556.js","https://github.com/linuxadi/40k-nuclei-templates/blob/542be6820c801c02a33aee60f1c05ca7b0b5005f/aditya/folder1/cve-2007-4556-1344.yaml","https://github.com/Apibug/SecPost/blob/2f7df9980cab025c48cce9b14b2d48eeb37328ef/%EF%BC%88CVE-2007-4556%EF%BC%89s2-001.md","https://github.com/lianqingsec/NucleiPocGather/blob/dcce204f62196117b9c95c52d8101ccf7a5d27bc/poc/cve/cve-2007-4556-1345_3.yaml","https://github.com/daffainfo/cvelist/blob/37b3071167a2a3fb5757922e970775326b735d8f/cves/2007/4xxx/CVE-2007-4556.json","https://github.com/daxtar2/Guts/blob/885dac464c9948f7809c239b00901699cd593827/templates/http/cves/2007/CVE-2007-4556.yaml","https://github.com/adampielak/nuclei-templates/blob/ac9605f5a915670fd80cb4e1904f4435f1835b65/nuclei-v2/C/CVE-2007-4556_28.yaml"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2007/AVE-2007-0005.toml"},{"ave_id":"AVE-2007-0004","file_name":"2007/AVE-2007-0004.toml","cve_id":"CVE-2007-4504","title":"Joomla! RSfiles 1.0.2 路径遍历文件下载漏洞","description":"Joomla! 的 RSfiles 组件 1.0.2 版本中存在路径遍历漏洞，远程攻击者通过在请求中构造恶意的 path 参数，可利用目录遍历技术下载服务器上的任意文件，导致敏感信息泄露。该漏洞无需身份认证即可利用，攻击复杂度低，影响运行 Joomla! 及 RSfiles 组件的所有 Web 服务器。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2007-4504"],"sources":["nuclei"],"published":"2007-08-24","updated":"2007-08-24","remediation":"立即升级 RSfiles 组件至 1.0.2 以上版本，厂商 RSJoomla 已在后续版本中修复 `path` 参数路径遍历漏洞。如无法获取更新，建议彻底卸载 `com_rsfiles` 组件并换用其他文件管理扩展。临时缓解措施：在 Joomla! 根目录 .htaccess 中添加重写规则，拦截 `option=com_rsfiles&task=files.display` 请求中 path 参数包含 `..` 或 `|` 的恶意请求；同时在 PHP 层面过滤 `$_GET['path']` 中的目录遍历序列，禁止包含 `..` 的输入。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["https://www.exploit-db.com/exploits/4307","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2007/CVE-2007-4504.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2007/CVE-2007-4504.md","https://github.com/projectdiscovery/nuclei-templates/blob/69a5a3cf926251a00061ec14d208b227367df73d/http/cves/2007/CVE-2007-4504.yaml","https://github.com/CVEProject/cvelistV5/blob/8aea42c71147e21c6d32b71ffce877107de995c6/cves/2007/4xxx/CVE-2007-4504.json","https://github.com/lianqingsec/NucleiPocGather/blob/dcce204f62196117b9c95c52d8101ccf7a5d27bc/poc/cve/cve-2007-4504-1339.yaml","https://github.com/adampielak/nuclei-templates/blob/ac9605f5a915670fd80cb4e1904f4435f1835b65/nuclei-v2/C/CVE-2007-4504-1342.yaml","https://github.com/RiskBasedPrioritization/RiskBasedPrioritizationAnalysis/blob/3d5cc1819ecb8cbc3aeb75d9a8260318544faf56/data_in/nuclei/nuclei.txt","https://github.com/ahisec/Lots-of-POC/blob/51ed84ccc21e97e5e12563150992e03f9de384cd/nuclei/joomla/rsfiles/CVE-2007-4504.yaml","https://github.com/0xKayala/Custom-Nuclei-Templates/blob/1940dfd29577590f076c89dec5c30d809d68f210/5001-to-6000-templates/cve-2007-4504-1340.yaml","https://github.com/rix4uni/nucleihub-templates/blob/579a0234551b9e0e322460a62dc77bd6109e4aff/nucleihub-templates/CVE-2007-4504_5.yaml","https://github.com/ExpLangcn/NucleiTP/blob/2b7ecb9031a6eda4f272793045f29b339d8e0cce/CVES/high/cve-2007-4504-1339.yaml"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2007/AVE-2007-0004.toml"},{"ave_id":"AVE-2007-0002","file_name":"2007/AVE-2007-0002.toml","cve_id":"CVE-2007-2449","title":"Apache Tomcat 跨站脚本攻击漏洞","description":"Apache Tomcat 示例应用 (examples web application) 中的多个 JSP 文件存在跨站脚本 (XSS) 漏洞，远程攻击者通过在 URI 中 ';' 字符之后的部分注入任意 Web 脚本或 HTML 代码触发该漏洞，导致恶意脚本在受害者浏览器中执行，可窃取 Cookie 或篡改页面内容。该漏洞影响 Tomcat 4.0.0 至 6.0.13 的多个版本系列，CVSS 评分 4.3，危害等级中危。建议删除示例应用目录或升级至修复版本。","severity":"MEDIUM","score":4.3,"aliases":["CVE-2007-2449"],"sources":["nuclei"],"published":"2007-06-14T23:30:00.000","updated":"2026-06-16T22:39:37.433","remediation":"升级 Apache Tomcat 至 5.5.25 及以上版本，或 6.0.14 及以上版本。如无法立即升级，可将 webapps 目录下的 examples 目录删除或重命名，禁用示例 Web 应用。生产环境应始终移除 examples 应用，避免部署在对外服务中。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://community.ca.com/blogs/casecurityresponseblog/archive/2009/01/23.aspx","http://h20000.www2.hp.com/bizsupport/TechSupport/Document.jsp?objectID=c01178795","http://lists.apple.com/archives/security-announce/2008//Jun/msg00002.html","http://lists.opensuse.org/opensuse-security-announce/2008-03/msg00008.html","http://lists.opensuse.org/opensuse-security-announce/2009-02/msg00002.html","http://osvdb.org/36080","http://rhn.redhat.com/errata/RHSA-2008-0630.html","http://secunia.com/advisories/26076","http://secunia.com/advisories/27037","http://secunia.com/advisories/27727","http://secunia.com/advisories/29392","http://secunia.com/advisories/30802","http://secunia.com/advisories/31493","http://secunia.com/advisories/33668","http://securityreason.com/securityalert/2804","http://support.apple.com/kb/HT2163","http://support.ca.com/irj/portal/anonymous/phpsupcontent?contentID=197540","http://tomcat.apache.org/security-4.html","http://tomcat.apache.org/security-5.html","http://tomcat.apache.org/security-6.html","http://www.mandriva.com/security/advisories?name=MDKSA-2007:241","http://www.redhat.com/support/errata/RHSA-2007-0569.html","http://www.redhat.com/support/errata/RHSA-2008-0261.html","http://www.securityfocus.com/archive/1/4713