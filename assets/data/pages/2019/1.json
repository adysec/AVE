[{"ave_id":"AVE-2019-0001","file_name":"2019/AVE-2019-0001.toml","cve_id":"无","title":"WSO2 服务器端请求伪造漏洞（SSRF）","description":"WSO2 产品 5.8.0 之前版本存在服务器端请求伪造漏洞。攻击者可利用 shindig Web 应用的 UI 小工具加载功能，通过修改特定 URL 参数使服务器向攻击者控制的地址发起 GET 请求，从而造成内部网络探测和信息泄露。","severity":"MEDIUM","score":6.8,"aliases":["NUCLEI-HTTP-VULNERABILITIES-OTHER-WSO2-2019-0598-YAML"],"sources":["nuclei"],"published":"2019-01-01","updated":"2019-01-01","remediation":"将 WSO2 产品升级至 5.8.0 或更高版本，以修复 shindig 组件中存在的 SSRF 漏洞。","status":"completed","collected_at":"2026-07-15T01:13:01.727834469+00:00","references":["https://docs.wso2.com/display/Security/Security+Advisory+WSO2-2019-0598"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2019/AVE-2019-0001.toml"}]