[{"ave_id":"AVE-2000-0180","file_name":"2000/AVE-2000-0180.toml","cve_id":"CVE-2000-0204","title":"Trend Micro OfficeScan 客户端拒绝服务漏洞","description":"Trend Micro OfficeScan 企业版（3.0、3.5、3.11、3.13 等版本）的客户端服务在处理网络连接时存在拒绝服务漏洞。远程攻击者无需身份认证，只需向目标主机监听的 12345 端口发起 5 次连接请求，即可触发该漏洞，使目标进程的 CPU 占用率升至 100%，造成服务无响应或系统资源耗尽。该漏洞影响运行上述版本 OfficeScan 客户端的 Windows 主机，攻击条件简单、可远程发起且无需特权，但仅导致可用性丧失，属中危拒绝服务类问题。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2000-0204"],"sources":["exploitdb"],"published":"2000-02-28T05:00:00.000","updated":"2026-06-16T21:51:13.130","remediation":"升级 Trend Micro OfficeScan 客户端至官方已修复版本，或应用 Trend Micro 发布的官方安全补丁以修复 12345 端口连接处理缺陷，并在防火墙层面限制对 12345 端口的未授权访问。","status":"completed","collected_at":"2026-07-19T00:00:00Z","references":["http://archives.neohapsis.com/archives/bugtraq/2000-02/0340.html","http://www.antivirus.com/download/ofce_patch_35.htm","http://www.securityfocus.com/bid/1013","http://www.securityfocus.com/templates/archive.pike?list=1&msg=D129BBE1730AD2118A0300805FC1C2FE038AF28B%40209-76-212-10.trendmicro.com","https://www.exploit-db.com/exploits/19780","https://github.com/CVEProject/cvelistV5/blob/ad08212eac84f46206c2da8a50436d48e5ad608c/cves/2000/0xxx/CVE-2000-0204.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0204","https://github.com/yarencheng/cve-devops-playground/blob/1fe9b156eeeb72b8f8baa50bbe7bc0d9806e8c64/content/CVE-2000-0204.md","https://github.com/Patrowl/PatrowlHearsData/blob/baa4573f2fa6813cfbc3f5cda2f1796a92d64bdf/CVE/data/2000/CVE-2000-0204.json","https://github.com/github/advisory-database/blob/95e6ff620d5494b93ba2234edfcf6a45187dc0a8/advisories/unreviewed/2022/04/GHSA-x769-wmh4-gxvx/GHSA-x769-wmh4-gxvx.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_152200_152300.json"