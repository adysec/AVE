urity Bulletin MS99-013 对应补丁。该漏洞已在新版 IE 中修复，建议立即停止使用旧版 IE，改用 Microsoft Edge 或 Chrome 等现代浏览器。如因兼容性必须使用，可在安全设置中将「Internet 区域」和「受限站点区域」的安全级别设为「高」，并禁用「下载未签名的 ActiveX 控件」。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0280","https://github.com/CVEProject/cvelistV5/blob/269e5b2b6ea60fdb4a03411be38d3e381b26e4c4/cves/1999/0xxx/CVE-1999-0280.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0280","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0280.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0280.md","https://github.com/Patrowl/PatrowlHearsData/blob/2f876a2c24d5ccd5bbd081f09e801e580536456a/CVE/data/1999/CVE-1999-0280.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-hjxm-3j2g-hph3/GHSA-hjxm-3j2g-hph3.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/CrackerCat/simpread/blob/1ec36a5827997f39a7a815e20121b12f8d781497/md/Chrome%20Browser%20Exploitation,%20Part%201:%20Introduction%20to%20V8%20and%20JavaScript%20Internals%20-%20Jack%20Hacks.md","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0280.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0466.toml"}]