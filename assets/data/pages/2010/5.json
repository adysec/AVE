loits/blob/f496d51148a2b151f14fe6d0bef5b42ee27f6ccb/CVE%20List/2010/1xxx/CVE-2010-1494.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0043.toml"},{"ave_id":"AVE-2010-0042","file_name":"2010/AVE-2010-0042.toml","cve_id":"CVE-2010-1491","title":"Joomla! MMS Blog 组件目录遍历漏洞","description":"Joomla! 的 MMS Blog 组件 2.3.0 中存在目录遍历漏洞，该漏洞源于程序对 controller 参数过滤不严，远程攻击者可通过在参数中注入 ../ 序列构造恶意请求，绕过路径限制读取服务器上的任意敏感文件，如配置文件等。影响运行 Joomla! 且安装 MMS Blog 2.3.0 组件的网站，攻击者无需认证即可远程利用，导致敏感信息泄露。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2010-1491"],"sources":["nuclei"],"published":"2010-04-23T14:30:01.243","updated":"2026-06-16T23:18:29.410","remediation":"立即卸载或禁用 MMS Blog (com_mmsblog) 2.3.0 组件，该组件已长期无人维护且无官方补丁。同时检查服务器上是否仍存在 controller 参数传递，在 Web 应用防火墙 (WAF) 层添加规则拦截 `..` 目录遍历攻击载荷。建议迁移至其他仍在维护的 Joomla! 博客扩展。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://packetstormsecurity.org/1004-exploits/joomlammsblog-lfi.txt","http://secunia.com/advisories/39533","http://www.exploit-db.com/exploits/12318","http://www.securityfocus.com/bid/39607","https://www.exploit-db.com/exploits/12318","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2010/CVE-2010-1491.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2010/CVE-2010-1491.md","https://github.com/projectdiscovery/nuclei-templates/blob/1482f62c613998b0fe0690591034b732c0bb2e0a/http/cves/2010/CVE-2010-1491.yaml","https://github.com/sepehrdaddev/zap-scripts/blob/2b63b02ca79cc7f0023cdbab72c5c6c774354b07/active/CVE-2010-1491.js","https://github.com/0xKayala/Custom-Nuclei-Templates/blob/1940dfd29577590f076c89dec5c30d809d68f210/5001-to-6000-templates/cve-2010-1491-1693.yaml","https://github.com/wpsec/ARL-Source-Install/blob/aecf83f1f55a6f1a1a67dbe25e22ea0eb5a44bf2/tools/nuclei-templates/http/cves/2010/CVE-2010-1491.yaml","https://github.com/adampielak/nuclei-templates/blob/ac9605f5a915670fd80cb4e1904f4435f1835b65/nuclei-v3/C/CVE-2010-1491_11.yaml","https://github.com/westonsteimel/national-vulnerability-database/blob/2ce54d3744fd5bcac7a1e8c5fe748135d72fb2a6/data/2010/CVE-2010-1491.json","https://github.com/hungryfoolou/Vulnerability_Mining/blob/3df1d8ed0489ae1228f975ae1f58a690aae53886/craw/cveid_craw/cveid_craw/data/cveid_by_kind/cveid_dirtra.txt","https://github.com/Ciyfly/woodpecker/blob/f88bed6da55238547a423ce17dccb2cdbc93be50/pocs/nuclei/cves/2010/CVE-2010-1491.yaml","https://github.com/exploit-io/nuclei-templates/blob/a4b7182985a6e45df346cfe45242d40455e152b5/templates/cve-2010-1491-1689.yaml"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0042.toml"},{"ave_id":"AVE-2010-0041","file_name":"2010/AVE-2010-0041.toml","cve_id":"CVE-2010-1478","title":"Joomla! Jfeedback 组件目录遍历漏洞","description":"Joomla! 的 Jfeedback 组件 1.2 版本存在目录遍历漏洞，远程攻击者无需身份认证即可通过在 controller 参数中注入 `../` 序列，进而读取服务器上的任意文件。该漏洞影响使用该组件的所有 Joomla! 站点，CVSS 评分 6.8，危害等级中危。由于缺少对用户输入的充分过滤，攻击者可获取敏感配置文件或系统文件，可能导致进一步的信息泄露或攻击。","severity":"MEDIUM","score":6.8,"aliases":["CVE-2010-1478"],"sources":["nuclei"],"published":"2010-04-19T19:30:01.007","updated":"2026-06-16T23:18:28.283","remediation":"建议立即在 Joomla! 后台扩展管理器中卸载 com_jfeedback 组件，或从服务器删除该组件目录。如无法卸载，修改 PHP 代码在 controller 参数入口处过滤 ../ 和 %00 字符，仅允许字母数字和白名单值；同时在 Apache/Nginx 层添加 RewriteRule/location 规则拦截包含目录遍历特征的请求，并将 PHP 配置 open_basedir 限制到站点根目录以阻止读取系统文件。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://packetstormsecurity.org/1004-exploits/joomlajfeedback-lfi.txt","http://secunia.com/advisories/39262","http://www.exploit-db.com/exploits/12145","http://www.securityfocus.com/bid/39390","https://www.exploit-db.com/exploits/12145","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2010/CVE-2010-1478.yaml","https://github.com/t