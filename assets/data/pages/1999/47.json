ist/CVE-1999/CVE-1999-0271","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0271.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0271.md","https://github.com/Patrowl/PatrowlHearsData/blob/2ed73314b4d66512efbb22e0644e615bc00001f2/CVE/data/1999/CVE-1999-0271.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-6vw2-j8x2-pj9j/GHSA-6vw2-j8x2-pj9j.json","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/P/pnserver.nasl","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x83000/82096/info.html","https://github.com/fkie-cad/nvd-json-data-feeds/blob/1b69cf2313f68e29acceed58f52f6109cd37bb04/CVE-1999/CVE-1999-02xx/CVE-1999-0271.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0457.toml"},{"ave_id":"AVE-1999-0456","file_name":"1999/AVE-1999-0456.toml","cve_id":"CVE-1999-0270","title":"SGI IRIX Performer API Search Tool 目录遍历漏洞","description":"SGI IRIX 操作系统自带的 Performer API Search Tool 中的 pfdispaly.cgi 脚本存在目录遍历漏洞，远程攻击者无需身份认证即可通过向 CGI 程序发送包含特殊路径序列（如 ../）的恶意 HTTP 请求，突破 Web 根目录限制，读取服务器上任意文件，包括 /etc/passwd 等敏感系统文件。该漏洞影响安装了 performer_tools 组件的 SGI IRIX 系统，CVSS 评分 5.0，危害等级中危。厂商已发布安全公告建议禁用相关 CGI 脚本。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0270"],"sources":["epss"],"published":"1998-04-03T05:00:00.000","updated":"2026-06-16T21:48:02.600","remediation":"建议立即升级 SGI Performer API Search Tool 至最新补丁版本，或从 Web 服务器中移除 pfdispaly.cgi 脚本。如无法升级，可在 Web 服务器配置中限制对 pfdispaly.cgi 的访问（如禁用该 CGI 执行权限、限制访问来源 IP），并部