# Public repo in output/: keep only site files + public vulnerability data
*

# Track directories and selected files
!/.gitignore
!/README.md
!/index.html
!/detail.html
!/asset.html
!/CNAME
!/.nojekyll
!/assets/
!/assets/**
!/assets/data/
!/assets/data/**
!/scripts/
!/scripts/**
!/.github/
!/.github/**
!/vulns/
!/vulns/**
!/pocs/
!/pocs/**
!/exploits/
!/exploits/**
!/bin/
!/bin/**
!/src/
!/src/**
!/Cargo.toml
# Exclude Rust build artifacts from git
/target/
