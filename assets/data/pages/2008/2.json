[{"ave_id":"AVE-2008-0002","file_name":"2008/AVE-2008-0002.toml","cve_id":"CVE-2008-1059","title":"WordPress Sniplets 插件远程文件包含漏洞","description":"WordPress 的 Sniplets 插件 1.1.2 及 1.2.2 版本中存在 PHP 远程文件包含漏洞，位于 `modules/syntax_highlight.php` 文件中。未经认证的远程攻击者可通过 `libpath` 参数传入恶意 URL，导致任意 PHP 代码执行。攻击者可利用此漏洞完全控制目标网站服务器，危害严重。受影响的用户应立即升级或禁用该插件。","severity":"HIGH","score":7.5,"aliases":["CVE-2008-1059"],"sources":["nuclei"],"published":"2008-02-28T19:44:00.000","updated":"2026-06-16T22:50:53.943","remediation":"立即停用并彻底删除 Sniplets 插件（1.1.2/1.2.2 版），该插件已停止维护，无安全更新。如必须使用，修改 php.ini 中 allow_url_include 和 allow_url_fopen 为 Off，并升级 WordPress 至最新版本以减缓攻击面。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://secunia.com/advisories/29099","http://securityreason.com/securityalert/3706","http://www.securityfocus.com/archive/1/488734/100/0/threaded","http://www.securityfocus.com/bid/27985","https://exchange.xforce.ibmcloud.com/vulnerabilities/40829","https://www.exploit-db.com/exploits/5194","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2008/CVE-2008-1059.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2008/CVE-2008-1059.md","https://github.com/projectdiscovery/nuclei-templates/blob/69a5a3cf926251a00061ec14d208b227367df73d/http/cves/2008/CVE-2008-1059.yaml","https://github.com/CVEProject/cvelistV5/blob/6b5bb884a1dbb91134673e92ed8e62094db574f9/cves/2008/1xxx/CVE-2008-1059.json","https://github.com/topscoder/nuclei-wordfence-cve/blob/b4db95253d9e0f4fa88894d49422458d88bb2c32/nuclei-templates/2008/CVE-2008-1059-sniplets-5e90704e-1a0c-448c-9139-542927cfa4f8.yaml","https://github.com/cckuailong/reapoc/blob/699762e4c31d0183733f64313d8fc3be6470bd37/2008/README.md","https://github.com/rix4uni/nucleihub-templates/blob/579a0234551b9e0e322460a62dc77bd6109e4aff/nucleihub-templates/CVE-2008-1059_2.yaml","https://github.com/opencve/opencve-kb/blob/a5ed01398c096830b618c734267e2ea50e3a69c5/2008/CVE-2008-1059.json","https://github.com/adampielak/nuclei-templates/blob/ac9605f5a915670fd80cb4e1904f4435f1835b65/nuclei-v2/C/CVE-2008-1059_4.yaml","https://github.com/coreruleset/seaweed-reports/blob/3e2a1bd3dbca1b431f18ed0dabb71fa729d4d059/2023/Jan/08/Reports/lfiReport.csv","https://github.com/ARPSyndicate/suricata-vedas/blob/fe24794ad36564b5bbc7c69101525011387b8650/2008/CVE-2008-1059.rules"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/2008/POC-AVE-2008-0002.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/2008/EXP-AVE-2008-0002.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2008/AVE-2008-0002.toml"},{"ave_id":"AVE-2008-0001","file_name":"2008/AVE-2008-0001.toml","cve_id":"CVE-2008-0702","title":"Titan FTP Server USER/PASS 命令远程堆溢出漏洞","description":"Titan FTP Server 6.03 及 6.0.5.549 版本中存在多处基于堆的缓冲区溢出漏洞，远程攻击者可通过向 USER 或 PASS 命令发送超长参数触发该漏洞，导致服务进程崩溃或挂起，甚至可能执行任意代码。攻击无需身份认证，仅需目标开放 FTP 服务端口，可实现远程拒绝服务或代码执行。该漏洞与 CVE-2004-1641 属于不同的攻击向量，危害严重。","severity":"CRITICAL","score":9.3,"aliases":["CVE-2008-0702"],"sources":["nuclei"],"published":"2008-02-12T01:00:00.000","updated":"2026-06-16T22:50:10.213","remediation":"立即升级 Titan FTP Server 至 6.10 及以上版本（South River Technologies 已于 2008 年发布修复版本）。当前仍在使用的应迁移至受支持的 Titan MFT 或 Titan SFTP 产品线。临时缓解措施：在防火墙层面限制对 TCP 端口 21 的访问，仅允许白名单 IP 连接；同时在 IPS/IDS 设备上添加规则，检测并拦截长度超过 1024 字节的 USER 或 PASS 命令参数。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://secunia.com/advisories/28760","http://securityreason.com/securityalert/3639","http://www.securityfocus.com/archive/1/487431/100/0/threaded","http://www.securityfocus.com/bid/27568","http://www.vupen.com/english/advisories/2008/0393","https://www.exploit-db.com/exploits/5036","https://github.com/projectdiscovery/nuclei-templates/blob/main/network/cves/2008/CVE-2008-0702.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2008/CVE-2008-0702.md","https://github.com/projectdiscovery/nuclei-templates/blob/69a5a3cf926251a00061ec14d208b227367df73d/network/cves/2008/CVE-2008-0702.yaml","https://github.com/CVEProject/cvelistV5/blob/8aea42c71147e21c6d32b71ffce877107de995c6/cves/2008/0xxx/CVE-2008-0702.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2008/CVE-2008-0702","https://github.com/adampielak/nuclei-templates/blob/ac9605f5a915670fd80cb4e1904f4435f1835b65/nuclei-v3/C/CVE-2008-0702_6.yaml","https://github.com/youki992/VscanPlus/blob/714a0e276a538a22c1a6215c71458a8b59a920ef/pocs_yml/nucleiFiles/network/cves/2008/CVE-2008-0702.yaml","https://github.com/mabitoski/cve_submodules/blob/44ad7e2705b3aef1b2ffaf64bd47596c10a6c2e4/2008/CVE-2008-0702.md","https://github.com/github/advisory-database/blob/179c45b9fa0538b72b0d380b72ed3445aca781eb/advisories/unreviewed/2022/05/GHSA-m434-vxwp-c3vg/GHSA-m434-vxwp-c3vg.json","https://github.com/tholian-network/vulnerabilities/blob/cd8798a37e6d58633681c9596bee14e4189ad0e9/database/vulnerability/CVE-2008-0702.json","https://github.com/sailuh/perceive/blob/85ca622832e25fa91d8d836b8c93a096178bb35d/Notebooks/NVD/data/2008.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2008/AVE-2008-0001.toml"},{"ave_id":"AVE-2008-0010","file_name":"2008/AVE-2008-0010.toml","cve_id":"CVE-2008-5281","title":"South River Technologies Titan FTP Server 远程缓冲区溢出漏洞","description":"South River Technologies Titan FTP Server 6.05 存在栈缓冲区溢出漏洞，远程攻击者可通过向目标 FTP 服务器发送特制的 DELE 命令触发该漏洞，导致拒绝服务或远程代码执行。该漏洞影响 Titan FTP Server 6.05 build 550 及之前版本，攻击者无需认证即可利用，危害等级高危。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2008-5281"],"sources":["nuclei"],"published":"2008-11-29","updated":"2008-11-29","remediation":"立即升级 Titan FTP Server 至最新版本（该漏洞已在 6.05 build 550 之后的版本修复）；由于旧版 Titan FTP Server 已停止维护，建议迁移至 Titan MFT 或 Titan SFTP Server。如无法升级，在防火墙层面限制 FTP 端口（默认 21）的可信源 IP 白名单，并在服务器上禁用 DELE 命令或限制其执行权限作为临时缓解措施。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["https://www.exploit-db.com/exploits/31105","https://github.com/projectdiscovery/nuclei-templates/blob/main/network/cves/2008/CVE-2008-5281.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2008/CVE-2008-5281.md","https://github.com/projectdiscovery/nuclei-templates/blob/490586283f9ca1596471e5230c91d74f96495bb9/network/cves/2008/CVE-2008-5281.yaml","https://github.com/CVEProject/cvelistV5/blob/6b5bb884a1dbb91134673e92ed8e62094db574f9/cves/2008/5xxx/CVE-2008-5281.json","https://github.com/adampielak/nuclei-templates/blob/ac9605f5a915670fd80cb4e1904f4435f1835b65/nuclei-v3/C/CVE-2008-5281_9.yaml","https://github.com/Patrowl/PatrowlHearsData/blob/0287dd3c7f7460ce5db63d69ee5530c51a548735/CVE/data/2008/CVE-2008-5281.json","https://github.com/youki992/VscanPlus/blob/714a0e276a538a22c1a6215c71458a8b59a920ef/pocs_yml/nucleiFiles/network/cves/2008/CVE-2008-5281.yaml","https://github.com/mabitoski/cve_submodules/blob/44ad7e2705b3aef1b2ffaf64bd47596c10a6c2e4/2008/CVE-2008-5281.md","https://github.com/github/advisory-database/blob/179c45b9fa0538b72b0d380b72ed3445aca781eb/advisories/unreviewed/2022/05/GHSA-gfhc-mhqj-6287/GHSA-gfhc-mhqj-6287.json","https://github.com/CVEDB/Poc-Git/blob/0275aeb329b0747c9a1d46160c921eae06095557/2008/CVE-2008-5281.md","https://github.com/adampielak/nuclei-templates/blob/ac9605f5a915670fd80cb4e1904f4435f1835b65/nuclei-v3/C/CVE-2008-5281_28.yaml"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2008/AVE-2008-0010.toml"}]