ve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0383.md","https://github.com/Patrowl/PatrowlHearsData/blob/8c57fab4f71bd6fdcec1202e5361e2a9805c4950/CVE/data/1999/CVE-1999-0383.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-7hmx-xxrr-h2wg/GHSA-7hmx-xxrr-h2wg.json","https://github.com/xqcyberscore/nvt/blob/978f6a9acb495d7d669239530ffe6da5d631f4da/pre2008/account_public_public.nasl","https://github.com/LubyRuffy/plugins/blob/f873b19f27c95eaf2993ca4acde5cb7965d2ee3f/pre2008/acc.nasl","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0383.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153300_153400.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0619.toml"],"repo_exp_urls":[],"has_poc":true,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0619.toml"},{"ave_id":"AVE-1999-0595","file_name":"1999/AVE-1999-0595.toml","cve_id":"CVE-1999-0363","title":"S.u.S.E. Linux 5.2 lpc 缓冲区溢出本地权限提升漏洞","description":"SuSE Linux 5.2 系统中的 lpc（行式打印机控制）程序存在缓冲区溢出漏洞，本地攻击者可通过向 lpc 程序发送特制的输入参数触发该溢出，从而获取 root 权限。该漏洞影响 SuSE Linux 5.2 版本，CVSS 评分 7.2，危害等级高。由于需要本地访问权限，攻击者须先拥有系统普通用户账户方可利用。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0363"],"sources":["epss"],"published":"1999-02-02T05:00:00.000","updated":"2026-06-16T21:48:14.117","remediation":"升级 SuSE Linux 至 5.3 及以上版本，该版本已修复 lpc 程序缓冲区溢出漏洞。如无法升级，建议限制 lpc 可执行文件的 SUID 权限（chmod u-s /usr/sbin/lpc）以降低提权风险。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.securityfocus.com/bid/328","https://www.exploit-db.com/exploits/19259","https://gith