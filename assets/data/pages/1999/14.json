tp://marc.info/?l=ntbugtraq&m=92162979530341&w=2","http://support.microsoft.com/support/kb/articles/q222/1/59.asp","https://exchange.xforce.ibmcloud.com/vulnerabilities/7398","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/1xxx/CVE-1999-1317.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1317","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1317.md","https://github.com/Patrowl/PatrowlHearsData/blob/58eef6eedd760f280b47bfb4c94db9995b29c5a0/CVE/data/1999/CVE-1999-1317.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-fgh9-68h7-45xw/GHSA-fgh9-68h7-45xw.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1317.json","https://github.com/opsxcq/mirror-vxheaven.org/blob/4675a2c53cbb825974e4df213a6b129d5d52c764/vxheaven.org/index.html%3Fdetails=720","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153900_154000.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001021.txt","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--23b5b680-7984-4f54-9813-18b17b1b0ce3.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1038.toml"},{"ave_id":"AVE-1999-1037","file_name":"1999/AVE-1999-1037.toml","cve_id":"CVE-1999-1316","title":"Microsoft Windows NT SP2 密码安全筛选策略漏洞","description":"Windows NT SP2 附带的 Passfilt.dll 密码过滤器存在设计缺陷，无法有效阻止用户设置包含用户名的密码。攻击者可利用该漏洞，通过结合已知用户名进行针对性密码猜测攻击，大幅降低暴力破解难度，可能导致未授权访问或权限提升。该漏洞影响 Windows NT SP2 系统，需用户交互触发。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-1316"],"sources":["cve"],"published":"1999-12-31T05:00:00.000","updated":"2026-06-16T21:50:10.843","remediation":"Windows NT 已停止支持，建议升级至 Windows Server 2019/2022 或更高版本。若无法升级，在 Windows NT 中可通过「域安全策略」→「密码策略」启用「密码必须符合复杂性要求」，并禁用允许密码包含用户名的策略，同时设置密码长度最小值≥8 位。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://support.microsoft.com/support/kb/articles/Q247/9/75.asp","https://exchange.xforce.ibmcloud.com/vulnerabilities/7391","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/1xxx/CVE-1999-1316.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1316","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1316.md","https://github.com/Patrowl/PatrowlHearsData/blob/58eef6eedd760f280b47bfb4c94db9995b29c5a0/CVE/data/1999/CVE-1999-1316.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-m9pv-rhw7-3fh9/GHSA-m9pv-rhw7-3fh9.json","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1316.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153900_154000.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_001020.txt","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--d807e3af-205b-4b29-b446-fd385a964d1b.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1037.toml"},{"ave_id":"AVE-1999-1036","file_name":"1999/AVE-1999-1036.toml","cve_id":"CVE-1999-1315","title":"DEC OpenVMS DECnet/OSI 权限提升与拒绝服务漏洞","description":"DECnet/OSI for OpenVMS 5.8 之前版本中存在安全漏洞，DEC Alpha AXP 和 VAX/VMS 系统上的本地用户可利用该漏洞提升权限或导致拒绝服务。该漏洞源于 DECnet 网络协议栈在处理特定协议数据时存在边界条件缺陷，攻击者通过向受影响系统发送特制的 DECnet 数据包，可触发协议栈处理异常，进而造成系统服务崩溃或获取非授权访问权限。","severity":"MEDIUM","score":4.6,"aliases":["CVE-1999-1315"],"sources":["cve"],"published":"1999-12-31T05:00:00.000","updated":"2026-06-16T21:50:10.717","remediation":"升级 DECnet/OSI for OpenVMS 至 5.8 或更高版本。如无法升级，在非必要系统上禁用 DECnet/OSI 协议栈，限制本地用户对敏感系统组件的访问权限，并监控系统审计日志中异常的权限提升行为。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://ciac.llnl.gov/ciac/bulletins/f-04.shtml","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/1xxx/CVE-1999-1315.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1315","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1315.md","https://github.com/Patrowl/PatrowlHearsData/blob/58eef6eedd760f280b47bfb4c94db9995b29c5a0/CVE/data/1999/CVE-1999-1315.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-8jgc-f2hf-74fp/GHSA-8jgc-f2hf-74fp.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x85000/84458/info.html","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1315.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/nomi-sec/CVE-Easy-List/blob/8358776d7db47304e3a87c0f78eff81411ac0e47/1999.tsv","https://github.com/Yuning-J/NVDFeatureAnalysis/blob/493a57a415cc110f9945148abd717eeb92f6ca7e/originalDataset/cveIDThreatType/cve_idgainpre"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1036.toml"},{"ave_id":"AVE-1999-1035","file_name":"1999/AVE-1999-1035.toml","cve_id":"CVE-1999-1307","title":"Novell UnixWare urestore 本地权限提升漏洞","description":"Novell UnixWare 1.1 的 urestore 工具存在权限许可漏洞，本地攻击者可利用该工具在处理恢复操作时未正确限制特权执行路径的缺陷，通过精心构造的恢复数据或参数触发权限提升，从而获得 root 权限。该漏洞影响 Novell UnixWare 1.1 版本，需本地访问权限，危害等级高危。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-1307"],"sources":["cve"],"published":"1999-12-31T05:00:00.000","updated":"2026-06-16T21:50:09.703","remediation":"从 Novell 官方渠道获取并安装针对 UnixWare 1.1 urestore 漏洞的安全补丁（参见 CIAC Bulletin F-06）。如无法安装补丁，可执行 `chmod u-s /usr/bin/urestore` 移除该命令的 setuid 权限位，作为临时缓解措施。建议升级至受支持的 Unix 或 Linux 发行版，从根本上规避该产品已停止安全更新的风险。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://ciac.llnl.gov/ciac/bulletins/f-06.shtml","http://www.dataguard.no/bugtraq/1994_4/0676.html","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/1xxx/CVE-1999-1307.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1307","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1307.md","https://github.com/Patrowl/PatrowlHearsData/blob/58eef6eedd760f280b47bfb4c94db9995b29c5a0/CVE/data/1999/CVE-1999-1307.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-cr84-5qj8-f776/GHSA-cr84-5qj8-f776.json","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-1307.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153900_154000.json","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--fca28a80-1505-4ad5-962e-45d3a10f89e6.json","https://github.com/Yuning-J/VulnerabilityClassifier/blob/c0f06c21b73c26b5ee2b75c21a498eb04eada4b5/threatPrediction/cveIDThreatType/cve_idgainpre","https://github.com/hungryfoolou/Vulnerability_Mining/blob/3df1d8ed0489ae1228f975ae1f58a690aae53886/craw/cveid_craw/cveid_craw/data/cveid_by_kind/cveid_gainpre.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1035.toml"},{"ave_id":"AVE-1999-1034","file_name":"1999/AVE-1999-1034.toml","cve_id":"CVE-1999-1300","title":"Cray UNICOS 任意文件读取漏洞","description":"Cray UNICOS 6.0 和 6.1 版本中的 accton 工具存在任意文件读取漏洞。本地攻击者利用该工具对系统记账配置文件的处理缺陷，可读取系统上任意文件内容，同时可修改系统记账配置，导致敏感信息泄露和系统审计功能异常。该漏洞需要本地用户权限才能利用，攻击复杂度较低，影响范围限于 Cray UNICOS 特定版本。","severity":"LOW","score":3.6,"aliases":["CVE-1999-1300"],"sources":["cve"],"published":"1999-12-31T05:00:00.000","updated":"2026-06-16T21:50:08.807","remediation":"升级到 Cray UNICOS 6.2 及以上版本，该版本已修复 accton 命令的权限检查缺陷。如无法升级，可移除 accton 的 setuid 位（chmod u-s /usr/sbin/accton）以消除本地提权与任意文件读取风险，但会牺牲记账功能。作为替代方案，限制可登录系统的用户范围，仅授予可信用户 shell 访问权限。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://ciac.llnl.gov/ciac/bulletins/b-31.shtml","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/1xxx/CVE-1999-1300.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1300","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-1300.md","https://github.com/Patrowl/PatrowlHearsData/blob/58eef6eedd760f280b47bfb4c94db9995b29c5a0/CVE/data/1999/CVE-1999-1300.json","https://github.com/github/advisory-database/blob/6eca843f42fd99f