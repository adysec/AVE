com/github/advisory-database/blob/1b2e09705f0816776a0a8a0cd6fc1208d25f09b2/advisories/unreviewed/2022/04/GHSA-73j6-752c-7hrj/GHSA-73j6-752c-7hrj.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0235.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_2.list.dict","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--ed289855-2ebf-495d-9754-266d2c9ea1e7.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0420.toml"},{"ave_id":"AVE-1999-0419","file_name":"1999/AVE-1999-0419.toml","cve_id":"CVE-1999-0234","title":"GNU Bash 命令分隔符注入漏洞","description":"Bash 在处理命令解析时存在分隔符逻辑缺陷，会将字节值 255（0xFF）错误识别为命令分隔符。攻击者通过向 Bash 执行的字符串中注入包含 0xFF 字节的特制数据，可导致命令注入，实现以当前用户权限执行任意命令，造成机密性、完整性、可用性部分损失。该漏洞影响 openlinux 等使用早期 Bash（1.x 及以前版本）的 Linux 系统，CVSS 评分 4.6，危害等级中危。","severity":"MEDIUM","score":4.6,"aliases":["CVE-1999-0234"],"sources":["avd"],"published":"1996-10-08T04:00:00.000","updated":"2026-06-16T21:47:58.140","remediation":"立即升级 Bash 至 2.0 或更高版本，255 字节在已修复版本中不会被解析为命令分隔符。如无法升级，可对用户输入进行严格过滤，移除或替换 ASCII 255 字节（0xFF），并限制不可信数据传入交互式 Bash 环境。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0234"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0419.toml"},{"ave_id":"AVE-1999-0418","file_name":"1999/AVE-1999-0418.toml","cve_id":"CVE-1999-0233","title":"Microsoft IIS 1.0 .cmd/.bat 文件远程命令执行漏洞","description":"Microsoft IIS 1.0、Netscape Server 1.0/1.12 及 O'Reilly WebSite Professional 1.1b 等早期 Web 服务器在处理 .cmd 和 .bat 文件请求时存在远程命令执行漏洞。远程攻击者通过向受影响服务器发送包含 .cmd 或 .bat 后缀的 HTTP 请求，可导致服务器直接执行任意系统命令。该漏洞影响多种主流 Web 服务器软件，危害严重。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0233"],"sources":["exploitdb"],"published":"1996-02-25T05:00:00.000","updated":"2026-06-16T21:47:58.010","remediation":"对于 Microsoft IIS 1.0，打开 Internet 服务管理器，删除 .bat 和 .cmd 扩展名的脚本映射，或升级至 IIS 2.0 及以上版本（已于后续版本中默认移除该映射）。对于 Netscape Server 1.0/1.12，升级至 Netscape Enterprise Server 2.0 或更高版本。对于 O'Reilly WebSite Professional 1.1b，升级至 WebSite Professional 2.0 或更高版本。鉴于以上产品均已终止支持且停止更新，强烈建议迁移至仍在安全维护周期内的现代 Web 服务器产品。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://support.microsoft.com/default.aspx?scid=kb%3B%5BLN%5D%3BQ148188","http://support.microsoft.com/default.aspx?scid=kb%3B%5BLN%5D%3BQ155056","https://www.exploit-db.com/exploits/20445","https://github.com/CVEProject/cvelistV5/blob/ead50dc12e50bdd7f50b53d9d01c9f9946862c44/cves/1999/0xxx/CVE-1999-0233.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0233","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0233.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-0233.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-2752-8gwx-98x4/GHSA-2752-8gwx-98x4.json","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/snort/drop-rules/web-iis.rules","https://github.com/marcellodesales/aibbp-reverse-engineer/blob/960f610d597aae9fec1cc5f03c68679be00c222d/reverse_engineer/invicti/vulnerabilities/db/vulnerabilities/vdb/1999/0xxx/cve-1999-0233.yaml","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-02