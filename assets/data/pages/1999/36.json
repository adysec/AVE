://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/nessus/nessus-plugins/scripts/netbios_name_get.nasl","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0621.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/gitpan/QualysGuard-Request/blob/d9b44790f3fe9c775d3c27df315f23d890890583/t/02-ticket_list.t","https://github.com/opexxx/Metasploit-Unleashed-ebook/blob/c8c7947d4d4a18382b92c12c7ece8573da39c1de/05_vulnerability_scanning/06_working_with_nessus/working_with_nessus.html","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0621.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0912.toml"},{"ave_id":"AVE-1999-0910","file_name":"1999/AVE-1999-0910.toml","cve_id":"CVE-1999-0620","title":"NIS 相关服务运行配置问题","description":"该漏洞编号已被 NVD 驳回，原描述为目标系统上运行了 NIS（Network Information System）组件服务。NIS 协议在设计上缺乏加密和认证机制，通过网络在局域网内传输用户账户数据（包括密码哈希）时，处于同一网段的攻击者可进行网络嗅探，捕获 NIS 映射数据后实施离线破解，进而获取系统访问权限。该问题属于安全配置核查范畴，并非传统代码层面的安全漏洞，广泛影响启用 NIS 服务的 Unix/Linux 系统。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0620"],"sources":["avd"],"published":"1999-01-01T05:00:00.000","updated":"2023-11-07T01:54:59.480","remediation":"如业务无需 NIS 服务，应停止 ypserv/ypbind 服务并设置开机不自启：systemctl disable --now ypserv ypbind。如确需使用 NIS，应在 /var/yp/securenets 中限定仅允许受信任子网访问，并避免与互联网直连。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://github.com/CVEProject/cvelistV5/blob/5917e2b15694e167c1fd9ad85775b2bdfc5fe29c/cves/1999/0xxx/CVE-1999-0620.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0620","https://github.com/Patrowl/PatrowlHearsData/blob/a55bddfc5dd568e972e08b703ab596ed3580b7ba/CVE/data/1999/CVE-1999-0620.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0620.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/fkie-cad/nvd-json-data-feeds/blob/1b69cf2313f68e29acceed58f52f6109cd37bb04/CVE-1999/CVE-1999-06xx/CVE-1999-0620.json","https://github.com/williamjsmail/piranha/blob/e60f12e6edcde8585ee473f701c2421f6efe72d9/CVE2CAPEC/database/CVE-1999.jsonl","https://github.com/cmjayasinghe/Threat-Intelligence-Dashboard/blob/ccfec8014cc85c9e776b8f657bdb7879139ab5ed/data/cves.csv","https://github.com/Software-Engineering-2026-Class/kelompok4-cyber-kg-agentic/blob/0fc3a7d1e2416617ef834c956997e1f0f283424b/parser_agent/output/cve.ttl"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0910.toml"},{"ave_id":"AVE-1999-0907","file_name":"1999/AVE-1999-0907.toml","cve_id":"CVE-1999-0619","title":"通用 Telnet 服务配置不当问题","description":"该候选编号已被拒绝，原描述为\"Telnet 服务正在运行\"。Telnet 协议以明文传输所有数据（包括用户名和密码），未提供任何加密或认证机制，远程攻击者可通过网络嗅探拦截并窃取敏感凭据。此条目属于安全配置问题（不应启用不安全的 Telnet 服务）而非软件漏洞，因此被移入通用配置枚举（CCE）进行管理，建议使用 SSH 等安全替代方案。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0619"],"sources":["avd"],"published":"1999-01-01T05:00:00.000","updated":"2023-11-07T01:54:59.450","remediation":"关闭 Telnet 服务（端口 23），改用 SSH（端口 22）进行远程管理。如因兼容性无法禁用，应在防火墙限制 Telnet 的源 IP 访问范围，仅允许受信任的管理网段连接，并启用加密通道（如 stunnel）封装 Telnet 流量。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://github.com/CVEProject/cvelistV5/blob/5917e2b15694e167c1fd9ad85775b2bdfc5fe29c/cves/1999/0xxx/CVE-1999-0619.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0619","https://github.com/Patrowl/PatrowlHearsData/blob/a55bddfc5dd568e972e08b703ab596ed3580b7ba/CVE/data/1999/CVE-1999-0619.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0619.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/harshsingh4469/endpoint-security-analyzer/blob/39935d29fd093a995963ab16d1953b9224b57717/scanner.py","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000455.txt","https://github.com/SwethaV0611/Network_vuln/blob/fce59788552720e2cf78ee52ee7c584a9475da61/scanner/vulnerability.py","https://github.com/athiasjerome/XORCISM/blob/327e2a3be196660f82c89ae9d7c4e7abe4785b0d/SOURCES/XProviderQualys/QualysSampleResults.xml"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0907.toml"},{"ave_id":"AVE-1999-0904","file_name":"1999/AVE-1999-0904.toml","cve_id":"CVE-1999-0618","title":"Unix rexec 服务权限提升漏洞","description":"rexec（远程执行）服务是一种未加密的远程命令执行协议，运行在 TCP 512 端口，使用主机名和 .rhosts 文件进行基于主机的认证。攻击者可通过伪造信任主机 IP 地址或利用 .rhosts 配置缺陷绕过认证，在目标系统上以当前用户权限执行任意命令，实现权限提升。该服务默认不启用加密，明文传输密码，容易被中间人攻击窃听。该漏洞 CVSS 评分 10.0，危害等级严重，建议禁用 rexec 服务并改用 SSH。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0618"],"sources":["avd"],"published":"1999-01-01T05:00:00.000","updated":"2026-06-16T21:48:44.510","remediation":"立即禁用 rexec 服务（通常为 /etc/inetd.conf 中注释 exec 行或 systemctl stop rexec），并使用 SSH（OpenSSH）替代所有远程执行需求。检查系统是否仍在运行 rexecd/in.rexecd 进程并予以停止卸载。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://www.cve.org/CVERecord?id=CVE-1999-0618","https://github.com/CVEProject/cvelistV5/blob/5917e2b15694e167c1fd9ad85775b2bdfc5fe29c/cves/1999/0xxx/CVE-1999-0618.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0618","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0618.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0618.md","https://github.com/Patrowl/PatrowlHearsData/blob/a55bddfc5dd568e972e08b703ab596ed3580b7ba/CVE/data/1999/CVE-1999-0618.json","https://github.com/DefectDojo/django-DefectDojo/blob/619e5656f308396a3cc3a7f039c6426ae98baa17/unittests/scans/openvas/many_vuln.xml","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/nessus/nessus-plugins/scripts/rexecd.nasl","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-jw99-fq4j-hx93/GHSA-jw99-fq4j-hx93.json","https://github.com/ornl-sava/nv/blob/8cbf2a775f3c35accff96fe30217e9afff65410e/data/metasploitable.2.0.nbe","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0618.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0904.toml"}]