","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/snort/drop-rules/web-iis.rules","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/A/asp_source_data.nasl"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0464.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0464.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0464.toml"},{"ave_id":"AVE-1999-0463","file_name":"1999/AVE-1999-0463.toml","cve_id":"CVE-1999-0277","title":"Sun Solaris WorkMan 任意文件覆盖本地权限提升漏洞","description":"Solaris 操作系统中的 WorkMan 日历程序存在任意文件覆盖漏洞。本地攻击者可利用 WorkMan 程序的缺陷，通过符号链接攻击或直接指定路径覆盖系统任意文件（如 /etc/passwd 或 /bin/su 等），从而获得 root 权限。该漏洞影响 Solaris 系统，攻击者需要拥有本地用户账号才能利用，CVSS 评分 7.2，危害等级高。通过覆盖关键系统文件实现提权，目前厂商已发布相关安全公告。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0277"],"sources":["avd"],"published":"1996-10-28T05:00:00.000","updated":"2026-06-16T21:48:03.473","remediation":"立即移除 WorkMan 二进制文件的 setuid 权限：执行 `chmod -s /usr/bin/workman`。如已安装 Sun 补丁 100176-01（适用于 Solaris 2.4/2.5/2.5.1），请安装该补丁修复符号链接竞争条件。若业务不需要该日历程序，建议直接删除 `/usr/bin/workman` 以彻底消除风险。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0277"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0463.toml"},{"ave_id":"AVE-1999-0462","file_name":"1999/AVE-1999-0462.toml","cve_id":"CVE-1999-0276","title":"Hughes Technologies mSQL 缓冲区溢出漏洞","description":"mSQL（Mini SQL）2.0.1 及更早版本存在缓冲区溢出漏洞。远程攻击者可向目标服务的 1114 端口发送特制的畸型数据包，触发栈缓冲区溢出，进而覆盖返回地址，实现远程代码执行。该漏洞影响 mSQL 2.0.1 及之前所有版本，CVSS 评分 7.5，危害等级高危，无需认证即可远程利用。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0276"],"sources":["epss"],"published":"1999-01-01T05:00:00.000","updated":"2026-06-16T21:48:03.350","remediation":"立即将 mSQL 升级至 v2.0.1 以上版本（如 2.0.2 或更高），该版本修复了 wprint 函数中的缓冲区溢出问题。由于 mSQL 已停止维护多年，强烈建议迁移至受支持的数据库产品，如 MariaDB 或 PostgreSQL。在无法迁移前，应通过在防火墙上限制对 mSQL 默认端口（1114/TCP）的访问来源，仅允许受信任的 IP 连接，作为临时缓解措施。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0276","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0276.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0276","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0276.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0276.md","https://github.com/Patrowl/PatrowlHearsData/blob/2f876a2c24d5ccd5bbd081f09e801e580536456a/CVE/data/1999/CVE-1999-0276.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-j548-f7g3-8wxc/GHSA-j548-f7g3-8wxc.json","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/snort/drop-rules/sid-msg.map","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/slacker247/GPDA/blob/fa9006d0877a691f1ddffe88799c844a3e8a669a/Sodi/Run/IDSrules/rule.863","https://github.com/fkie-cad/nvd-json-data-feeds/blob/1b69cf2313f68e29acceed58f52f6109cd37bb04/CVE-1999/CVE-1999-02xx/CVE-1999-0276.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0462.toml"},{"ave_id":"AVE-1999-0461","file_name":"1999/AVE-1999-0461.toml","cve_id":"CVE-1999-0275","title":"Microsoft Windows NT 4.0 DNS Server 拒绝服务漏洞","description":"Windows NT 4.0 DNS 服务器存在拒绝服务漏洞，远程攻击者无需身份认证即可通过向目标系统的 UDP 53 端口发送大量超长字符数据包，导致 DNS 服务耗尽系统资源而崩溃拒绝服务。该漏洞影响 Windows NT 4.0 系统，攻击条件简单，仅需网络可达即可实施攻击。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0275"],"sources":["epss"],"published":"1997-06-10T04:00:00.000","updated":"2026-06-16T21:48:03.227","remediation":"安装 Microsoft Windows NT 4.0 Service Pack 4 或更高版本安全更新，限制仅允许信任源 IP 访问 DNS 服务端口 53，在防火墙层面启用速率限制和连接数控制以缓解 DNS 泛洪攻击。建议升级至 Windows Server 2003 或更高版本以获得持续安全支持。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0275","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0275.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0275","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0275.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0275.md","https://github.com/Patrowl/PatrowlHearsData/blob/2ed73314b4d66512efbb22e0644e615bc00001f2/CVE/data/1999/CVE-1999-0275.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-w59j-5972-p7cr/GHSA-w59j-5972-p7cr.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/W/winnt_dns_flood.nasl","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0275.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0461.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0461.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0461.toml"},{"ave_id":"AVE-1999-0460","file_name":"1999/AVE-1999-0460.toml","cve_id":"CVE-1999-0274","title":"Microsoft Windows NT 4.0 DNS Server 拒绝服务漏洞","description":"Microsoft Windows NT 4.0 DNS 服务器存在拒绝服务漏洞。远程攻击者可向目标服务器发送一个未经请求的恶意 DNS 应答数据包，由于服务器未对该应答与待处理查询进行匹配验证，处理该异常响应时会导致服务进程崩溃或资源耗尽，造成正常的域名解析服务中断。攻击者无需认证即可远程触发该漏洞。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0274"],"sources":["epss"],"published":"1997-01-01T05:00:00.000","updated":"2026-06-16T21:48:03.090","remediation":"升级 Windows NT 4.0 至 Service Pack 4 及以上版本，或在 DNS 服务器上配置仅响应来自可信上游 DNS 的查询请求，并在边界防火墙上过滤源端口 53 的非授权 DNS 响应数据包，防止伪造 DNS 应答触发拒绝服务。如无法升级，建议将 DNS 服务迁移至 Windows 2000 Server 或后续受支持版本。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0274","https://github.com/trickest/cve/blob/34851454a7b07498072de47d56f63daa4a4f524d/1999/CVE-1999-0274.md","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0274.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0274","https://github.com/edoardottt/missing-cve-nuclei-templates/blob/36c16d53eb6071e39cfc3cf88e99f1b340ec913b/data/year/1999.txt","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0274.json","https://github.com/Patrowl/PatrowlHearsData/blob/2ed73314b4d66512efbb22e0644e615bc00001f2/CVE/data/1999/CVE-1999-0274.json","https://github.com/mabitoski/cve_submodules/blob/44ad7e2705b3aef1b2ffaf64bd47596c10a6c2e4/1999/CVE-1999-0274.md","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-5q47-xw9h-8mx2/GHSA-5q47-xw9h-8mx2.json","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0274.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0460.toml"},{"ave_id":"AVE-1999-0459","file_name":"1999/AVE-1999-0459.toml","cve_id":"CVE-1999-0273","title":"Sun Solaris 2.5.1 Telnet 控制字符拒绝服务漏洞","description":"Sun Solaris 2.5.1 Telnet 服务存在控制字符处理缺陷，远程攻击者无需认证即可通过向目标系统的 telnet 端口发送 ^D（Ctrl+D）控制字符，导致 telnet 守护进程崩溃或进入异常状态，从而造成拒绝服务。该漏洞影响 Sun Solaris 2.5.1 操作系统，攻击利用难度低，无需特殊权限即可触发，属于典型的拒绝服务漏洞。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0273"],"sources":["epss"],"published":"1998-01-01T05:00:00.000","updated":"2026-06-16T21:48:02.973","remediation":"升级至 Oracle Solaris 11 或更高版本，并停止使用 telnet 服务；在 inetd.conf 中注释 telnet 行（或执行 svcadm disable telnet），改用 SSH 作为远程管理协议。若必须运行旧版系统，限制 telnet 服务的源 IP 访问并部署入侵检测规则监控异常 ^D 字符序列。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0273","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0273.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0273","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0273.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0273.md","https://github.com/Patrowl/PatrowlHearsData/blob/2ed73314b4d66512efbb22e0644e615bc00001f2/CVE/data/1999/CVE-1999-0273.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-2mh6-5954-wmgr/GHSA-2mh6-5954-wmgr.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/S/sunkill.nasl","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0273.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x83000/82086/info.html"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0459.toml"},{"ave_id":"AVE-1999-0458","file_name":"1999/AVE-1999-0458.toml","cve_id":"CVE-1999-0272","title":"Slmail POP3 拒绝服务漏洞","description":"Slmail 3.0.2421 及 2.5 版本的 POP3 服务存在拒绝服务漏洞，远程攻击者无需身份认证即可通过向目标主机的 POP3 端口（默认 110）发送特制恶意数据包，导致服务进程崩溃或停止响应，造成正常的邮件收发功能中断。该漏洞利用方式简单，无需复杂权限即可触发，影响运行 Slmail 服务的邮件服务器系统。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0272"],"sources":["epss"],"published":"1997-10-01T04:00:00.000","updated":"2026-06-16T21:48:02.843","remediation":"Slmail 产品已停止维护多年，建议迁移至现代受支持的邮件服务器软件（如 Postfix、Exchange 等）。如仍需继续使用，可在防火墙层面限制 POP3 端口（110）仅允许受信任 IP 段访问，并监控异常连接流量作为临时缓解。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0272","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0272.json","https://github.com/Patrowl/PatrowlHearsData/blob/2ed73314b4d66512efbb22e0644e615bc00001f2/CVE/data/1999/CVE-1999-0272.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0272.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511