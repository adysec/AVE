[{"ave_id":"AVE-1999-0309","file_name":"1999/AVE-1999-0309.toml","cve_id":"CVE-1999-0702","title":"Microsoft Internet Explorer Import/Export Favorites 远程代码执行漏洞","description":"Microsoft Internet Explorer 4.0.1 及 5.x 版本的\"导入/导出收藏夹\"功能存在代码注入漏洞。远程攻击者可构造恶意收藏夹文件，诱使用户通过该功能导入，从而在用户系统上执行任意代码或修改文件。该漏洞影响 IE 4.0.1 至 5.01 版本，攻击者无需身份认证，利用难度低，CVSS 评分 10.0，危害等级严重。Microsoft 已发布安全更新修复此漏洞。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0702"],"sources":["avd"],"published":"1999-09-10T04:00:00.000","updated":"2026-06-16T21:48:52.797","remediation":"升级到 Internet Explorer 5.01 Service Pack 2 或更高版本以修复 ImportExportFavorites 漏洞。由于 IE 已停止支持，建议立即升级到 Microsoft Edge 或 Chrome 等现代浏览器，并在组策略中禁用 ActiveX 控件和脚本执行作为临时缓解措施。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://support.microsoft.com/default.aspx?scid=kb%3B%5BLN%5D%3BQ241361","http://www.securityfocus.com/bid/627","https://docs.microsoft.com/en-us/security-updates/securitybulletins/1999/ms99-037","https://www.exploit-db.com/exploits/19490","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/0xxx/CVE-1999-0702.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0702","https://github.com/fankh/vulnerability-poc/blob/da1ae45b8d49565b6ec43a0af3ddc2b6a2d9fdb0/1999/CVE-1999-0702/README.md","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0702.md","https://github.com/Patrowl/PatrowlHearsData/blob/8c57fab4f71bd6fdcec1202e5361e2a9805c4950/CVE/data/1999/CVE-1999-0702.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-2q7j-jrwg-8822/GHSA-2q7j-jrwg-8822.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-0702.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_4.list.dict"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0309.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0309.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0309.toml"},{"ave_id":"AVE-1999-0308","file_name":"1999/AVE-1999-0308.toml","cve_id":"CVE-1999-0696","title":"多厂商 CDE Calendar Manager Service Daemon (rpc.cmsd) 缓冲区溢出漏洞","description":"CDE 日历管理服务守护进程（rpc.cmsd）存在缓冲区溢出漏洞，远程攻击者可通过向目标系统发送特制的 RPC 请求触发该漏洞，导致拒绝服务或任意代码执行。该漏洞影响 Caldera OpenUnix 8.0/UnixWare 7.1.1、HP HP-UX 11.0、Solaris 7.0 及 SunOS 4.1.4 等多个 Unix 操作系统版本，CVSS 评分 10.0，危害等级严重。攻击者无需身份认证即可远程利用此漏洞。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0696"],"sources":["avd"],"published":"1999-07-01T04:00:00.000","updated":"2026-06-16T21:48:52.067","remediation":"建议立即安装各厂商对应安全补丁：Solaris 7.0 安装补丁 106827-01 或 106828-01，HP-UX 11.0 安装 PHSS_19757 补丁，UnixWare 7.1.1 安装 erg711905 补丁。如无法打补丁，可在 inetd.conf 中注释掉 rpc.cmsd 服务行并重启 inetd，或在防火墙层面阻止对 611/TCP 端口的访问作为临时缓解措施。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://sunsolve.sun.com/pub-cgi/retrieve.pl?doctype=coll&doc=secbull/188","http://www.ciac.org/ciac/bulletins/j-051.shtml","http://www1.itrc.hp.com/service/cki/docDisplay.do?docId=HPSBUX9908-102","https://www.exploit-db.com/exploits/19421","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/0xxx/CVE-1999-0696.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0696","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0696.md","https://github.com/Patrowl/PatrowlHearsData/blob/58eef6eedd760f280b47bfb4c94db9995b29c5a0/CVE/data/1999/CVE-1999-0696.json","https://github.com/eldondev/Snort/blob/34bdcf6a7a638b55c7c04f77ef1efa526ad08e33/doc/signatures/1907.txt","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-h3qp-3qwx-3x56/GHSA-h3qp-3qwx-3x56.json","https://github.com/NetBSD/pkgsrc-wip/blob/6723edd43ced2a9627d0c0e8bf12d208cfde84d5/sara/PLIST","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/snort/drop-rules/sid-msg.map","https://github.com/bailehang/snort_2.2.0/blob/34f8a3a85f15645aea53d6e0d46863c7c57e43ef/doc/signatures/1909.txt","https://github.com/xqcyberscore/nvt/blob/978f6a9acb495d7d669239530ffe6da5d631f4da/2011/gb_cde_rpc_cmsd_service_detect.nasl"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0308.toml"},{"ave_id":"AVE-1999-0307","file_name":"1999/AVE-1999-0307.toml","cve_id":"CVE-1999-0713","title":"Compaq Tru64 UNIX dtlogin 本地权限提升漏洞","description":"Compaq Tru64 UNIX 系统中的 dtlogin 程序在处理用户身份验证时存在权限提升漏洞。本地攻击者可通过向 dtlogin 程序发送特制请求或利用其不安全的配置，成功利用此漏洞可将自身权限提升至 root 级别，从而完全控制目标系统。该漏洞影响 Compaq Tru64 UNIX 多个版本，CVSS 评分 7.2，危害等级高。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0713"],"sources":["cve"],"published":"1999-06-11T04:00:00.000","updated":"2026-06-16T21:48:54.077","remediation":"请升级至 Compaq Tru64 UNIX 最新可用补丁包（如 Tru64 UNIX 5.1B-6 及对应 Patch Kit），该漏洞在后续版本中已修复。如无法升级，建议移除 dtlogin 程序的 setuid root 权限（chmod u-s /usr/dt/bin/dtlogin）以消除本地提权风险，或禁用 CDE 桌面环境服务替代为安全登录方式。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://www.ciac.org/ciac/bulletins/j-044.shtml"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0307.toml"},{"ave_id":"AVE-1999-0306","file_name":"1999/AVE-1999-0306.toml","cve_id":"CVE-1999-0692","title":"Cray Unicos Array Services 守护进程默认认证绕过漏洞","description":"Cray UNICOS 操作系统中的 Array Services 守护进程（arrayd）存在默认配置不当漏洞。该服务在默认安装情况下关闭了身份认证机制，导致远程攻击者无需任何凭证即可直接连接 arrayd 端口，并以 root 权限在目标系统上执行任意命令。攻击条件极低——只需目标开放 arrayd 服务且使用默认配置即可完成利用。该漏洞 CVSS 评分 10.0，危害等级严重，影响 Cray UNICOS 系列操作系统。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0692"],"sources":["avd"],"published":"1999-07-19T04:00:00.000","updated":"2026-06-16T21:48:51.550","remediation":"升级 Cray Unicos 至厂商修复版本（如 8.0 及以上补丁级别），或修改 arrayd 配置文件启用认证（设置 require_authentication=yes）。如无法升级，使用 iptables 限制仅有信任管理节点可访问 arrayd 端口（默认 TCP/1050）。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.ciac.org/ciac/bulletins/j-052.shtml","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/0xxx/CVE-1999-0692.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0692","https://github.com/fankh/vulnerability-poc/blob/479b29734109e75b43136719820cebdc00fad096/1999/CVE-1999-0692/README.md","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0692.md","https://github.com/Patrowl/PatrowlHearsData/blob/58eef6eedd760f280b47bfb4c94db9995b29c5a0/CVE/data/1999/CVE-1999-0692.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/05/GHSA-g2hc-xmvw-hhph/GHSA-g2hc-xmvw-hhph.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0692.json","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--9e4ef6a4-48d0-4517-8dd9-a548963a1dd4.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0306.toml"},{"ave_id":"AVE-1999-0305","file_name":"1999/AVE-1999-0305.toml","cve_id":"CVE-1999-0712","title":"Caldera Open Administration System 权限许可和访问控制漏洞","description":"Caldera Open Administration System (COAS) 存在权限配置不当漏洞，导致系统关键密码文件 /etc/shadow 被设置为全局可读。本地攻击者可利用该漏洞直接读取 Shadow 文件内容，进而获取系统所有用户密码哈希值，通过离线破解获得明文密码，最终实现未授权访问或权限提升。该漏洞影响 Caldera COAS 相关版本，CVSS 评分 2.1，危害等级低。","severity":"LOW","score":2.1,"aliases":["CVE-1999-0712"],"sources":["cve"],"published":"1999-04-27T04:00:00.000","updated":"2026-06-16T21:48:53.950","remediation":"立即以 root 身份执行 chmod 600 /etc/shadow 将 shadow 文件恢复为仅 root 可读写权限，并检查是否被非法读取；安装 Caldera 官方提供的 COAS 安全补丁或更新至包含修复的 OpenLinux 版本；如无需使用 COAS Web 管理界面，建议直接停止并禁用 COAS 服务（kill coasd 并移除自启动）；鉴于 Caldera OpenLinux 已停止维护多年，强烈建议迁移至仍在安全支持期内的现代 Linux 发行版（如 RHEL/Debian/Ubuntu LTS）。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0712"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0305.toml"},{"ave_id":"AVE-1999-0304","file_name":"1999/AVE-1999-0304.toml","cve_id":"CVE-1999-0149","title":"SGI IRIX cgi-bin wrap 目录遍历漏洞","description":"SGI IRIX 6.2 系统中的 cgi-bin wrap 程序存在目录遍历漏洞，远程攻击者可通过在 URL 参数中使用 `..`（点点）序列绕过路径限制，访问并列出服务器上任意目录的内容。该漏洞无需身份认证即可利用，可导致敏感文件信息泄露，例如系统配置文件、用户数据等。攻击条件简单，仅需目标系统运行存在漏洞的 wrap CGI 程序即可实施。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0149"],"sources":["exploitdb"],"published":"1997-04-19T04:00:00.000","updated":"2026-06-16T21:47:42.233","remediation":"建议升级至 SGI IRIX 6.3 及以上版本，或直接移除系统 cgi-bin 目录下的 wrap CGI 脚本。若无法升级，在 Web 服务器（如 Netscape FastTrack）配置中严格限制 cgi-bin 目录访问权限，并禁用路径穿越（..）与目录列表功能以作临时缓解。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://www.osvdb.org/247","http://www.securityfocus.com/bid/373","https://exchange.xforce.ibmcloud.com/vulnerabilities/290","https://www.exploit-db.com/exploits/19298","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0149.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0149","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0149.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0149.md","https://github.com/Patrowl/PatrowlHearsData/blob/2f876a2c24d5ccd5bbd081f09e801e580536456a/CVE/data/1999/CVE-1999-0149.json","https://github.com/stg-tud/cveenhance/blob/6476e73d87cdc9cf610342ef15d131432ab41588/Annotations/UnAnnotated/CVE-1999-0149.xml","https://github.com/NetBSD/pkgsrc-wip/blob/9e4b769742ed57395763142c26029c2f9910f15b/sara/PLIST","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/snort/drop-rules/web-cgi.rules","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/W/wrap.nasl","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0304.toml"},{"ave_id":"AVE-1999-0303","file_name":"1999/AVE-1999-0303.toml","cve_id":"CVE-1999-0711","title":"Oracle 8.x 智能代理 oratclsh 解释器本地权限提升漏洞","description":"Oracle 8.x Intelligent Agent for Unix 中的 oratclsh 解释器存在不安全的 SUID 权限配置漏洞。该解释程序设置了 SUID root 权限位，导致本地攻击者可利用 oratclsh 以 root 身份执行任意 Tcl 命令，实现本地权限提升，获取目标系统完全控制权。该漏洞影响 Oracle 8.x 系列版本，攻击前提是已获得系统本地访问权限，无需额外认证可直接提权至 root，危害等级中危。","severity":"MEDIUM","score":4.6,"aliases":["CVE-1999-0711"],"sources":["cve"],"published":"1999-04-29T04:00:00.000","updated":"2026-06-16T21:48:53.820","remediation":"建议移除 oratclsh 的 setuid 权限位：执行 `chmod u-s $ORACLE_HOME/bin/oratclsh` 或 `chmod 755 $ORACLE_HOME/bin/oratclsh` 阻止非授权用户以 root 执行 Tcl 命令。同时升级到 Oracle 9i 及以上受支持版本，或限制可执行该二进制文件的用户组为 dba。如确需使用智能代理，配置系统访问控制（如 sudo 白名单）严格限制调用权限。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://marc.info/?l=bugtraq&m=92609807906778&w=2","http://marc.info/?t=92550157100002&w=2&r=1","https://www.exploit-db.com/exploits/19125"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0303.toml"},{"ave_id":"AVE-1999-0301","file_name":"1999/AVE-1999-0301.toml","cve_id":"CVE-1999-0147","title":"Glimpse GlimpseHTTP/WebGlimpse aglimpse CGI 远程命令执行漏洞","description":"GlimpseHTTP 1.0/2.0 及 WebGlimpse 1.0 的 aglimpse CGI 组件中存在远程命令执行漏洞。攻击者可通过向该 CGI 程序发送特制的管道命令参数，利用服务器端对用户输入过滤不严的缺陷，在目标系统上以 Web 服务器进程权限执行任意命令。该漏洞影响早期 GlimpseHTTP 及 WebGlimpse 版本，CVSS 评分 7.5，危害等级高，无需认证即可远程触发。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0147"],"sources":["exploitdb"],"published":"1997-07-01T04:00:00.000","updated":"2026-06-16T21:47:41.957","remediation":"立即停止使用 GlimpseHTTP/WebGlimpse，从 cgi-bin 目录中移除 aglimpse 可执行文件，并迁移至现代受支持的 Web 服务器（如 Apache/Nginx）。如无法立即迁移，可在 Web 服务器层面限制 aglimpse 脚本执行权限，设置仅授权 IP 可访问 cgi-bin 目录，同时移除不必要的 CGI 程序以减少攻击面。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0147","https://www.exploit-db.com/exploits/20449","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0147.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0147","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0147.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0147.md","https://github.com/Patrowl/PatrowlHearsData/blob/2ed73314b4d66512efbb22e0644e615bc00001f2/CVE/data/1999/CVE-1999-0147.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-j92f-fc3c-68gj/GHSA-j92f-fc3c-68gj.json","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/snort/drop-rules/sid-msg.map","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/G/glimpse.nasl","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0147.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0301.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0301.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0301.toml"},{"ave_id":"AVE-1999-0300","file_name":"1999/AVE-1999-0300.toml","cve_id":"CVE-1999-0590","title":"Linux Linux Kernel 未显示用户访问法律警告信息漏洞","description":"Linux 系统在用户登录访问前未显示适当的法律声明或警告信息（如\"仅限授权用户使用\"等提示），导致未经授权的访问者无法获知系统访问权限规定及法律后果。攻击者可在无任何警告提示的情况下直接尝试登录系统，降低了安全策略的合规性。该漏洞影响早期 Linux 内核版本，属于安全策略配置缺陷而非代码逻辑漏洞，通常通过修改 /etc/issue 和 /etc/issue.net 等登录横幅文件添加法律声明来修复。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0590"],"sources":["avd"],"published":"2000-06-01T04:00:00.000","updated":"2026-06-16T21:48:41.527","remediation":"在 /etc/issue 和 /etc/issue.net 中添加经法务审核的未授权访问警告文本，如 \"WARNING: Unauthorized access is prohibited and subject to legal action.\"。对于 SSH 服务，在 /etc/ssh/sshd_config 中设置 Banner /etc/issue.net 并重启 sshd。对 Telnet/FTP 等服务也需配置对应横幅文件。建议同时设置 /etc/motd 显示登录后法律声明。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://ciac.llnl.gov/ciac/bulletins/j-043.shtml","https://github.com/CVEProject/cvelistV5/blob/2765cfa5d0fc39151c354509f5ba2b7abfdb61de/cves/1999/0xxx/CVE-1999-0590.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0590","https://github.com/Patrowl/PatrowlHearsData/blob/37da04e8698400cbfe936368ce494fc186159eb4/CVE/data/1999/CVE-1999-0590.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0590.json","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0590.json","https://github.com/opencve/opencve-kb/blob/b13a5af37e59aa19fd1ac1c09247642e81435453/1999/CVE-1999-0590.json","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0590.json","https://github.com/fkie-cad/nvd-json-data-feeds/blob/97009c469920f4d8991128f84d19644c3badca15/CVE-1999/CVE-1999-05xx/CVE-1999-0590.json","https://github.com/CyberSecAI/cve_info/blob/03b7e36424574a3a9ba5fd13480a326b666a1046/1999/0xxx/CVE-1999-0590.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0590.md"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0300.toml"},{"ave_id":"AVE-1999-0299","file_name":"1999/AVE-1999-0299.toml","cve_id":"CVE-1999-0146","title":"NCSA httpd campas CGI 远程命令执行漏洞","description":"NCSA httpd 服务器自带的 campas CGI 程序未对用户输入进行充分过滤，远程攻击者可通过在查询字符串中插入编码的回车符（CR）注入任意系统命令，进而读取服务器上的敏感文件（如密码文件）或执行其他恶意操作。该漏洞影响多个版本的 NCSA web 服务器，无需身份认证即可远程利用，危害严重。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0146"],"sources":["exploitdb"],"published":"1997-07-15T04:00:00.000","updated":"2026-06-16T21:47:41.800","remediation":"删除 cgi-bin 目录下的 campas 示例脚本，或确保 NCSA httpd 已升级至不受影响的版本。建议迁移至长期维护的 Web 服务器（如 Apache HTTP Server），并移除所有示例 CGI 脚本以避免类似安全问题。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://www.securityfocus.com/bid/1975","https://exchange.xforce.ibmcloud.com/vulnerabilities/298","https://www.exploit-db.com/exploits/20423","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0146.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0146","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0146.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0146.md","https://github.com/Patrowl/PatrowlHearsData/blob/2ed73314b4d66512efbb22e0644e615bc00001f2/CVE/data/1999/CVE-1999-0146.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-c22c-6v4p-99rm/GHSA-c22c-6v4p-99rm.json","https://github.com/NetBSD/pkgsrc-wip/blob/9e4b769742ed57395763142c26029c2f9910f15b/sara/PLIST","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/snort/drop-rules/sid-msg.map","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/Freem93/grammar_nasl_v2/blob/63834ebb8cd6e97050e155291c7500ad53bb20c6/plugins/campas.nasl"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0299.toml"},{"ave_id":"AVE-1999-0298","file_name":"1999/AVE-1999-0298.toml","cve_id":"CVE-1999-0145","title":"Sendmail WIZ 命令远程权限提升漏洞","description":"Sendmail WIZ 命令漏洞存在于 sendmail 邮件服务器软件中，其 DEBUG 模式的 WIZ 命令默认开启且未经身份认证。远程攻击者可直接连接至 SMTP 端口（25/TCP），发送 WIZ 命令后输入 root 即可获得目标系统最高权限，实现完全控制。该漏洞影响早期版本 sendmail，危害严重，攻击门槛极低，无需任何前置条件即可远程利用。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0145"],"sources":["epss"],"published":"1993-09-30T04:00:00.000","updated":"2026-06-16T21:47:41.620","remediation":"升级 Sendmail 至 8.6.10 或更新版本（该版本已移除 WIZ 调试命令），或在 sendmail.cf 中注释或移除 `Ow` 相关 WIZ 选项来禁用 WIZ 命令。若无法立即升级，应在防火墙上限制对 TCP 25 端口的访问，仅允许可信来源连接 SMTP 服务。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://seclists.org/fulldisclosure/2019/Jun/16","http://www.alw.nih.gov/Security/Docs/admin-guide-to-cracking.101.html","http://www.cert.org/advisories/CA-1990-11.html","http://www.cert.org/advisories/CA-1993-14.html","http://www.openwall.com/lists/oss-security/2019/06/05/4","http://www.openwall.com/lists/oss-security/2019/06/06/1","http://www2.dataguard.no/bugtraq/1995_1/0332.html"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0298.toml"},{"ave_id":"AVE-1999-0297","file_name":"1999/AVE-1999-0297.toml","cve_id":"CVE-1999-0708","title":"Martin Schulze Cfingerd GECOS 缓冲区溢出漏洞","description":"cfingerd 1.4.2 存在缓冲区溢出漏洞，本地用户可通过向 GECOS 字段提交超长输入触发栈溢出，从而获取 root 权限。该漏洞影响 Martin Schulze Cfingerd 1.4.2 及更早版本，攻击者需拥有本地系统访问权限，利用难度较低。成功利用后攻击者可完全控制目标系统，CVSS 评分 7.2，危害等级高。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0708"],"sources":["avd"],"published":"1999-09-21T04:00:00.000","updated":"2026-06-16T21:48:53.557","remediation":"立即升级 cfingerd 至 1.4.3 及以上版本，该版本已修复 GECOS 字段长度检查逻辑。如无法升级，可在 /etc/cfingerd.conf 中限制本地用户登录或禁用 cfingerd 服务，改用安全替代方案如 inetutils-inetd 的 fingerd。同时建议使用 AppArmor/SELinux 限制 cfingerd 进程权限，降低提权风险。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.securityfocus.com/bid/651","https://www.exploit-db.com/exploits/19504","https://github.com/CVEProject/cvelistV5/blob/6df16fc0c02ccadd2d0fbb0029e3db345d75f1c8/cves/1999/0xxx/CVE-1999-0708.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0708","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0708.md","https://github.com/Patrowl/PatrowlHearsData/blob/8c57fab4f71bd6fdcec1202e5361e2a9805c4950/CVE/data/1999/CVE-1999-0708.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-3rpm-2rjq-r29f/GHSA-3rpm-2rjq-r29f.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/C/cfinger_format_bug.nasl","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-0708.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/debiancn/debian.org/blob/6abc98daa6356b20e410013a6920b3764af682d4/english/security/1999/19990806.data"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0297.toml"},{"ave_id":"AVE-1999-0296","file_name":"1999/AVE-1999-0296.toml","cve_id":"CVE-1999-0707","title":"HP Visualize Conference FTP 未授权文件传输漏洞","description":"HP Visualize Conference 的默认 FTP 配置存在授权缺失漏洞。该软件在 HP-UX 系统上运行时，其 FTP 服务默认允许会议中的任意参与者向其他与会者发送文件，而无需经过任何身份验证或授权检查。远程攻击者可在未授权的情况下，利用该默认配置向会议中的其他用户传输任意文件，导致敏感信息泄露或恶意文件分发。该漏洞影响 HP Visualize Conference 相关版本，CVSS 评分 7.5，危害等级高。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0707"],"sources":["avd"],"published":"1999-07-01T04:00:00.000","updated":"2026-06-16T21:48:53.430","remediation":"立即应用 HP 安全公告 HPSBUX9906-099 提供的补丁，或升级 HP Visualize Conference 至修复版本。如无法升级，在 FTP 服务配置中禁用未经授权的文件传输功能，并在网络层面限制对 FTP 端口（默认 21）的访问，仅允许受信任的 IP 连接。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.ciac.org/ciac/bulletins/j-050.shtml","http://www.securityfocus.com/bid/493","http://www1.itrc.hp.com/service/cki/docDisplay.do?docId=HPSBUX9906-099","https://github.com/CVEProject/cvelistV5/blob/6df16fc0c02ccadd2d0fbb0029e3db345d75f1c8/cves/1999/0xxx/CVE-1999-0707.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0707","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0707.md","https://github.com/Patrowl/PatrowlHearsData/blob/8c57fab4f71bd6fdcec1202e5361e2a9805c4950/CVE/data/1999/CVE-1999-0707.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-c7p7-q447-5vcr/GHSA-c7p7-q447-5vcr.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153500_153600.json","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-0707.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000686.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0296.toml"},{"ave_id":"AVE-1999-0294","file_name":"1999/AVE-1999-0294.toml","cve_id":"CVE-1999-0144","title":"Dan Bernstein QMail 远程拒绝服务漏洞","description":"QMail 1.0 存在拒绝服务漏洞，远程攻击者无需认证即可通过 SMTP 协议的 RCPT 命令指定大量收件人地址，导致 QMail 在处理过程中消耗过多系统资源（CPU 与内存），最终造成邮件服务瘫痪。该漏洞影响 Dan Bernstein QMail 1.0 及早期版本，CVSS 评分为 2.1，危害等级低。官方建议升级至 QMail 1.03 或更高版本进行修复。","severity":"LOW","score":2.1,"aliases":["CVE-1999-0144"],"sources":["exploitdb"],"published":"1997-06-01T04:00:00.000","updated":"2026-06-16T21:47:41.470","remediation":"升级到 netqmail 1.06 或应用 qmail-1.03 的 RCPT DoS 补丁；在 qmail-smtpd 中设置软限制参数 `MAXRCPTS`（如设为 100），限制单次 SMTP 会话的收件人数量；同时启用 `rcpthosts` 和 `morercpthosts` 控制邮件转发，防止被滥用为拒绝服务攻击的反射点。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://cr.yp.to/qmail/venema.html","http://marc.info/?l=bugtraq&m=87602558319024&w=2","http://marc.info/?l=bugtraq&m=87602558319029&w=2","http://www.ornl.gov/its/archives/mailing-lists/qmail/1997/06/threads.html","http://www.securityfocus.com/bid/2237","https://exchange.xforce.ibmcloud.com/vulnerabilities/208","https://www.exploit-db.com/exploits/20562","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0144.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0144","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0144.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0144.md","https://github.com/Patrowl/PatrowlHearsData/blob/2ed73314b4d66512efbb22e0644e615bc00001f2/CVE/data/1999/CVE-1999-0144.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-78g5-jc8q-wgq5/GHSA-78g5-jc8q-wgq5.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x3000/2237/info.html","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_154300_154400.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0144.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0294.toml"},{"ave_id":"AVE-1999-0293","file_name":"1999/AVE-1999-0293.toml","cve_id":"CVE-1999-0143","title":"MIT Kerberos 4 密钥服务器会话密钥伪造漏洞","description":"Kerberos 4 密钥服务器存在会话密钥破解漏洞，攻击者可通过破解并伪造会话密钥来伪装成任意合法用户身份。该漏洞影响 Kerberos 4 密钥分发中心（KDC），攻击者无需高级权限即可实施身份欺骗攻击，可能导致未授权访问受保护网络资源。CVSS 评分 4.6，危害等级中危。","severity":"MEDIUM","score":4.6,"aliases":["CVE-1999-0143"],"sources":["avd"],"published":"1996-02-21T05:00:00.000","updated":"2026-06-16T21:47:41.347","remediation":"升级至 Kerberos 5 协议（MIT Kerberos 1.11+ 或 Active Directory 均已废弃 Kerberos 4），Kerberos 5 使用更强的加密算法和安全的会话密钥协商机制。如在旧系统中仍启用 Kerberos 4 兼容模式，应关闭 krb4 支持（设置 KRB5_KRB4_COMPAT=no），并禁用 Telnet/FTP 等明文传输通道以减少凭据泄露风险。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0143"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0293.toml"}]