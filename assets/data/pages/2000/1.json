[{"ave_id":"AVE-2000-0002","file_name":"2000/AVE-2000-0002.toml","cve_id":"CVE-2000-0760","title":"Apache Tomcat Snoop Servlet 信息泄露漏洞","description":"Jakarta Tomcat 3.0 和 3.1 版本中的 Snoop Servlet 存在信息泄露漏洞。远程攻击者无需认证即可向目标服务器发送一个不存在的 .snp 后缀 URL 请求，触发 Snoop Servlet 返回系统属性、环境变量、请求参数等敏感信息。该漏洞可能导致服务器内部配置和文件路径等关键信息暴露，为攻击者后续入侵提供情报基础，影响所有运行在 Apache 下的 Tomcat 3.0 及 3.1 版本。","severity":"MEDIUM","score":6.4,"aliases":["CVE-2000-0760"],"sources":["nuclei"],"published":"2000-10-20T04:00:00.000","updated":"2026-06-16T21:52:25.440","remediation":"升级到 Tomcat 3.2 或更高版本以彻底移除 Snoop Servlet；若无法升级，删除 `$CATALINA_HOME/webapps/ROOT/WEB-INF/web.xml` 中 Snoop Servlet 的 `<servlet-mapping>` 配置，或直接移除 `snoop.jar` 文件，并重启 Tomcat 服务使配置生效。也可在 Apache 反向代理层添加访问规则，拦截对 `*.snp` 路径的请求作为临时缓解。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://www.securityfocus.com/bid/1532","http://www.securityfocus.com/frames/?content=/templates/archive.pike%3Flist%3D1%26date%3D2000-07-15%26msg%3DPine.SUN.3.96.1000719235404.24004A-100000%40grex.cyberspace.org","https://www.exploit-db.com/exploits/20132","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2000/CVE-2000-0760.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2000/CVE-2000-0760.md","https://github.com/projectdiscovery/nuclei-templates/blob/a5c2e8e4dab8c8e618ba76807c3e07587b7d781a/http/cves/2000/CVE-2000-0760.yaml","https://github.com/CVEProject/cvelistV5/blob/d5838f491a2d04e9f823fb9638e9e6f0b038d399/cves/2000/0xxx/CVE-2000-0760.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0760","https://github.com/ARPSyndicate/suricata-vedas/blob/fe24794ad36564b5bbc7c69101525011387b8650/2000/CVE-2000-0760.rules","https://github.com/hack007x/veil_poc/blob/5cfe1da6e975ba816d728597885a5c5e79bda8bd/cves/2000/CVE-2000-0760.poc","https://github.com/Patrowl/PatrowlHearsData/blob/a7dc09e86ccf6c48996b8c45fb9dcbb33ad05167/CVE/data/2000/CVE-2000-0760.json","https://github.com/p0dalirius/ApacheTomcatScanner/blob/af5077ce3aeae4c7df3be909998bb54e3812c742/apachetomcatscanner/data/vulnerabilities/2000/CVE-2000-0760.json","https://github.com/InfoSecWarrior/Vulnerable-Box-Resources/blob/c784bcf63e1ec5c3a0116043d8653d00f0a21a0b/Infosecwarrior/My-Tomcat-Host/MyTomcatHost-1-nuclei-8080-output.txt","https://github.com/runZeroInc/nuclei-templates/blob/89af8e391d368228625addfe3ecc6aee3b5d0345/http/cves/2000/CVE-2000-0760.yaml"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/2000/POC-AVE-2000-0002.toml"],"repo_exp_urls":[],"has_poc":true,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0002.toml"},{"ave_id":"AVE-2000-0001","file_name":"2000/AVE-2000-0001.toml","cve_id":"CVE-2000-0114","title":"Microsoft FrontPage Server Extensions 信息泄露漏洞","description":"Microsoft FrontPage Server Extensions 存在信息泄露漏洞，远程攻击者可通过向目标服务器 /_vti_bin/ 虚拟目录下的 shtml.dll 发送特制的 RPC POST 请求，导致服务器返回匿名账户名称信息。该漏洞使得攻击者能够获取目标系统有效用户名，为后续暴力破解或其他身份认证绕过攻击提供便利条件。影响 Microsoft FrontPage Server Extensions 相关版本，CVSS 评分 5.0，危害等级中等。","severity":"MEDIUM","score":5,"aliases":["CVE-2000-0114"],"sources":["nuclei"],"published":"2000-02-02T05:00:00.000","updated":"2026-06-16T21:51:01.787","remediation":"安装 Microsoft 发布的 FrontPage Server Extensions 2000 安全更新 (MS00-015)，禁用匿名用户通过 RPC POST 请求访问 `_vti_bin/shtml.dll`；通过 IIS 管理控制台移除 `_vti_bin` 虚拟目录的匿名访问权限，或限制可访问该目录的 IP 地址范围。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-2000-0114","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2000/CVE-2000-0114.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2000/CVE-2000-0114.md","https://github.com/nomi-sec/PoC-in-GitHub/blob/a8dd65f3bd9f09f4c40ddbec294c8d30c1b24bd7/2000/CVE-2000-0114.json","https://github.com/projectdiscovery/nuclei-templates/blob/a5c2e8e4dab8c8e618ba76807c3e07587b7d781a/http/cves/2000/CVE-2000-0114.yaml","https://github.com/ExpLangcn/NucleiTP/blob/2b7ecb9031a6eda4f272793045f29b339d8e0cce/CVES/low/cve-2000-0114-1296.yaml","https://github.com/linuxadi/40k-nuclei-templates/blob/542be6820c801c02a33aee60f1c05ca7b0b5005f/aditya/folder4/cve-2000-0114-1297.yaml","https://github.com/rix4uni/nucleihub-templates/blob/579a0234551b9e0e322460a62dc77bd6109e4aff/nucleihub-templates/CVE-2000-0114_3.yaml","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0114","https://github.com/0xKayala/Custom-Nuclei-Templates/blob/1940dfd29577590f076c89dec5c30d809d68f210/5001-to-6000-templates/cve-2000-0114-1297.yaml","https://github.com/Cappricio-Securities/CVE-2000-0114/blob/d55271822e7949554affd151f8066eceba688ebf/cve20000114/includes/filereader.py","https://github.com/lucacoratu/disertatie/blob/a2c31bd97f20ca0f95df5d2a9c35f46a0798dbde/agent/rules/CVEs/CVE-2000-0114.yaml","https://github.com/Cappricio-Securities/CVE-2000-0114","https://github.com/adhamelhansye/CVE-2000-0114","https://github.com/Josekutty-K/frontpage-server-extensions-vulnerability-scanner"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0001.toml"}]