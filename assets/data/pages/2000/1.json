son","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/2000/CVE-2000-0308.json","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--3ba2bd6a-56d3-4758-a3b9-f10406d45458.json","https://github.com/Yuning-J/VulnerabilityClassifier/blob/c0f06c21b73c26b5ee2b75c21a498eb04eada4b5/threatPrediction/cveIDThreatType/cve_idgainpre"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0808.toml"},{"ave_id":"AVE-2000-0360","file_name":"2000/AVE-2000-0360.toml","cve_id":"CVE-2000-0351","title":"SCO UnixWare 软件包管理命令本地权限提升漏洞","description":"SCO UnixWare 7.1.0 的软件包管理命令存在不安全的权限设置漏洞，本地攻击者利用该漏洞可绕过权限限制添加或移除系统软件包，可能导致系统配置被篡改或安装恶意软件包。此漏洞需要本地访问权限，攻击复杂度较低，CVSS 评分 4.6，危害等级中等。","severity":"MEDIUM","score":4.6,"aliases":["CVE-2000-0351"],"sources":["cve"],"published":"2001-03-12T05:00:00.000","updated":"2026-06-16T21:51:32.180","remediation":"建议立即应用 SCO 安全公告 SB-99.09b 中提供的补丁程序，修复 packaging 命令（如 pkgadd/pkgrm）的不安全权限问题。如无法打补丁，应严格限制本地用户对系统的交互式登录权限，移除不必要的本地用户账户，并审查 /var/sadm/pkg 等软件包管理目录的权限设置，确保仅 root 用户可执行软件包安装与删除操作。","status":"completed","collected_at":"2026-07-20T00:00:00Z","references":["https://github.com/CVEProject/cvelistV5/blob/4e8d44fc9434dcaf08511a3267e0bf049a6756de/cves/2000/0xxx/CVE-2000-0351.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0351","https://github.com/yarencheng/cve-devops-playground/blob/470a5f1c0d1bd36cd0a6327cda49cf96a1474588/content/CVE-2000-0351.md","https://github.com/Patrowl/PatrowlHearsData/blob/f9199c6ea2112c9d2536a126688b640a45f0982a/CVE/data/2000/CVE-2000-0351.json","https://github.com/github/advisory-database/blob/4544d3857250fe21711ce8febf38e8822729678f/advisories/unreviewed/2022/05/GHSA-86q7-rq88-2w73/GHSA-86q7-rq88-2w73.json","https://github.com/olbat/nvdcve/blob/39f1db26eec9899ab2f8110ab3b45424c6fe9ec2/nvdcve/CVE-2000-0351.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x89000/88305/info.html","https://github.com/nomi-sec/CVE-Easy-List/blob/dd9f81e9fd85457bf78c55783cb6a31e9af71d63/2000.tsv","https://github.com/williamjsmail/piranha/blob/e60f12e6edcde8585ee473f701c2421f6efe72d9/CVE2CAPEC/database/CVE-2000.jsonl","https://github.com/fkie-cad/nvd-json-data-feeds/blob/a913ac9f87691de86825ecccd6699d1970d6fddc/CVE-2000/CVE-2000-03xx/CVE-2000-0351.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0360.toml"},{"ave_id":"AVE-2000-0357","file_name":"2000/AVE-2000-0357.toml","cve_id":"CVE-2000-0349","title":"SCO UnixWare 7.1.0 Passthru Driver 拒绝服务漏洞","description":"SCO UnixWare 7.1.0 操作系统的 Passthru 驱动程序中存在安全漏洞，本地攻击者可通过向受影响系统发送特制的请求触发该驱动程序的异常处理错误，导致系统内核崩溃或服务不可用，造成拒绝服务。该漏洞影响 SCO UnixWare 7.1.0 版本，CVSS 评分 5.0，危害等级中等。攻击者需具有本地系统访问权限才能利用此漏洞。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2000-0349"],"sources":["cve"],"published":"2001-03-12T05:00:00.000","updated":"2026-06-16T21:51:31.923","remediation":"从 SCO 官方 FTP 获取并安装安全公告 SB-99.13a 提供的补丁，或联系 SCO 获取修补后的 passthru 驱动。由于 SCO UnixWare 7.1.0 已停止支持多年，建议迁移至受支持的操作系统（如现代 Linux 发行版）以彻底消除安全隐患。临时缓解措施可在系统层面限制对 passthru 驱动的访问权限。","status":"completed","collected_at":"2026-07-20T00:00:00Z","references":["https://github.com/CVEProject/cvelistV5/blob/4e8d44fc9434dcaf08511a3267e0bf049a6756de/cves/2000/0xxx/CVE-2000-0349.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2000/CVE-2000-0349","https://github.com/yarencheng/cve-devops-playground/blob/470a5f1c0d1bd36cd0a6327cda49cf96a1474588/content/CVE-2000-0349.md","https://github.com/Patrowl/PatrowlHearsData/blob/228df6a85079f5c6b1ecdfb3d41be685458438ef/CVE/data/2000/CVE-2000-0349.json","https:/