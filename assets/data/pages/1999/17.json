[{"ave_id":"AVE-1999-0249","file_name":"1999/AVE-1999-0249.toml","cve_id":"CVE-1999-0689","title":"Sun Solaris Common Desktop Environment dtspcd 本地权限提升漏洞","description":"Common Desktop Environment (CDE) 的 dtspcd 守护进程存在符号链接（symlink）漏洞，本地攻击者可通过创建恶意符号链接诱导 dtspcd 以提升的权限读取或写入任意文件，从而执行任意命令获取 root 权限。该漏洞影响 CDE 2.1.20 及 Solaris 7.0 等版本，CVSS 评分 7.2，危害等级高。攻击者需拥有本地系统访问权限，利用难度较低。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0689"],"sources":["avd"],"published":"1999-09-13T04:00:00.000","updated":"2026-06-16T21:48:51.173","remediation":"安装 Sun 安全公告 #192 中对应平台的 dtspcd 补丁（Solaris 7：Patch ID 106594-01；Solaris 2.6：106593-01；Solaris 2.5.1：106592-01），HP-UX 用户安装 HPSBUX9909-103 补丁。临时缓解措施可停止 dtspcd 服务（/usr/dt/bin/dtspcd -kill）或移除其 setuid root 权限（chmod 555 /usr/dt/bin/dtspcd）。由于 CDE 已停止维护，建议迁移至 GNOME/KDE 等其他桌面环境作为根本解决方案。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://sunsolve.sun.com/pub-cgi/retrieve.pl?doctype=coll&doc=secbull/192","http://www.securityfocus.com/bid/636","http://www1.itrc.hp.com/service/cki/docDisplay.do?docId=HPSBUX9909-103","https://oval.cisecurity.org/repository/search/definition/oval%3Aorg.mitre.oval%3Adef%3A1880","https://www.exploit-db.com/exploits/19498","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/0xxx/CVE-1999-0689.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0689","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0689.md","https://github.com/Patrowl/PatrowlHearsData/blob/638fc08494602a9faf37bf81043122f16d26625c/CVE/data/1999/CVE-1999-0689.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-wp6j-p4jf-4rwv/GHSA-wp6j-p4jf-4rwv.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--c3dc2ea0-0265-4c0c-ae08-6be3c238c97a.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_3.list.dict","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0689.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0249.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0249.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0249.toml"},{"ave_id":"AVE-1999-0309","file_name":"1999/AVE-1999-0309.toml","cve_id":"CVE-1999-0702","title":"Microsoft Internet Explorer Import/Export Favorites 远程代码执行漏洞","description":"Microsoft Internet Explorer 4.0.1 及 5.x 版本的\"导入/导出收藏夹\"功能存在代码注入漏洞。远程攻击者可构造恶意收藏夹文件，诱使用户通过该功能导入，从而在用户系统上执行任意代码或修改文件。该漏洞影响 IE 4.0.1 至 5.01 版本，攻击者无需身份认证，利用难度低，CVSS 评分 10.0，危害等级严重。Microsoft 已发布安全更新修复此漏洞。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0702"],"sources":["avd"],"published":"1999-09-10T04:00:00.000","updated":"2026-06-16T21:48:52.797","remediation":"升级到 Internet Explorer 5.01 Service Pack 2 或更高版本以修复 ImportExportFavorites 漏洞。由于 IE 已停止支持，建议立即升级到 Microsoft Edge 或 Chrome 等现代浏览器，并在组策略中禁用 ActiveX 控件和脚本执行作为临时缓解措施。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://support.microsoft.com/default.aspx?scid=kb%3B%5BLN%5D%3BQ241361","http://www.securityfocus.com/bid/627","https://docs.microsoft.com/en-us/security-updates/securitybulletins/1999/ms99-037","https://www.exploit-db.com/exploits/19490","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/0xxx/CVE-1999-0702.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0702","https://github.com/fankh/vulnerability-poc/blob/da1ae45b8d49565b6ec43a0af3ddc2b6a2d9fdb0/1999/CVE-1999-0702/README.md","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0702.md","https://github.com/Patrowl/PatrowlHearsData/blob/8c57fab4f71bd6fdcec1202e5361e2a9805c4950/CVE/data/1999/CVE-1999-0702.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-2q7j-jrwg-8822/GHSA-2q7j-jrwg-8822.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-0702.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_4.list.dict"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0309.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0309.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0309.toml"},{"ave_id":"AVE-1999-0273","file_name":"1999/AVE-1999-0273.toml","cve_id":"CVE-1999-0697","title":"SCO Doctor 本地权限提升漏洞","description":"SCO Doctor 管理工具中存在权限提升漏洞，本地用户可通过该工具的 \"Tools\" 选项以 root 权限执行任意操作。攻击者需拥有系统本地访问权限，利用该漏洞可完全控制受影响系统，包括修改系统配置、访问敏感数据及安装恶意程序。该漏洞影响 SCO OpenServer 等版本，CVSS 评分 7.2，危害等级高。建议用户限制本地用户对 SCO Doctor 工具的访问权限。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0697"],"sources":["avd"],"published":"1999-09-09T04:00:00.000","updated":"2026-06-16T21:48:52.187","remediation":"升级 SCO OpenServer 至 5.0.5 及以上版本，或安装 SCO 官方安全补丁 erg712103。如无法升级，移除 SCO Doctor 的 setuid root 权限（chmod u-s /opt/K/SCO/Doctor/1.0.0/bin/doctor），并限制可登录系统的本地用户账号数量，仅保留管理员可交互登录。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.securityfocus.com/bid/621","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/0xxx/CVE-1999-0697.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0697","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0697.md","https://github.com/Patrowl/PatrowlHearsData/blob/58eef6eedd760f280b47bfb4c94db9995b29c5a0/CVE/data/1999/CVE-1999-0697.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-fwr5-hvj8-gff6/GHSA-fwr5-hvj8-gff6.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0697.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153600_153700.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--6229833c-4cf2-4d79-b4d0-ced5f5ebb24d.json","https://github.com/Yuning-J/VulnerabilityClassifier/blob/c0f06c21b73c26b5ee2b75c21a498eb04eada4b5/threatPrediction/cveIDThreatType/cve_idgainpre"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0273.toml"},{"ave_id":"AVE-1999-0482","file_name":"1999/AVE-1999-0482.toml","cve_id":"CVE-1999-0767","title":"IBM AIX / Sun Solaris LC_MESSAGES 环境变量 libc 缓冲区溢出漏洞","description":"Solaris libc 库、ufsrestore 及 rcp 工具在处理 LC_MESSAGES 环境变量时存在缓冲区溢出漏洞。本地攻击者可通过设置超长 LC_MESSAGES 环境变量触发缓冲区溢出，从而以 root 权限执行任意代码。该漏洞影响 IBM AIX 4.2.1 及 Sun Solaris 7.0 等 Unix 系统，CVSS 评分 7.2，危害等级高。厂商已发布补丁修复该问题。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0767"],"sources":["cve"],"published":"1999-09-08T04:00:00.000","updated":"2026-06-16T21:49:00.953","remediation":"对 Sun Solaris 7.0 系统，安装 Sun 安全补丁 107733-01 或更新版本；对 IBM AIX 4.2.1 系统，升级到 APAR IX89537 修复版本或安装对应 bos.rte.libc 补丁包。无法立即升级时，可通过在 /etc/environment 或 shell 启动脚本中过滤 LC_MESSAGES 环境变量（如 unset LC_MESSAGES）来缓解该缓冲区溢出风险。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["https://marc.info/?l=bugtraq&m=87602167420557&w=2","https://www.exploit-db.com/exploits/19217"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0482.toml"},{"ave_id":"AVE-1999-1309","file_name":"1999/AVE-1999-1309.toml","cve_id":"CVE-1999-0926","title":"Apache HTTP Server MIME Header 拒绝服务漏洞","description":"Apache HTTP Server 1.2.5 及 1.3.1 版本在处理大量 MIME 头部时存在拒绝服务漏洞。远程攻击者无需认证，通过向目标服务器发送包含大量 MIME 头部的特制 HTTP 请求，可耗尽服务器资源致其崩溃，无法响应正常请求。该漏洞利用简单，攻击门槛低，受影响版本包括 Apache 1.2.5/1.3.1 及 UnityMail 2.0。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0926"],"sources":["cve"],"published":"1999-09-03T04:00:00.000","updated":"2026-06-16T21:49:20.597","remediation":"升级至 Apache HTTP Server 1.3.2 或更高版本，该漏洞已在后续版本中修复。如无法立即升级，可在 httpd.conf 中通过 `LimitRequestFields` 指令限制请求头字段数量，减小 MIME 头泛滥导致拒绝服务的攻击面。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://archives.neohapsis.com/archives/bugtraq/1998_3/0742.html","https://www.exploit-db.com/exploits/20272"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1309.toml"},{"ave_id":"AVE-1999-0725","file_name":"1999/AVE-1999-0725.toml","cve_id":"CVE-1999-0925","title":"Messagemedia UnityMail 2.0 MIME Header 拒绝服务漏洞","description":"MessageMedia UnityMail 2.0 邮件服务器在处理邮件 MIME 头部时存在拒绝服务漏洞。远程攻击者无需身份认证即可向目标服务器发送包含大量 MIME 头的特制邮件，导致服务程序因资源耗尽而崩溃，影响正常邮件收发功能。该漏洞影响 UnityMail 2.0 版本，CVSS 评分 5.0，危害等级中危。厂商已发布相关安全公告。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0925"],"sources":["cve"],"published":"1999-09-03T04:00:00.000","updated":"2026-06-16T21:49:20.490","remediation":"建议升级至 UnityMail 2.1 或更高版本，该版本已在 MIME 解析器中加入头部数量限制。若供应商已停止支持该产品，应迁移至仍在维护的邮件服务器软件（如 Postfix、Exchange），并在边界邮件网关配置 MIME 头部数量阈值（建议≤100 个）作为临时缓解。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://marc.info/?l=bugtraq&m=90486243124867&w=2"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0725.toml"},{"ave_id":"AVE-1999-0970","file_name":"1999/AVE-1999-0970.toml","cve_id":"CVE-1999-1129","title":"Cisco Catalyst 2900 VLAN交换机 未授权VLAN遍历漏洞","description":"Cisco Catalyst 2900 系列虚拟局域网交换机中存在 IEEE 802.1q VLAN 遍历漏洞。远程攻击者可通过伪造中继标签中的 VLAN 标识符，向其他 VLAN 注入 802.1q 帧，从而打破 VLAN 隔离机制实现跨 VLAN 访问。该漏洞允许攻击者无需认证即可绕过网络隔离策略，窃取或篡改不同 VLAN 中的敏感数据。CVSS 评分 7.5，危害等级高。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-1129"],"sources":["cve"],"published":"1999-09-01T04:00:00.000","updated":"2026-06-16T21:49:46.940","remediation":"将所有非 trunk 端口设为静态 access 模式（`switchport mode access`），禁用 DTP（`switchport nonegotiate`），并在 trunk 端口上启用 VLAN 修剪（`vlan pruning`）以及限制允许的 VLAN 列表（`allowed vlan`）。同时配置本征 VLAN 为未使用的专用 ID 并关闭自动协商。这些措施可阻断伪造 802.1q 帧跨 VLAN 攻击。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://www.cisco.com/univercd/cc/td/doc/product/lan/28201900/1928v8x/eescg8x/aleakyv.htm","http://www.securityfocus.com/archive/1/26008","http://www.securityfocus.com/bid/615","https://exchange.xforce.ibmcloud.com/vulnerabilities/3294","https://github.com/CVEProject/cvelistV5/blob/92d64b4c9b3c5a0ce1fd1e5f8c017b9772e0139b/cves/1999/1xxx/CVE-1999-1129.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1129","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-1129.md","https://github.com/Patrowl/PatrowlHearsData/blob/db45dbc75ff0264d63b603291e4a83d7361bd7ba/CVE/data/1999/CVE-1999-1129.json","https://github.com/github/advisory-database/blob/79c2cf4630fcc44f2632735de08432a07cfaf204/advisories/unreviewed/2022/04/GHSA-29q9-4h2h-9p7g/GHSA-29q9-4h2h-9p7g.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x1000/615/info.html","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1129.json","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--ecbfddda-04a3-4138-b1cd-3892ec7d91fd.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/Vasileios-Mavroeidis/semantic-stix-vulnerability/blob/30f07606133364b9623f401bc306c8c9cbcf9386/vulnerability/vulnerability--ecbfddda-04a3-4138-b1cd-3892ec7d91fd.owl"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0970.toml"},{"ave_id":"AVE-1999-0684","file_name":"1999/AVE-1999-0684.toml","cve_id":"CVE-1999-0891","title":"Microsoft Internet Explorer 5 Download Behavior 任意文件读取漏洞","description":"Microsoft Internet Explorer 5 的下载行为（Download Behavior）功能存在安全漏洞。远程攻击者可通过构造特制的服务端重定向（server-side redirect）响应，诱使用户访问恶意网页后绕过 IE 5 的安全限制，实现跨域读取目标系统上的任意文件。该漏洞影响 Internet Explorer 5 版本，攻击成功的前提是受害者使用受影响浏览器访问攻击者控制的恶意站点，无需额外认证，可能导致敏感信息泄露。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0891"],"sources":["cve"],"published":"1999-09-01T04:00:00.000","updated":"2026-06-16T21:49:16.310","remediation":"立即升级 Internet Explorer 至 5.5 以上版本，该漏洞在 IE 5.5 及后续版本中已修复。如无法升级，建议禁用 ActiveX 控件及脚本下载行为：在 Internet 选项 → 安全 → 自定义级别中，将\"下载已签名的 ActiveX 控件\"和\"下载未签名的 ActiveX 控件\"均设为\"禁用\"。根本解决措施是停止使用已停止支持的 Internet Explorer，迁移至 Microsoft Edge 或 Chrome 等现代浏览器。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://support.microsoft.com/default.aspx?scid=kb%3B%5BLN%5D%3BQ242542","http://www.ciac.org/ciac/bulletins/k-002.shtml","http://www.kb.cert.org/vuls/id/37828","http://www.osvdb.org/11274","http://www.securityfocus.com/bid/674","https://docs.microsoft.com/en-us/security-updates/securitybulletins/1999/ms99-040","https://www.exploit-db.com/exploits/19530"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0684.toml"},{"ave_id":"AVE-1999-0400","file_name":"1999/AVE-1999-0400.toml","cve_id":"CVE-1999-0705","title":"ISC INN inews 缓冲区溢出漏洞","description":"ISC INN（InterNetNews）新闻服务器中的 inews 程序存在缓冲区溢出漏洞，远程攻击者可通过向目标系统发送特制的新闻组文章数据触发该漏洞，导致缓冲区溢出，进而可能造成拒绝服务或远程代码执行。该漏洞影响 ISC INN 2.2 及 RedHat Linux 6.0 等版本，CVSS 评分 7.5，危害等级高。厂商已发布补丁修复此漏洞。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0705"],"sources":["avd"],"published":"1999-09-01T04:00:00.000","updated":"2026-06-16T21:48:53.177","remediation":"升级 ISC INN 至 2.3 及以上版本，或安装 RedHat Linux 6.0 对应安全补丁 (RHSA-1999:034)。如无法升级，可移除 inews 的 setuid 权限 (chmod -s /usr/bin/inews) 并限制仅受信用户通过 SSH 提交新闻文章作为临时缓解。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.securityfocus.com/bid/616","https://www.exploit-db.com/exploits/19480","https://github.com/CVEProject/cvelistV5/blob/e927b0fe51353a8ed03f0466aad3c47ffd172da3/cves/1999/0xxx/CVE-1999-0705.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0705","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0705.md","https://github.com/Patrowl/PatrowlHearsData/blob/8c57fab4f71bd6fdcec1202e5361e2a9805c4950/CVE/data/1999/CVE-1999-0705.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-43p9-vj97-wmgv/GHSA-43p9-vj97-wmgv.json","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/I/inn.nasl","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0705.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x1000/616/info.html","https://github.com/debiancn/debian.org/blob/6abc98daa6356b20e410013a6920b3764af682d4/english/security/1999/19990907.data","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_1.list.dict"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0400.toml"},{"ave_id":"AVE-1999-0202","file_name":"1999/AVE-1999-0202.toml","cve_id":"CVE-1999-0670","title":"Eyedog ActiveX 控件缓冲区溢出远程代码执行漏洞","description":"Eyedog ActiveX 控件存在缓冲区溢出漏洞，远程攻击者可通过构造特制网页诱使用户访问，触发缓冲区溢出从而执行任意命令。该漏洞影响了 Internet Explorer 浏览器中集成的 Eyedog ActiveX 控件，攻击者需要诱导用户打开恶意网页或包含恶意内容的电子邮件才能成功利用，危害较大。","severity":"MEDIUM","score":4.0,"aliases":["CVE-1999-0670"],"sources":["avd"],"published":"1999-09-01T04:00:00.000","updated":"2026-06-16T21:48:48.737","remediation":"安装 Microsoft 于 1999 年 8 月发布的安全公告 MS99-032 对应补丁（KB240308），或通过 Windows Update 更新至最新版本的 Internet Explorer。该补丁为 Eyedog ActiveX 控件设置 kill bit，阻止其在 IE 中加载。作为手动缓解措施，可在注册表 HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Internet Explorer\\ActiveX Compatibility 下为 CLSID {A5ECB622-137C-11D2-B34D-00C04FB6F6E1} 创建 Compatibility Flags 值为 0x400 的 DWORD 项，同样可禁用该控件。长远建议升级至现代操作系统及浏览器，因较新版本已不再包含此控件。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://ciac.llnl.gov/ciac/bulletins/j-064.shtml","https://docs.microsoft.com/en-us/security-updates/securitybulletins/1999/ms99-032","https://github.com/CVEProject/cvelistV5/blob/b8581edcbd9fb1606112c43470d0a7cb92a751f8/cves/1999/0xxx/CVE-1999-0670.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0670","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0670.md","https://github.com/Patrowl/PatrowlHearsData/blob/f6ced4f7862026f4207c9708deb4edf129c83fc5/CVE/data/1999/CVE-1999-0670.json","https://github.com/github/advisory-database/blob/25a429f7c036c8b0416069b51c2af695a6b890c2/advisories/unreviewed/2022/04/GHSA-vw7j-x4wv-gff4/GHSA-vw7j-x4wv-gff4.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0670.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x89000/88352/info.html","https://github.com/hungryfoolou/Vulnerability_Mining/blob/3df1d8ed0489ae1228f975ae1f58a690aae53886/craw/cveid_craw/cveid_craw/data/cveid_by_kind/cveid_overflow.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0202.toml"},{"ave_id":"AVE-1999-0196","file_name":"1999/AVE-1999-0196.toml","cve_id":"CVE-1999-0669","title":"Microsoft Internet Explorer 4/5 ActiveX Eyedog 远程代码执行漏洞","description":"Microsoft Internet Explorer 4.0/5.0 中的 Eyedog ActiveX 控件被错误标记为\"对脚本安全\"，远程攻击者可构造恶意网页或 HTML 邮件，诱使用户在 IE 中访问即可直接调用该控件执行任意命令，无需用户交互点击附件。该漏洞因 Bubbleboy 蠕虫的利用而闻名，影响 IE 4.0 及 5.0 版本，CVSS 评分 4.0，属于中危漏洞。微软已发布相关安全公告并提供修复措施。","severity":"MEDIUM","score":4.0,"aliases":["CVE-1999-0669"],"sources":["avd"],"published":"1999-09-01T04:00:00.000","updated":"2026-06-16T21:48:48.617","remediation":"在注册表中为 Eyedog ActiveX 控件设置 killbit（CLSID: {00000000-0000-0000-0000-000000000000}），将 Internet 区域安全级别设为\"高\"并禁用 ActiveX 脚本。升级至 Internet Explorer 6 或更高版本，或迁移至现代浏览器（Edge/Chrome/Firefox）以彻底消除风险。对于仍使用 IE 的遗留系统，通过组策略禁用所有标记为\"对脚本安全\"的未签名 ActiveX 控件。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://ciac.llnl.gov/ciac/bulletins/j-064.shtml","https://www.exploit-db.com/exploits/19487","https://github.com/CVEProject/cvelistV5/blob/928db9679b69032a137f1c2f3374c28367145ef0/cves/1999/0xxx/CVE-1999-0669.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0669","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0669.md","https://github.com/Patrowl/PatrowlHearsData/blob/f6ced4f7862026f4207c9708deb4edf129c83fc5/CVE/data/1999/CVE-1999-0669.json","https://github.com/github/advisory-database/blob/25a429f7c036c8b0416069b51c2af695a6b890c2/advisories/unreviewed/2022/04/GHSA-m9vr-8q37-f2rh/GHSA-m9vr-8q37-f2rh.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0669.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_0.list.dict","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--231fc8ca-ffbe-47b7-994f-ed5754a27cb7.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0196.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0196.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0196.toml"},{"ave_id":"AVE-1999-0503","file_name":"1999/AVE-1999-0503.toml","cve_id":"CVE-1999-0774","title":"Martin Stover Mars NWE 缓冲区溢出漏洞","description":"Mars NetWare Emulation (NWE, mars_nwe) 0.99 版本中存在缓冲区溢出漏洞，本地攻击者可通过向受影响系统提供特制的超长目录名触发该漏洞，导致缓冲区溢出，可能造成拒绝服务或权限提升。该漏洞 CVSS 评分 7.2，危害等级高，建议用户尽快升级至最新版本。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0774"],"sources":["cve"],"published":"1999-08-31T04:00:00.000","updated":"2026-06-16T21:49:01.833","remediation":"升级 mars_nwe 至 0.99 以上版本（如 0.99pl18+ 或最新 CVS 快照），该版本已修复长目录名处理代码中的缓冲区边界检查缺失问题。如无法升级，可在 mars_nwe.conf 中限制 NFS 导出目录路径长度不超过 255 字符，并限制可登录用户范围，同时利用系统审计工具监控 mars_nwe 进程的异常崩溃行为。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://www.securityfocus.com/bid/617","https://www.exploit-db.com/exploits/19485"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0503.toml"},{"ave_id":"AVE-1999-1209","file_name":"1999/AVE-1999-1209.toml","cve_id":"CVE-1999-0911","title":"ProFTPd MKD/CWD 命令缓冲区溢出漏洞","description":"ProFTPd 1.2 pre1 至 pre5 版本、wu-ftpd 及 beroftpd 中存在缓冲区溢出漏洞。远程攻击者可通过向目标 FTP 服务器发送一系列精心构造的 MKD（创建目录）和 CWD（切换目录）命令，创建深层嵌套目录结构，触发缓冲区溢出，进而获得 root 权限。该漏洞影响多个主流 FTP 服务端软件，危害严重，无需认证即可远程利用。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0911"],"sources":["cve"],"published":"1999-08-27T04:00:00.000","updated":"2026-06-16T21:49:18.797","remediation":"升级 ProFTPd 至 1.2.0 RC1 或更高稳定版本（1.2.0pre 系列已停止支持），该漏洞在 1.2.0 RC1 中修复。使用 wu-ftpd 的用户应升级至 2.6.2 或更新版本，或在 inetd 配置中禁用匿名用户 MKD/CWD 目录创建权限作为临时缓解措施。beroftpd 用户建议迁移至已维护的 FTP 服务器软件。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://www.debian.org/security/1999/19990210","http://www.securityfocus.com/bid/612","https://www.exploit-db.com/exploits/19476"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1209.toml"},{"ave_id":"AVE-1999-0866","file_name":"1999/AVE-1999-0866.toml","cve_id":"CVE-1999-1016","title":"Microsoft Internet Explorer HTML Form Control 拒绝服务漏洞","description":"Microsoft Internet Explorer 5 及 FrontPage Express、Outlook Express 5、Eudora 等软件所使用的 HTML Form Control 组件存在拒绝服务漏洞。远程攻击者可通过构造包含超大表单输入字段（如表格单元格中的大量文本框）的恶意网页或 HTML 邮件，诱使用户访问后导致目标系统 CPU 占用率高达 100%，造成拒绝服务。该漏洞利用方式简单，无需认证即可触发，影响范围广泛。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-1016"],"sources":["cve"],"published":"1999-08-27T04:00:00.000","updated":"2026-06-16T21:49:31.717","remediation":"升级至 Internet Explorer 5.01 或更高版本可修复此漏洞。对于仍使用旧版 IE 的环境，建议禁用 Active Scripting 及在 Outlook Express 中阻止 HTML 邮件加载表单控件。现网用户应迁移至受支持的现代浏览器（如 Edge、Chrome）以免受此及其他已知漏洞影响。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://marc.info/?l=ntbugtraq&m=93578772920970&w=2","http://www.securityfocus.com/bid/606","https://www.exploit-db.com/exploits/19471","https://github.com/trickest/cve/blob/34851454a7b07498072de47d56f63daa4a4f524d/1999/CVE-1999-1016.md","https://github.com/CVEProject/cvelistV5/blob/2765cfa5d0fc39151c354509f5ba2b7abfdb61de/cves/1999/1xxx/CVE-1999-1016.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1016","https://github.com/edoardottt/missing-cve-nuclei-templates/blob/36c16d53eb6071e39cfc3cf88e99f1b340ec913b/data/year/1999.txt","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-1016.json","https://github.com/xaitax/SploitScan/blob/e7c7a6140bbd6a60ea622b6124620fbed9d12332/README.md","https://github.com/Patrowl/PatrowlHearsData/blob/37da04e8698400cbfe936368ce494fc186159eb4/CVE/data/1999/CVE-1999-1016.json","https://github.com/github/advisory-database/blob/1b2e09705f0816776a0a8a0cd6fc1208d25f09b2/advisories/unreviewed/2022/04/GHSA-33jr-59q9-j8vq/GHSA-33jr-59q9-j8vq.json","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/nessus/nessus-plugins/scripts/smb_nt_ms02-005.nasl","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-1016.md"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0866.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0866.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0866.toml"},{"ave_id":"AVE-1999-0736","file_name":"1999/AVE-1999-0736.toml","cve_id":"CVE-1999-0939","title":"Debian Linux epic/epic4 IRC客户端 拒绝服务漏洞","description":"Debian Linux 2.1 和 2.2 版本中附带的 epic/epic4 IRC 客户端存在拒绝服务漏洞。远程攻击者可通过向客户端发送特制的超长字符串，触发客户端崩溃或无法响应，导致正常的 IRC 通信服务中断。该漏洞无需认证即可利用，攻击复杂度低，虽未造成数据泄露或代码执行，但严重影响服务的可用性。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0939"],"sources":["cve"],"published":"1999-08-26T04:00:00.000","updated":"2026-06-16T21:49:22.163","remediation":"升级 epic4 到 2.8 以上版本（Debian 2.1/2.2 已 EOL，建议升级到 Debian 3.0 Woody 或更新版本，其中包含已修复的 epic4 包）；也可改用 irssi、weechat 等替代 IRC 客户端，或在 IRC 服务器端限制单条消息最大长度作为临时缓解措施。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://www.securityfocus.com/bid/605"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0736.toml"}]