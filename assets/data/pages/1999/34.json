ub/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-qxqf-rx8x-jgrw/GHSA-qxqf-rx8x-jgrw.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1241.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x88000/87843/info.html","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153400_153500.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000628.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1808.toml"},{"ave_id":"AVE-1999-1005","file_name":"1999/AVE-1999-1005.toml","cve_id":"CVE-1999-1195","title":"NAI VirusScan NT 升级验证缺陷漏洞","description":"NAI VirusScan NT 4.0.2 在进行 FTP 在线更新病毒定义文件 scan.dat 时，由于未正确验证文件是否完整写入磁盘，即在更新流程完成后返回成功状态，导致即使病毒库文件实际未被正确修改，软件仍向管理员报告更新成功。攻击者可通过中间人攻击或控制更新服务器向目标推送无效或过时的病毒定义，使系统长期处于未受保护状态，严重影响主机安全性。","severity":"MEDIUM","score":5.1,"aliases":["CVE-1999-1195"],"sources":["cve"],"published":"1999-05-05T04:00:00.000","updated":"2026-06-16T21:49:55.253","remediation":"升级至 Network Associates VirusScan NT 4.0.3a 或更高版本。如无法升级，可临时关闭 VirusScan 引擎后等待数秒使系统释放 scan.dat 文件句柄，再手动将最新病毒定义文件复制到 VirusScan NT 安装目录覆盖旧文件。完成操作后应通过反病毒控制台检查「Created On」日期是否已更新，以确认定义文件确实被正确替换。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://marc.info/?l=bugtraq&m=92588169005196&w=2","http://marc.info/?l=ntbugtraq&m=92587579032534&w=2","http://www.securityfocus.com/bid/169","https://github.com/CVEProject/cvelistV5/blob/b8581edcbd9fb1606112c43470d0a7cb92a751f8/cves/1999/1xxx/CVE-1999-1195.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1195","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-1195.md","https://github.com/Patrowl/PatrowlHearsData/blob/0fec8c5c64ee33c93da01ddd0b28bf8f9f743a61/CVE/data/1999/CVE-1999-1195.json","https://github.com/github/advisory-database/blob/5783344e7c4adc3f449b78e346f760d75b095a9c/advisories/unreviewed/2022/04/GHSA-pm4g-gv9m-qf7v/GHSA-pm4g-gv9m-qf7v.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x1000/169/info.html","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-1195.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153400_153500.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv","https://github.com/nomi-sec/CVE-Easy-List/blob/151244184a2592693ea242321c22fa26af96c58c/1999.tsv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1005.toml"},{"ave_id":"AVE-1999-0861","file_name":"1999/AVE-1999-0861.toml","cve_id":"CVE-1999-1012","title":"Lotus Domino SMTP 拒绝服务漏洞","description":"Lotus Domino 4.6.1 的 SMTP 组件在处理超长字符串时存在未正确边界检查的漏洞，远程攻击者无需身份认证即可向目标服务器的 SMTP 端口发送特制超长字符串，触发缓冲区溢出或异常处理错误，导致邮件服务进程崩溃，造成拒绝服务。该漏洞影响 AS/400 平台的 Lotus Domino 4.6.1 版本并可能波及其他操作系统。","severity":"MEDIUM","score":5,"aliases":["CVE-1999-1012"],"sources":["cve"],"published":"1999-05-04T04:00:00.000","updated":"2026-06-16T21:49:31.237","remediation":"升级 Lotus Domino 至 4.6.2 或更高版本，该版本在 SMTP 服务中增加了输入长度校验，防止超长字符串导致缓冲区崩溃。如使用更现代的版本，建议迁移至 HCL Domino 12.x 或 14.x 长期支持版。同时可在 SMTP 网关或防火墙层面配置最大行长度限制（如 RFC 2821 建议的 998 字符），作为额外深度防御措施。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://www.securityfocus.com/archive/1/13527","http://www.securityfocus.com/bid/173","https://github.com/CVEProject/cvelistV5/blob/dc83b9e6d88de194a14e3020b4e71ac42054e609/cves/1999/1xxx/CVE-1999-1012.json","https://github.com/Patrowl/PatrowlHearsData/blob/04a84e78299e2aeaab4d2594fc26f920778c7b06/CVE/data/1999/CVE-1999-1012.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1012","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-1012.json","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-1012.json","https://github.com/fkie-cad/nvd-json-data-feeds/blob/97009c469920f4d8991128f84d19644c3badca15/CVE-1999/CVE-1999-10xx/CVE-1999-1012.json","https://github.com/opencve/opencve-kb/blob/dcc6735c9c3e50e93de820fa1ac9c54ecf6b2577/1999/CVE-1999-1012.json","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-1012.json","https://github.com/CVEProject/cvelist-dev/blob/5b8fbb570438e8094550205589cc6f1d122acc94/1999/1xxx/CVE-1999-1012.json","https://github.com/CyberSecAI/cve_info/blob/03b7e36424574a3a9ba5fd13480a326b666a1046/1999/1xxx/CVE-1999-1012.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0861.toml"},{"ave_id":"AVE-1999-0938","file_name":"1999/AVE-1999-0938.toml","cve_id":"CVE-1999-1097","title":"Microsoft NetMeeting 剪贴板信息泄露漏洞","description":"Microsoft NetMeeting 2.1 存在剪贴板信息泄露漏洞。当聊天框为空时，攻击者可通过在聊天框中发送 CTRL-C 快捷键操作，触发对另一客户端剪贴板内容的读取，导致用户剪贴板中的敏感信息（如密码、文本内容）被未授权获取。该漏洞影响 NetMeeting 2.1 版本，攻击者需与目标处于同一会话中方可利用。","severity":"MEDIUM","score":6.4,"aliases":["CVE-1999-1097"],"sources":["cve"],"published":"1999-05-04T04:00:00.000","updated":"2026-06-16T21:49:42.933","remediation":"建议立即卸载或禁用 Microsoft NetMeeting 2.1（通过控制面板 → 添加/删除程序 → 删除 NetMeeting 组件；Windows 98 可在安装光盘中删除通讯组件），避免在会议中使用聊天功能时泄露剪贴板内容。对于仍依赖远程协作功能的用户，应迁移至受支持的替代方案（如 Microsoft Teams、Skype for Business）或使用 PGP 加密剪贴板内容作为临时缓解措施。后续的 Windows 版本已移除 NetMeeting，不再受此漏洞影响。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://marc.info/?l=bugtraq&m=92586457816446&w=2","https://exchange.xforce.ibmcloud.com/vulnerabilities/2187","https://github.com/CVEProject/cvelistV5/blob/269e5b2b6ea60fdb4a03411be38d3e381b26e4c4/cves/1999/1xxx/CVE-1999-1097.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-1097","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-1097.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-1097.md","https://github.com/Patrowl/PatrowlHearsData/blob/2f876a2c24d5ccd5bbd081f09e801e580536456a/CVE/data/1999/CVE-1999-1097.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-mqf5-wgx4-qfwq/GHSA-mqf5-wgx4-qfwq.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x89000/88089/info.html","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-1097.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000625.txt","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153400_153500.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0938.toml"},{"ave_id":"AVE-1999-0007","file_name":"1999/AVE-1999-0007.toml","cve_id":"CVE-1999-0194","title":"UNIX in.comsat 拒绝服务漏洞","description":"in.comsat（Unix 邮件通知服务）存在拒绝服务漏洞，远程攻击者无需认证即可向目标主机的 comsat 服务（UDP 512 端口）发送特制的伪造消息数据包，触发服务生成大量告警通知并消耗系统资源，导致目标主机拒绝服务。受影响的系统包括各类 Unix 衍生系统，CVSS 评分 5.0，危害等级中等问题。厂商已发布安全补丁修复此漏洞。","severity":"MEDIUM","score":5,"aliases":["CVE-1999-0194"],"sources":["epss"],"published":"1999-05-01T04:00:00.000","updated":"2026-06-16T21:47:53.103","remediation":"在 /etc/inetd.conf 中注释或删除 comsat 行并重启 inetd 服务以禁用该服务；或在防火墙上封禁外部对 UDP 512 端口的访问。如需保留功能，请升级操作系统至厂商已发布修复补丁的最新版本。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["https://www.cve.org/CVERecord?id=CVE-1999-0194"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0007.toml"},{"ave_id":"AVE-1999-0159","file_name":"1999/AVE-1999-0159.toml","cve_id":"CVE-1999-0487","title":"Microsoft Internet Explorer DHTML Edit ActiveX 任意文件读取漏洞","description":"Internet Explorer 中的 DHTML Edit ActiveX 控件存在任意文件读取漏洞。远程攻击者可通过构造恶意网页，诱使用户在 IE 浏览器中访问，利用该 ActiveX 控件的跨帧访问特性读取目标系统上的任意文件内容。该漏洞影响 Internet Explorer 4 和 5 版本，攻击者无需身份认证即可实施攻击，危害用户隐私安全。","severity":"LOW","score":2.6,"aliases":["CVE-1999-0487"],"sources":["epss"],"published":"1999-05-01T04:00:00.000","updated":"2026-06-16T21:48:30.130","remediation":"升级到 Internet Explorer 6 或更高版本，该漏洞已在 IE 5.5 SP2 及后续版本中修复。如无法升级，可通过注册表设置 Kill Bit 禁用 DHTML Edit ActiveX 控件（CLSID: {2D360201-FFF5-11D1-8D03-00A0C959BC0A}），在 HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Internet Explorer\\ActiveX Compatibility 下创建对应 CLSID 项并将 Compatibility Flags 设为 0x400。建议迁移至现代浏览器（如 Edge/Chrome/Firefox）以彻底规避风险。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["https://docs.microsoft.com/en-us/security-updates/securitybulletins/1999/ms99-011","https://www.exploit-db.com/exploits/19094","https://github.com/CVEProject/cvelistV5/blob/58a0ea900decdd7e971b95fcaa99234de5a5df5e/cves/1999/0xxx/CVE-1999-0487.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0487","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0487.md","https://github.com/Patrowl/PatrowlHearsData/blob/dabf5b9888e8885cf125c5729901a7ad84d00092/CVE/data/1999/CVE-1999-0487.json","https://github.com/github/advisory-database/blob/18de81c56daca1c9e33223f0b95bdb8312a1ca75/advisories/unreviewed/2022/04/GHSA-79cg-j8cc-gwm8/GHSA-79cg-j8cc-gwm8.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0487.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/bibliotxt/bibliotxt/blob/07bb3ac8e74e6f78514faabae1ce10b662cf48a1/zines/trenchcoat-diaries/tcpaper2.txt","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_5.list.dict","https://github.com/akabe1/windows_exploit_dowser/blob/11b24e36173cd382721db28581e575faf687d06b/cve_from_exploitdb_website.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0159.toml"],"repo_exp_urls":[],"has_poc":true,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0159.toml"},{"ave_id":"AVE-1999-0480","file_name":"1999/AVE-1999-0480.toml","cve_id":"CVE-1999-0763","title":"NetBSD 多宿主主机 ARP 缓存投毒漏洞","description":"NetBSD 在多宿主主机（连接多个网络的系统）上存在 ARP 缓存投毒漏洞。当系统配置了多个网络接口并连接到不同子网时，从一个网络接口接收到的 ARP 数据包能够修改另一个网络接口上的 ARP 缓存条目，导致跨网络的 ARP 欺骗攻击。远程攻击者可通过向目标系统发送伪造的 ARP 响应包，将流量重定向至攻击者控制的地址，实现中间人攻击或拒绝服务。该漏洞影响多宿主配置下的 NetBSD 系统，CVSS 评分 6.4，危害等级中危。","severity":"MEDIUM","score":6.4,"aliases":["CVE-1999-0763"],"sources":["avd"],"published":"1999-05-01T04:00:00.000","updated":"2026-06-16T21:49:00.467","remediation":"升级 NetBSD 至 1.4.1 及以上版本，该版本修复了多宿主主机上 ARP 表项跨网修改的问题。如无法升级，可通过 sysctl -w net.inet.arp.allow_all=0 禁用跨接口 ARP 学习，或在各网络接口上启用 ARP 过滤（ifconfig xx0 arpfilter），同时为关键网关配置静态 ARP 条目（arp -s）防止 ARP 欺骗攻击。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.osvdb.org/6540"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0480.toml"},{"ave_id":"AVE-1999-0481","file_name":"1999/AVE-1999-0481.toml","cve_id":"CVE-1999-0764","title":"NetBSD ARP 静态条目覆盖漏洞","description":"NetBSD 内核 ARP 协议实现存在设计缺陷，远程攻击者可通过向目标系统发送特制的 ARP 数据包覆盖静态 ARP 缓存条目。该漏洞源于 ARP 协议未对静态条目进行写保护，攻击者可在同一广播域内伪造 IP-MAC 地址映射关系，导致目标系统的网络流量被重定向至攻击者控制的设备，进而实现中间人攻击、数据窃听或会话劫持。该漏洞影响 NetBSD 操作系统，攻击者无需认证即可利用，CVSS 评分 6.4，危害等级中危。","severity":"MEDIUM","score":6.4,"aliases":["CVE-1999-0764"],"sources":["avd"],"published":"1999-05-01T04:00:00.000","updated":"2026-06-16T21:49:00.597","remediation":"升级到 NetBSD 1.4 或更高版本（1.4 及 1.4_BETA 在 1999-05-05 之后已修复），或从 NetBSD FTP 服务器获取并应用 19990505-arp 补丁。如无法升级，可在网卡层面限制 ARP 学习范围，避免来自非本网段的 ARP 包覆盖静态条目。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.osvdb.org/6539"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0481.toml"},{"ave_id":"AVE-1999-0570","file_name":"1999/AVE-1999-0570.toml","cve_id":"CVE-1999-0807","title":"Netscape Directory Server 安装过程敏感信息泄露漏洞","description":"Netscape Directory Server 在安装过程中存在敏感信息泄露漏洞。安装程序将管理员密码、配置凭证等敏感数据以明文方式保存在本地文件中，且未设置充分的访问权限控制。本地攻击者可通过读取这些文件获取敏感信息，进而可能提升权限或获取目录服务器的管理访问权限。该漏洞影响早期版本的 Netscape Directory Server，CVSS 评分 7.2，危害等级高。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0807"],"sources":["cve"],"published":"1999-05-01T04:00:00.000","updated":"2026-06-16T21:49:05.883","remediation":"由于 Netscape Directory Server 已停止维护，建议迁移至 389 Directory Server、Red Hat Directory Server 或 OpenLDAP 等现代替代品。迁移前应立即检查并收紧安装目录文件权限（如 /usr/netscape/server4/ 等），移除 world-readable 权限并清理安装过程中遗留的 .inf/.log/响应文件等含明文凭据的临时文件。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0807"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0570.toml"}]