pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-2007/CVE-2007-2449","https://github.com/Tabll/gemnasium-db/blob/c78813392a686be9ed8245543249abb80331d014/maven/org.apache.tomcat/tomcat/CVE-2007-2449.yml","https://github.com/nottrobin/ubuntu-cve-tracker/blob/36e411296b5707284049ec2e0db8d2622feca498/retired/CVE-2007-2449","https://github.com/Patrowl/PatrowlHearsData/blob/e64e866f5c799abe7f39eba36818200f3831f1cb/CVE/data/2007/CVE-2007-2449.json","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/S/suse9_12116.nasl","https://github.com/GB28181/GB28181-Simulation-Tool/blob/c1cec6603bc905b84fefcd3d24fea51143a33888/webapps/docs/changelog.html"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2007/AVE-2007-0002.toml"},{"ave_id":"AVE-2007-0001","file_name":"2007/AVE-2007-0001.toml","cve_id":"CVE-2007-0885","title":"Atlassian JIRA 跨站脚本漏洞","description":"Atlassian JIRA 3.7.3 的 Rainbow.Zen 扩展中存在跨站脚本（XSS）安全漏洞，该漏洞位于 jira/secure/BrowseProject.jspa 页面中。远程攻击者可通过向 id 参数注入恶意 Web 脚本或 HTML 代码实施攻击，当管理员或其他用户访问被篡改的页面时，恶意脚本将在浏览器中执行，导致敏感信息泄露（如 Session Cookie 窃取）或页面内容篡改。攻击无需身份认证，仅需诱使用户访问特制 URL 即可触发。Atlassian 已发布修复版本，建议升级至 3.7.4 或更高版本。","severity":"MEDIUM","score":6.8,"aliases":["CVE-2007-0885"],"sources":["nuclei"],"published":"2007-02-12T20:28:00.000","updated":"2026-06-16T22:36:28.833","remediation":"立即从 JIRA 服务器中移除或禁用 Rainbow.Zen 扩展，以消除通过 `id` 参数注入脚本的攻击面。如仍需类似功能，替换为官方受支持的 JIRA 插件。在 Web 应用防火墙（WAF）层面添加规则，对 `/jira/secure/BrowseProject.jspa` 的 `id` 参数进行输入过滤，拦截 `<script>`、`onerror=` 等 XSS 载荷。如果无法移除该扩展，修改源码对 `id` 参数做严格的 HTML 实体编码输出。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://osvdb.org/33683","http://www.securityfocus.com/archive/1/459590/100/0/threaded","http://www.securityfocus.com/bid/22503","https://exchange.xforce.ibmcloud.com/vulnerabilities/32418","https://www.exploit-db.com/exploits/29576","h