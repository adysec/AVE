[{"ave_id":"AVE-1999-0082","file_name":"1999/AVE-1999-0082.toml","cve_id":"CVE-1999-0026","title":"SGI IRIX pset 命令缓冲区溢出本地权限提升漏洞","description":"SGI IRIX 6.3 系统中的 pset 命令存在缓冲区溢出漏洞，本地攻击者可通过向该命令提交特制输入触发缓冲区溢出，从而获取 root 权限。该漏洞需要攻击者拥有本地系统访问权限，利用门槛较低，成功利用后可完全控制受影响系统。CVSS 评分 4.6，危害等级中危。","severity":"MEDIUM","score":4.6,"aliases":["CVE-1999-0026"],"sources":["exploitdb"],"published":"1997-07-16T04:00:00.000","updated":"2026-06-16T21:47:22.857","remediation":"立即升级到 IRIX 6.5 及以上版本（该系列已修复此漏洞）；如无法升级，可移除 /usr/sbin/pset 的 setuid 位作为临时缓解措施，执行 chmod u-s /usr/sbin/pset 禁止普通用户提权；严格限制本地用户的交互式 shell 访问权限，仅允许受信用户登录。由于 SGI IRIX 已于 2006 年终止支持且厂商已破产，建议将关键业务系统迁移到仍受支持的操作系统平台。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0026","https://www.exploit-db.com/exploits/19347","https://github.com/CVEProject/cvelistV5/blob/dc83b9e6d88de194a14e3020b4e71ac42054e609/cves/1999/0xxx/CVE-1999-0026.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0026","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0026.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0026.md","https://github.com/Patrowl/PatrowlHearsData/blob/04a84e78299e2aeaab4d2594fc26f920778c7b06/CVE/data/1999/CVE-1999-0026.json","https://github.com/github/advisory-database/blob/1b2e09705f0816776a0a8a0cd6fc1208d25f09b2/advisories/unreviewed/2022/04/GHSA-jgjp-7pvm-43jq/GHSA-jgjp-7pvm-43jq.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0026.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_154400_154500.json","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--f13688fd-9dfb-4099-8671-861cf60a21e1.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0082.toml"},{"ave_id":"AVE-1999-0080","file_name":"1999/AVE-1999-0080.toml","cve_id":"CVE-1999-0025","title":"SGI IRIX df 本地权限提升漏洞","description":"SGI IRIX 6.3 系统中的 df 命令存在缓冲区溢出漏洞，本地攻击者可通过向 df 命令传入特制的超长参数触发缓冲区溢出，覆盖返回地址后执行任意代码，从而获取 root 权限。该漏洞影响 SGI IRIX 6.3 版本，利用条件是攻击者需拥有本地系统访问权限，CVSS 评分 7.2，危害等级高。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0025"],"sources":["exploitdb"],"published":"1997-07-16T04:00:00.000","updated":"2026-06-16T21:47:22.730","remediation":"安装 SGI 提供的 IRIX 安全补丁 19970505-02-PX，升级到已修复的 IRIX 版本。如无法立即打补丁，可执行 `chmod u-s /usr/sbin/df` 移除 df 的 setuid 权限作为临时缓解措施，或使用 AUSCERT 提供的 overflow_wrapper 工具限制命令行参数长度（建议 MAXARGLEN=32）并记录异常调用。由于 SGI IRIX 已停止维护，建议迁移至受支持的现代操作系统。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://www.cert.org/advisories/CA-1997-21.html","http://www.kb.cert.org/vuls/id/20851","http://www.securityfocus.com/bid/346","https://exchange.xforce.ibmcloud.com/vulnerabilities/440","https://www.exploit-db.com/exploits/19274","https://github.com/CVEProject/cvelistV5/blob/dc83b9e6d88de194a14e3020b4e71ac42054e609/cves/1999/0xxx/CVE-1999-0025.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0025","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0025.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0025.md","https://github.com/Patrowl/PatrowlHearsData/blob/04a84e78299e2aeaab4d2594fc26f920778c7b06/CVE/data/1999/CVE-1999-0025.json","https://github.com/github/advisory-database/blob/1b2e09705f0816776a0a8a0cd6fc1208d25f09b2/advisories/unreviewed/2022/04/GHSA-5wr5-299q-993r/GHSA-5wr5-299q-993r.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/kabaneridev/pt-notes/blob/05dba1a6e7d619d374878b2366ccc58b8e4a5ef2/CPTS-PREP/remote-management/linux-remote-protocols.md","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_154400_154500.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0080.toml"},{"ave_id":"AVE-1999-0299","file_name":"1999/AVE-1999-0299.toml","cve_id":"CVE-1999-0146","title":"NCSA httpd campas CGI 远程命令执行漏洞","description":"NCSA httpd 服务器自带的 campas CGI 程序未对用户输入进行充分过滤，远程攻击者可通过在查询字符串中插入编码的回车符（CR）注入任意系统命令，进而读取服务器上的敏感文件（如密码文件）或执行其他恶意操作。该漏洞影响多个版本的 NCSA web 服务器，无需身份认证即可远程利用，危害严重。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0146"],"sources":["exploitdb"],"published":"1997-07-15T04:00:00.000","updated":"2026-06-16T21:47:41.800","remediation":"删除 cgi-bin 目录下的 campas 示例脚本，或确保 NCSA httpd 已升级至不受影响的版本。建议迁移至长期维护的 Web 服务器（如 Apache HTTP Server），并移除所有示例 CGI 脚本以避免类似安全问题。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://www.securityfocus.com/bid/1975","https://exchange.xforce.ibmcloud.com/vulnerabilities/298","https://www.exploit-db.com/exploits/20423","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0146.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0146","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0146.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0146.md","https://github.com/Patrowl/PatrowlHearsData/blob/2ed73314b4d66512efbb22e0644e615bc00001f2/CVE/data/1999/CVE-1999-0146.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-c22c-6v4p-99rm/GHSA-c22c-6v4p-99rm.json","https://github.com/NetBSD/pkgsrc-wip/blob/9e4b769742ed57395763142c26029c2f9910f15b/sara/PLIST","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/snort/drop-rules/sid-msg.map","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/Freem93/grammar_nasl_v2/blob/63834ebb8cd6e97050e155291c7500ad53bb20c6/plugins/campas.nasl"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0299.toml"},{"ave_id":"AVE-1999-0150","file_name":"1999/AVE-1999-0150.toml","cve_id":"CVE-1999-0059","title":"SGI IRIX fam 服务信息泄露漏洞","description":"SGI IRIX 操作系统的 fam（File Alteration Monitor）服务存在信息泄露漏洞，攻击者无需身份认证即可通过远程网络请求获取目标服务器上的所有文件列表，导致系统敏感文件路径与结构暴露。该漏洞影响 IRIX 多个版本，CVSS 评分 7.3，危害等级高危，攻击者可借此进行信息收集，为后续针对性攻击创造条件。","severity":"HIGH","score":7.3,"aliases":["CVE-1999-0059"],"sources":["epss"],"published":"1997-07-14T04:00:00.000","updated":"2026-06-16T21:47:28.837","remediation":"立即安装 SGI 1997 年发布的安全补丁（SGI 安全公告 19970701-01-P），或升级 IRIX 至不受影响的更高版本。若无法打补丁，在 `/etc/inetd.conf` 中注释 fam 服务行并重启 inetd，或执行 `/etc/init.d/fam stop` 停止 fam 服务，再通过 `chkconfig fam off` 禁止开机自启。同时建议在边界防火墙上阻断对 fam 默认端口（TCP 9751）的外部访问。由于 SGI IRIX 已于 2006 年停止技术支持，建议将业务迁移至仍在安全维护期的操作系统。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://www.osvdb.org/164","http://www.securityfocus.com/bid/353","https://exchange.xforce.ibmcloud.com/vulnerabilities/325"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0150.toml"},{"ave_id":"AVE-1999-0351","file_name":"1999/AVE-1999-0351.toml","cve_id":"CVE-1999-0176","title":"WEBgais 1.0 远程命令执行漏洞","description":"WEBgais 1.0 存在远程命令执行漏洞，远程攻击者无需身份认证即可通过向服务器发送特制的 HTTP 请求，利用程序未对用户输入进行有效过滤的缺陷，在目标系统上执行任意命令，从而完全控制受影响的服务器。该漏洞影响 WEBgais 1.0 版本，CVSS 评分 7.5，危害等级高。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0176"],"sources":["exploitdb"],"published":"1997-07-10T04:00:00.000","updated":"2026-06-16T21:47:45.797","remediation":"立即从 Web 服务器 cgi-bin 目录中删除 webgais 脚本或将其移除，同时检查服务器上是否存在其他无用 CGI 程序并一并清理。如业务必须使用该功能，应迁移至有安全维护的替代方案（如现代 Web 框架实现的文件搜索功能），并在 Web 服务器（Apache/Nginx）层面限制 CGI 执行权限。临时缓解措施可配置 Web 服务器 ACL 仅允许可信 IP 访问 CGI 目录。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0176","https://www.exploit-db.com/exploits/20463","https://github.com/CVEProject/cvelistV5/blob/269e5b2b6ea60fdb4a03411be38d3e381b26e4c4/cves/1999/0xxx/CVE-1999-0176.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0176","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0176.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0176.md","https://github.com/Patrowl/PatrowlHearsData/blob/2f876a2c24d5ccd5bbd081f09e801e580536456a/CVE/data/1999/CVE-1999-0176.json","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/nessus/nessus-plugins/scripts/webgais.nasl","https://github.com/NetBSD/pkgsrc-wip/blob/9e4b769742ed57395763142c26029c2f9910f15b/sara/PLIST","https://github.com/fkie-cad/nvd-json-data-feeds/blob/1b69cf2313f68e29acceed58f52f6109cd37bb04/CVE-1999/CVE-1999-01xx/CVE-1999-0176.json","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/slacker247/GPDA/blob/fa9006d0877a691f1ddffe88799c844a3e8a669a/Sodi/Run/IDSrules/rule.840"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0351.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0351.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0351.toml"},{"ave_id":"AVE-1999-0378","file_name":"1999/AVE-1999-0378.toml","cve_id":"CVE-1999-0196","title":"WEBgais websendmail 远程命令执行漏洞","description":"Webgais 1.0 的 websendmail 组件在处理 receiver 参数（$VAR_receiver 变量）时存在输入验证缺陷，远程攻击者可通过向目标服务发送特制 HTTP 请求注入系统命令，从而实现任意文件读取与远程命令执行。该漏洞无需身份认证，攻击条件低，CVSS 评分 5.0，影响运行 Webgais 1.0 的服务器系统。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0196"],"sources":["exploitdb"],"published":"1997-07-08T04:00:00.000","updated":"2026-06-16T21:47:53.363","remediation":"立即删除 Web 服务器 cgi-bin/ 目录下的 websendmail 和 webgais 脚本，或通过 Apache 的 Directory 指令拒绝访问该 CGI 路径。WEBgais 1.0 已不再维护，无法通过升级修复。如必须使用，须在接收 $VAR_receiver 参数后过滤 shell 元字符（;、`、|、$ 等），并改用 Perl Mail::Sendmail 模块替代 open() 管道方式调用 sendmail。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://www.osvdb.org/237","http://www.securityfocus.com/bid/2077","https://www.exploit-db.com/exploits/20483","https://github.com/CVEProject/cvelistV5/blob/92d64b4c9b3c5a0ce1fd1e5f8c017b9772e0139b/cves/1999/0xxx/CVE-1999-0196.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0196","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0196.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0196.md","https://github.com/Patrowl/PatrowlHearsData/blob/db45dbc75ff0264d63b603291e4a83d7361bd7ba/CVE/data/1999/CVE-1999-0196.json","https://github.com/rhuitl/uClinux/blob/0486e80a025dccbe4a2213715a2ab8a5063ea86b/user/nessus/nessus-plugins/scripts/websendmail.nasl","https://github.com/github/advisory-database/blob/79c2cf4630fcc44f2632735de08432a07cfaf204/advisories/unreviewed/2022/04/GHSA-35m5-388q-jrx8/GHSA-35m5-388q-jrx8.json","https://github.com/slacker247/GPDA/blob/fa9006d0877a691f1ddffe88799c844a3e8a669a/Sodi/Run/IDSrules/rule.820","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0196.json","https://github.com/jdkoftinoff/mb-linux-msli/blob/8adb103e34af9ff1d8d122e9ee2a1808836f0a14/uClinux-dist/user/snort/drop-rules/sid-msg.map"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0378.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0378.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0378.toml"},{"ave_id":"AVE-1999-0093","file_name":"1999/AVE-1999-0093.toml","cve_id":"CVE-1999-0031","title":"Microsoft Internet Explorer JavaScript 信息泄露漏洞","description":"JavaScript 同源策略绕过漏洞存在于 Internet Explorer 3.x/4.x 及 Netscape 2.x/3.x/4.x 等早期浏览器中。远程攻击者可通过在恶意网页中植入特制 JavaScript 代码，监控用户跨站点的网页浏览活动，窃取用户的浏览历史与访问行为等敏感信息。该漏洞由贝尔实验室发现并报告，CVSS 评分 2.6，危害等级低，但由于浏览器版本较早且已停止支持，实际利用价值有限。","severity":"LOW","score":2.6,"aliases":["CVE-1999-0031"],"sources":["epss"],"published":"1997-07-08T04:00:00.000","updated":"2026-06-16T21:47:23.630","remediation":"立即停止使用 Internet Explorer 3.x/4.x 及 Netscape 2.x/3.x/4.x，升级到受支持的主流浏览器（如 Chrome、Edge、Firefox 最新版本），这些浏览器已不存在该跨域脚本监控漏洞。对于无法升级浏览器的老旧系统，建议在终端安装脚本拦截插件（如 NoScript）并禁用 JavaScript 执行作为临时缓解。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://www.codetalker.com/advisories/vendor/hp/hpsbux9707-065.html"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0093.toml"},{"ave_id":"AVE-1999-0930","file_name":"1999/AVE-1999-0930.toml","cve_id":"CVE-1999-0628","title":"GNU RWHO/rwhod 服务信息泄露漏洞","description":"rwho/rwhod 服务运行于 Unix/Linux 系统，基于 UDP 协议广播用户登录状态、系统运行时间等信息。该服务默认不进行身份认证，攻击者可在同一广播域内监听并收集目标系统的用户名、登录时长、终端类型等敏感信息，为后续针对性攻击提供情报支撑。此漏洞源于服务设计缺陷，影响所有启用了 rwho/rwhod 的类 Unix 系统，CVSS 评分 5.0，危害等级中危。建议在无需使用该服务的环境中禁用或通过防火墙限制 UDP 端口 513 的访问。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0628"],"sources":["avd"],"published":"1997-07-01T04:00:00.000","updated":"2026-06-16T21:48:45.330","remediation":"建议立即停止并禁用 rwhod 服务：`systemctl stop rwhod && systemctl disable rwhod`（Systemd 系统）或 `service rwhod stop && chkconfig rwhod off`（SysV 系统）。如业务确实需要 rwhod 服务，应在防火墙层面限制 UDP 端口 513 仅允许受信任网段访问，并配置 hosts.{allow,deny} 白名单控制连接来源。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0628","https://github.com/CVEProject/cvelistV5/blob/ab669d9fb37e52ed0619cb2b8265d34528fbe875/cves/1999/0xxx/CVE-1999-0628.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0628","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0628.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0628.md","https://github.com/Patrowl/PatrowlHearsData/blob/2f876a2c24d5ccd5bbd081f09e801e580536456a/CVE/data/1999/CVE-1999-0628.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-5fhh-rhpf-rxrp/GHSA-5fhh-rhpf-rxrp.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89822577def7df5351966d2/nvdcve/CVE-1999-0628.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_154400_154500.json","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--a257f052-36b0-4db1-9cd3-c865c04d3601.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0930.toml"},{"ave_id":"AVE-1999-0807","file_name":"1999/AVE-1999-0807.toml","cve_id":"CVE-1999-0541","title":"Web 资源访问密码可猜测漏洞","description":"该漏洞是由于用于保护 WWW URL 访问的认证密码强度不足或使用常见弱口令，导致远程攻击者可通过字典猜解或暴力枚举方式获取有效密码，从而在未授权的情况下访问受保护的 Web 页面或资源。此类问题常见于 HTTP Basic Authentication 及 URL 嵌入式密码场景，攻击门槛低且影响范围广泛，CVSS 评分 7.5，危害等级高危。修复措施包括使用高强度复杂密码、启用多因素认证及避免在 URL 中明文传递凭据。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0541"],"sources":["avd"],"published":"1997-07-01T04:00:00.000","updated":"2026-06-16T21:48:36.393","remediation":"对所有 Web 认证页面强制使用长度 ≥12 位、包含大小写字母数字及特殊字符的强密码，并实施账户锁定策略（连续 5 次失败锁定 30 分钟），同时启用多因素认证（MFA）并定期使用密码审计工具检查弱口令。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://www.cve.org/CVERecord?id=CVE-1999-0541"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0807.toml"},{"ave_id":"AVE-1999-0799","file_name":"1999/AVE-1999-0799.toml","cve_id":"CVE-1999-0533","title":"DNS服务器反查询漏洞","description":"DNS 服务器存在反查询（Inverse Query）信息泄露漏洞，远程攻击者可通过向目标 DNS 服务器发送特制的反查询请求，绕过正常访问控制获取内网主机名与 IP 地址对应关系等网络拓扑敏感信息。攻击者利用泄漏的信息可进一步实施针对性渗透攻击，扩大攻击面。该漏洞影响多种未禁用反查询功能的 DNS 服务器软件，CVSS 评分 7.5，危害等级高。建议禁用反查询功能或升级至不受影响的版本。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0533"],"sources":["avd"],"published":"1997-07-01T04:00:00.000","updated":"2026-06-16T21:48:35.763","remediation":"升级 DNS 服务器软件至最新受支持版本（如 BIND 升级至 9.16.x 或更高版本），并在 named.conf 中使用 allow-query 指令限制反向查询区域仅允许内部可信网络访问；同时设置 allow-recursion 为内部网络地址范围，禁止外部客户端发起递归查询。如使用 Microsoft DNS，升级至受支持的 Windows Server 版本，在 DNS 控制台中限制区域传输与递归查询范围。此外在防火墙上限制 TCP/UDP 53 端口的来源 IP，仅允许已知 DNS 客户端和下游 DNS 服务器访问。临时缓解措施可关闭递归查询功能。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0533"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0799.toml"},{"ave_id":"AVE-1999-0798","file_name":"1999/AVE-1999-0798.toml","cve_id":"CVE-1999-0532","title":"通用DNS服务区域传输漏洞","description":"DNS 区域传输（Zone Transfer）功能存在访问控制缺陷，未对请求来源进行身份验证和授权检查，远程攻击者可通过向目标 DNS 服务器发送 AXFR 请求获取该服务器管理的全部域名解析记录。攻击仅需目标 DNS 服务器未限制区域传输来源地址。成功利用后可泄露内部网络主机名、IP 地址映射等敏感信息，暴露网络拓扑结构，为后续渗透攻击提供信息支撑。该漏洞广泛影响未正确配置访问控制列表的 DNS 服务器（如 BIND、Microsoft DNS 等）。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0532"],"sources":["avd"],"published":"1997-07-01T04:00:00.000","updated":"2026-06-16T21:48:35.650","remediation":"在 DNS 服务器（BIND/Windows DNS）上配置区域传输（Zone Transfer）仅允许指定的授权从 DNS 服务器 IP，禁止对任意主机开放。具体操作为在 named.conf 中使用 `allow-transfer { 从服务器 IP; };` 或在 Windows DNS 管理器的\"区域传送\"选项卡中勾选\"只允许到下列服务器\"并添加授权 IP。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://www.cve.org/CVERecord?id=CVE-1999-0532","http://www.us-cert.gov/ncas/alerts/TA15-103A","https://github.com/websecnl/Bulk_CVE-1999-0532_Scanner","https://github.com/Rodney-O-C-Melby/dns-zone-transfer-test","https://github.com/SleepTheGod/dns-zone-audit"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0798.toml"},{"ave_id":"AVE-1999-0435","file_name":"1999/AVE-1999-0435.toml","cve_id":"CVE-1999-0250","title":"Dan Bernstein Qmail SMTP 命令处理拒绝服务漏洞","description":"Qmail 1.01 的 SMTP 组件在处理超长命令时存在拒绝服务漏洞。远程攻击者无需认证即可向目标服务器的 25 端口发送特制长 SMTP 命令，导致 qmail-smtpd 进程崩溃或异常终止，从而中断邮件服务。该漏洞影响 Dan Bernstein Qmail 1.01 版本，攻击复杂度低，且无需任何权限，可被用于阻断正常邮件收发功能。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0250"],"sources":["epss"],"published":"1997-07-01T04:00:00.000","updated":"2026-06-16T21:48:00.120","remediation":"立即升级至 Qmail 1.03 或更高版本，或在编译时添加 qmail-smtpd.c 中对输入行长度（LINE_MAX）的显式检查。如不便升级，可在 SMTP 服务前端部署流量过滤规则，限制单行 SMTP 命令长度不超过 512 字节。长期建议迁移至 Netqmail 补丁集（netqmail 1.06）以获得持续维护。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["http://cr.yp.to/qmail/venema.html","http://marc.info/?l=bugtraq&m=87602558319024&w=2","http://www.ornl.gov/its/archives/mailing-lists/qmail/1997/06/threads.html","https://github.com/trickest/cve/blob/34851454a7b07498072de47d56f63daa4a4f524d/1999/CVE-1999-0250.md","https://github.com/CVEProject/cvelistV5/blob/ab6ab436962e16237b21ed9d4458dafc38c692fc/cves/1999/0xxx/CVE-1999-0250.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0250","https://github.com/edoardottt/missing-cve-nuclei-templates/blob/36c16d53eb6071e39cfc3cf88e99f1b340ec913b/data/year/1999.txt","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0250.json","https://github.com/Patrowl/PatrowlHearsData/blob/a55bddfc5dd568e972e08b703ab596ed3580b7ba/CVE/data/1999/CVE-1999-0250.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-wq5m-pq24-j5cv/GHSA-wq5m-pq24-j5cv.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x83000/82079/info.html","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0250.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0435.toml"},{"ave_id":"AVE-1999-0407","file_name":"1999/AVE-1999-0407.toml","cve_id":"CVE-1999-0219","title":"Cat Soft Serv-U FTP Server 远程缓冲区溢出漏洞","description":"Cat Soft Serv-U FTP Server 2.5 存在远程缓冲区溢出漏洞。已认证的远程攻击者可通过向 FTP 服务发送超长的 CWD（切换目录）或 LS（列出文件）命令触发缓冲区溢出，导致服务进程崩溃，造成拒绝服务。该漏洞影响 Serv-U FTP Server 2.5 版本，攻击者只需拥有有效账号即可利用，无需其他特殊权限。","severity":"HIGH","score":7.8,"aliases":["CVE-1999-0219"],"sources":["exploitdb"],"published":"1997-07-01T04:00:00.000","updated":"2026-06-16T21:47:56.290","remediation":"升级至 Serv-U 2.5a 或更高版本可修复此缓冲区溢出漏洞。当前最新版为 SolarWinds Serv-U 15.x，建议立即升级并开启自动更新。如无法升级，可在防火墙限制 FTP 端口（21/TCP）仅对可信来源开放，并禁用匿名用户写权限作为临时缓解。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://marc.info/?l=ntbugtraq&m=92574916930144&w=2","http://marc.info/?l=ntbugtraq&m=92582581330282&w=2","http://www.securityfocus.com/bid/269","https://exchange.xforce.ibmcloud.com/vulnerabilities/205","https://www.exploit-db.com/exploits/19218","https://github.com/CVEProject/cvelistV5/blob/ead50dc12e50bdd7f50b53d9d01c9f9946862c44/cves/1999/0xxx/CVE-1999-0219.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0219","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0219.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-0219.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-5495-52g6-8q95/GHSA-5495-52g6-8q95.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/blackhook/nessus-plugins/blob/64177d96abbb07c58cf7e131046b067ebc61fcb5/F/ftp_servu_dos.nasl","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0219.json","https://github.com/jdkoftinoff/mb-linux-msli/blob/8adb103e34af9ff1d8d122e9ee2a1808836f0a14/uClinux-dist/user/nessus/nessus-plugins/scripts/ftp_overflow.nasl","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_154400_154500.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0407.toml"},{"ave_id":"AVE-1999-0377","file_name":"1999/AVE-1999-0377.toml","cve_id":"CVE-1999-0195","title":"Sun RPC Portmapper 源IP地址欺骗拒绝服务漏洞","description":"Linux Kernel 2.6.20.1 中的 RPC Portmapper 组件存在源 IP 地址验证缺陷，远程攻击者可通过伪造 127.0.0.1 等源 IP 地址向目标系统发送特制的 RPC 请求，实现注册/注销 RPC 服务或伪装合法 RPC 服务，导致目标系统拒绝服务。该漏洞影响 Linux Kernel 2.6.20.1 版本，CVSS 评分 5.0，危害等级中危。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0195"],"sources":["epss"],"published":"1997-07-01T04:00:00.000","updated":"2026-06-16T21:47:53.223","remediation":"升级 Linux 内核至 2.6.20.1 以上版本，该漏洞已在后续版本修复。使用 iptables 限制对 TCP/UDP 111 端口的访问来源，仅允许可信 IP 段连接 RPC portmapper。如不需要 RPC 服务，建议在 `/etc/init.d/` 中停止 portmap/rpcbind 服务并通过 `chkconfig portmap off` 禁止开机自启。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["https://www.cve.org/CVERecord?id=CVE-1999-0195"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0377.toml"},{"ave_id":"AVE-1999-0367","file_name":"1999/AVE-1999-0367.toml","cve_id":"CVE-1999-0184","title":"ISC BIND 动态DNS更新不当漏洞","description":"BIND DNS 服务器在编译时启用 -DALLOW_UPDATES 选项后，会允许未经验证的动态 DNS 更新请求。远程攻击者可利用该功能向目标服务器发送恶意动态更新数据包，从而篡改或添加 DNS 记录，导致域名解析劫持、流量重定向等严重后果。该漏洞影响多种 Unix/Linux 系统上运行的 BIND 服务，CVSS 评分 6.4，危害等级中危。","severity":"MEDIUM","score":6.4,"aliases":["CVE-1999-0184"],"sources":["epss"],"published":"1997-07-01T04:00:00.000","updated":"2026-06-16T21:47:46.770","remediation":"重新编译 BIND 时移除 -DALLOW_UPDATES 编译选项以禁用动态更新功能；如业务需要动态 DNS 更新，请在 named.conf 中使用 allow-update ACL 限定仅允许信任网段（如 10.0.0.0/8）发起更新请求，并配置 TSIG 密钥签名认证确保更新来源合法性；同时升级至 BIND 9.x 或更高版本以获取完整的访问控制和身份验证机制。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0184"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0367.toml"}]