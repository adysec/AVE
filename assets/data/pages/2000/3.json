[{"ave_id":"AVE-2000-0354","file_name":"2000/AVE-2000-0354.toml","cve_id":"CVE-2000-0432","title":"Matt Kruse Calendar Script 远程命令执行漏洞","description":"Matt Kruse Calendar Script 2.2 中的 calender.pl 和 calendar_admin.pl 脚本存在命令注入漏洞，远程攻击者无需身份认证即可通过向脚本参数中注入 shell 元字符（如反引号、管道符等）执行任意系统命令。该漏洞源于 CGI 程序未对用户输入进行有效过滤，直接传递给 shell 执行，可导致服务器被完全控制，危害严重。目前官方已停止维护，建议用户移除相关脚本。","severity":"HIGH","score":7.5,"aliases":["CVE-2000-0432"],"sources":["cve"],"published":"2000-05-16","updated":"2026-06-16","remediation":"Matt Kruse Calendar Script 已停止维护，建议立即移除 calender.pl 和 calendar_admin.pl 脚本，或迁移至其他仍在维护的日历系统。如仍需使用，需在脚本中对用户输入进行严格的 shell 元字符过滤（如过滤反引号、$、|、; 等特殊字符），并限制 Web 服务器对该脚本的访问权限。","status":"completed","collected_at":"2026-07-20T06:16:45.953183799+00:00","references":[],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2000/AVE-2000-0354.toml"},{"ave_id":"AVE-2000-0345","file_name":"2000/AVE-2000-0345.toml","cve_id":"CVE-2000-0424","title":"George Burgyan CGI Counter 远程命令执行漏洞","description":"George Burgyan CGI Counter 4.0.2 及 4.0.7 版本存在输入验证漏洞，远程攻击者可通过向 CGI 程序提交包含 shell 元字符的特制请求，触发命令注入，从而在目标服务器上执行任意命令。该漏洞源于程序未对用户输入进行充分过滤，攻击者无需身份认证即可利用，CVSS 评分 7.5，危害等级高。","severity":"HIGH","score":7.5,"aliases":["CVE-2000-0424"],"sources":["exploitdb"],"published":"2000-05-15T04:00:00.000","updated":"2026-06-16T21:51:42.193","remediation":"该 CGI Counter 程序已停止维护且无安全更新，建议立即从 Web 服务器移除 cgicounter.cgi 脚本或将其执行权限取消。若仍需使用，需在脚本中对用户输入参数进行严格过滤，禁止 shell 元字符（如 ; | & ` $ 等）传入，或改用非 CGI 替代方案。","status":"completed","collected_at":"2026-07-20T00:00:00Z","references":["http://www.securityfocus.com/bid/1202","http://www.securityfocus.com/templates/archive.pike?list=1&msg=200005151024.aa01811%40blaze.arl.mil","https://www.exploit-db.com/exploits/19913","https://github.com/CVEProject/cvelistV5/blob/24df5d59670dfe04b9c86de11fa86df63c0d28f7/cves/2000/0xxx/CVE-2000-0424.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55