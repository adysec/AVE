visories/39755","http://www.exploit-db.com/exploits/12595","http://www.securityfocus.com/bid/40166","https://exchange.xforce.ibmcloud.com/vulnerabilities/58574","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2010/CVE-2010-2045.yaml","https://github.com/trickest/cve/blob/8600ac0c091970175de0b53d9682f50858aef8dc/2010/CVE-2010-2045.md","https://github.com/projectdiscovery/nuclei-templates/blob/6bfef5eb290cbfeb2b2cb4d2bae8e5cab0243137/http/cves/2010/CVE-2010-2045.yaml","https://github.com/sepehrdaddev/zap-scripts/blob/2b63b02ca79cc7f0023cdbab72c5c6c774354b07/active/CVE-2010-2045.js","https://github.com/0xKayala/Custom-Nuclei-Templates/blob/1940dfd29577590f076c89dec5c30d809d68f210/6001-to-7000-templates/cve-2010-2045-1921.yaml","https://github.com/CVEProject/cvelistV5/blob/5df5af06e079a6824349b336150de94d9ba1e7f8/cves/2010/2xxx/CVE-2010-2045.json","https://github.com/adampielak/nuclei-templates/blob/ac9605f5a915670fd80cb4e1904f4435f1835b65/nuclei-v3/C/CVE-2010-2045_27.yaml","https://nvd.nist.gov/vuln/detail/CVE-2010-2045"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0091.toml"},{"ave_id":"AVE-2010-0090","file_name":"2010/AVE-2010-0090.toml","cve_id":"CVE-2010-2037","title":"Joomla! Percha Downloads Attach 组件 目录遍历 任意文件读取漏洞","description":"Joomla! 组件 Percha 下载附件 1.1 存在目录遍历漏洞，攻击者可通过操控控制器参数实现任意文件读取。该漏洞影响 Joomla! 所有版本，攻击者只需向系统发送包含 \"..\" 的参数即可利用，从而严重威胁网站文件安全，可能导致机密信息泄露和系统进一步破坏。","severity":"HIGH","score":7.5,"aliases":["CVE-2010-2037"],"sources":["nuclei"],"published":"2010-05-25T14:30:01.687","updated":"2026-06-16T23:19:51.737","remediation":"tags<value>建议立即升级或卸载存在漏洞的 Percha Downloads Attach (com_perchadownloadsattach) 组件 1.1 版本，更换为官方已修复的版本；若暂无法升级，可在 Joomla 后台禁用或卸载该组件，并在 Web 服务器（如 Apache）配置中禁止对 index.php 的 controller 参数传入包含 \"../\" 的路径，同时设置 open_basedir 限制 PHP 文件访问范围作为临时缓解措施。","status":"completed","collected_at":"2026-07-15T0