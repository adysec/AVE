# Public repo in output/: keep only site files + public vulnerability data
*

# Track directories and selected files
!/.gitignore
!/README.md
!/index.html
!/detail.html
!/asset.html
!/CNAME
!/.nojekyll
!/assets/
!/assets/**
!/assets/data/
!/assets/data/**
!/scripts/
!/scripts/**
!/.github/
!/.github/**
!/vulns/
!/vulns/**
!/pocs/
!/pocs/**
!/exploits/
!/exploits/**
!/generate-vuln-data-rust/
!/generate-vuln-data-rust/**
# Exclude Rust build artifacts from git
/generate-vuln-data-rust/target/
