[{"ave_id":"AVE-1999-0225","file_name":"1999/AVE-1999-0225.toml","cve_id":"CVE-1999-0679","title":"Hybrid IRCd 远程缓冲区溢出漏洞","description":"Hybrid IRC 守护进程（hybrid-6）的 m_invite 功能存在缓冲区溢出漏洞，远程攻击者无需身份认证即可通过向目标服务器发送特制的 INVITE 命令触发该漏洞，导致任意代码执行。该漏洞主要影响 EFnet 上运行的 hybrid-6 版本 IRC 服务器，CVSS 评分 7.5，危害等级高。攻击者利用此漏洞可完全控制受影响服务器，进而发起进一步攻击。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0679"],"sources":["exploitdb"],"published":"1999-08-13T04:00:00.000","updated":"2026-06-16T21:48:49.900","remediation":"立即升级 hybrid-ircd 至 7.0 或更高版本，该漏洞在 hybrid-7 中已修复 m_invite 命令的缓冲区边界检查。如无法升级，可在 IRC 服务器配置中禁用 m_invite 命令（通过屏蔽 invite 消息类型），或在网络边界防火墙限制对 IRC 端口（6667/TCP）的访问仅限可信 IP。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.efnet.org/archive/servers/hybrid/ChangeLog","http://www.securityfocus.com/bid/581","https://www.exploit-db.com/exploits/19459"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0225.toml"},{"ave_id":"AVE-1999-0321","file_name":"1999/AVE-1999-0321.toml","cve_id":"CVE-1999-0724","title":"OpenBSD procfs/fdescfs readdir 缓冲区溢出漏洞","description":"OpenBSD 的 procfs 和 fdescfs 文件系统在 readdir() 函数中处理 uio_offset 参数时存在缓冲区溢出漏洞。本地攻击者可利用精心构造的 uio_offset 值触发缓冲区越界写入，导致内核内存损坏，进而实现权限提升。该漏洞影响 OpenBSD 2.5 及更早版本，但 procfs 和 fdescfs 默认未启用。","severity":"MEDIUM","score":4.6,"aliases":["CVE-1999-0724"],"sources":["cve"],"published":"1999-08-12","updated":"2026-06-16","remediation":"升级到 OpenBSD 2.6 或更高版本。对于 OpenBSD 2.5，应用 errata 002 补丁。建议在不必要时禁用 procfs 和 fdescfs 文件系统。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["https://www.openbsd.org/errata25.html","http://www.osvdb.org/6128"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0321.toml"},{"ave_id":"AVE-1999-1052","file_name":"1999/AVE-1999-1052.toml","cve_id":"CVE-1999-1336","title":"3Com HiPerARC 路由器 Telnet 服务 IAC 数据包泛洪拒绝服务漏洞","description":"3Com HiPer Access Router Card (HiperARC) 4.0 至 4.2.29 版本中的 Telnet 服务存在拒绝服务漏洞。远程攻击者可通过向 Telnet 端口（23/TCP）发送大量 IAC (Interpret As Command) 数据包，导致设备 CPU 过载并触发重启，造成服务不可用。攻击无需认证，仅需网络可达即可实施。该产品已停止维护，无官方补丁。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-1336"],"sources":["cve"],"published":"1999-08-12","updated":"2026-06-16","remediation":"该产品已停止维护，无官方补丁。建议在边界防火墙上限制对 Telnet 端口（23/TCP）的访问，仅允许受信任管理 IP 连接。如业务允许，建议禁用 Telnet 服务并迁移至 SSH 进行远程管理，同时尽快替换为受支持的现代路由设备。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://marc.info/?l=bugtraq&m=93458364903256&w=2","http://marc.info/?l=bugtraq&m=93492615408725&w=2","http://www.osvdb.org/6057","https://nvd.nist.gov/vuln/detail/CVE-1999-1336"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1052.toml"},{"ave_id":"AVE-1999-0263","file_name":"1999/AVE-1999-0263.toml","cve_id":"CVE-1999-0694","title":"IBM AIX ptrace 系统调用本地拒绝服务漏洞","description":"IBM AIX 操作系统中的 ptrace 系统调用存在缺陷，本地攻击者可通过向目标系统发起特制的 ptrace 调用来触发该漏洞，导致系统内核崩溃，造成拒绝服务。该漏洞影响 AIX 多个版本，攻击者需要拥有本地用户权限方可利用，无法远程触发，CVSS 评分 2.1，危害等级低。","severity":"LOW","score":2.1,"aliases":["CVE-1999-0694"],"sources":["avd"],"published":"1999-08-11T04:00:00.000","updated":"2026-06-16T21:48:51.820","remediation":"安装 IBM AIX APAR IX68314 补丁，或将 AIX 升级至 4.3.3 Maintenance Level 9 及以上版本。如无法立即打补丁，可通过限制非授权用户本地登录、使用 chdev 禁用不必要的调试接口等措施降低风险。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.ciac.org/ciac/bulletins/j-055.shtml","https://github.com/CVEProject/cvelistV5/blob/d92a0abc5d3abac6dcdfabfef6fd71c158e0fd8b/cves/1999/0xxx/CVE-1999-0694.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0694","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0694.md","https://github.com/Patrowl/PatrowlHearsData/blob/58eef6eedd760f280b47bfb4c94db9995b29c5a0/CVE/data/1999/CVE-1999-0694.json","https://github.com/github/advisory-database/blob/6eca843f42fd99fea8c9b630931afac7c9d4576c/advisories/unreviewed/2022/04/GHSA-vg2c-63m3-5wwm/GHSA-vg2c-63m3-5wwm.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0694.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x85000/84474/info.html","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153500_153600.json","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--06fdb7a2-f512-4bc3-ba75-667344476ce2.json","https://github.com/hungryfoolou/Vulnerability_Mining/blob/3df1d8ed0489ae1228f975ae1f58a690aae53886/craw/cveid_craw/cveid_craw/data/cveid_by_kind/cveid_dos.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0263.toml"},{"ave_id":"AVE-1999-0661","file_name":"1999/AVE-1999-0661.toml","cve_id":"CVE-1999-0861","title":"Microsoft IIS SSL ISAPI 筛选器竞争条件信息泄露漏洞","description":"CVE-1999-0861 是微软 IIS 及其他服务器中 SSL ISAPI 筛选器存在的竞态条件漏洞。攻击者利用该漏洞可绕过 SSL 加密保护机制，在特定时间窗口内截获以明文形式泄露的 HTTP 请求或响应数据，导致敏感信息（如身份凭证）泄漏。攻击者无需认证即可在目标网络内实施中间人攻击，利用线程竞争条件获取本应受 SSL 保护的通信内容。该漏洞影响 IIS 4.0 及早期版本，CVSS 评分 2.6，危害等级低。","severity":"LOW","score":2.6,"aliases":["CVE-1999-0861"],"sources":["cve"],"published":"1999-08-11T04:00:00.000","updated":"2026-06-16T21:49:12.627","remediation":"安装 Microsoft 安全公告 MS99-053 提供的修补程序（下载地址：https://www.microsoft.com/download/details.aspx?FamilyID=b6e3555b-a805-4140-aeae-7fd38d334923），将 IIS 4.0 SSL ISAPI 筛选器更新至修复版本。如无法安装补丁，可在 IIS 管理器中禁用 SSL ISAPI 筛选器作为临时缓解措施。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://support.microsoft.com/default.aspx?scid=kb%3B%5BLN%5D%3BQ244613","https://docs.microsoft.com/en-us/security-updates/securitybulletins/1999/ms99-053"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0661.toml"},{"ave_id":"AVE-1999-0667","file_name":"1999/AVE-1999-0667.toml","cve_id":"CVE-1999-0867","title":"Microsoft IIS 4.0 HTTP请求畸形标头泛洪拒绝服务漏洞","description":"Microsoft IIS 4.0 存在输入验证不当（CWE-20）导致的拒绝服务漏洞。远程未经认证的攻击者可通过向目标服务器发送大量包含畸变头部的 HTTP 请求，触发 IIS 处理畸形数据的资源耗尽，导致 IIS 服务进程崩溃或无法响应正常请求。该漏洞影响 IIS 4.0 及 Microsoft Commercial Internet System 2.0/2.5、Site Server Commerce Edition 3.0 等组件。","severity":"MEDIUM","score":5,"aliases":["CVE-1999-0867"],"sources":["cve"],"published":"1999-08-11T04:00:00.000","updated":"2026-06-16T21:49:13.347","remediation":"立即安装微软安全公告 MS99-029 提供的补丁（KB Q238349），或升级至 Windows Server 2003 及以上版本的 IIS（如 IIS 6.0+），旧版 IIS 4.0 已停止技术支持，继续使用存在安全风险。如无法升级，可在 IIS 管理器中启用 URLScan 工具过滤异常请求头作为临时缓解。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://support.microsoft.com/default.aspx?scid=kb%3B%5BLN%5D%3BQ238349","http://www.ciac.org/ciac/bulletins/j-058.shtml","http://www.securityfocus.com/bid/579","https://docs.microsoft.com/en-us/security-updates/securitybulletins/1999/ms99-029","https://www.exploit-db.com/exploits/19457"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0667.toml"],"repo_exp_urls":["https://raw.githubusercontent.com/adysec/AVE/main/exploits/1999/EXP-AVE-1999-0667.toml"],"has_poc":true,"has_exp":true,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0667.toml"},{"ave_id":"AVE-1999-0809","file_name":"1999/AVE-1999-0809.toml","cve_id":"CVE-1999-0814","title":"Red Hat pump DHCP客户端 权限提升漏洞","description":"Red Hat Linux 系统中所使用的 pump DHCP 客户端在处理恶意 DHCP 服务器返回的响应数据时存在安全缺陷，远程攻击者可通过搭建伪造的 DHCP 服务器向目标主机发送特制的 DHCP 应答包，利用该漏洞在特定配置条件下以 root 权限执行任意命令，从而完全控制受影响的系统。该漏洞影响使用 pump DHCP 客户端的 Red Hat Linux 发行版，攻击无需用户交互即可触发。","severity":"CRITICAL","score":10,"aliases":["CVE-1999-0814"],"sources":["cve"],"published":"1999-08-11T04:00:00.000","updated":"2026-06-16T21:49:06.780","remediation":"升级 pump 软件包至 RHSA-1999-027 中提供的修复版本（pump-0.7.1 及以上）。具体操作：使用 `rpm -Uvh pump-0.7.1-1.i386.rpm` 更新 pump DHCP 客户端程序；如无法立即升级，可停止并禁用 pump 服务，改用 dhcpcd 替代；同时在防火墙层面限制 DHCP 服务器来源，仅允许可信 DHCP 服务器响应请求作为临时缓解措施。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://www.redhat.com/support/errata/RHSA-1999-027.html"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0809.toml"},{"ave_id":"AVE-1999-1100","file_name":"1999/AVE-1999-1100.toml","cve_id":"CVE-1999-0875","title":"Microsoft Windows 98/Solaris IRDP 默认路由欺骗漏洞","description":"Windows 98a/98b/98SE 及 Solaris 2.6 系统中启用了 ICMP 路由器发现协议（IRDP）的 DHCP 客户端存在路由欺骗漏洞。远程攻击者无需身份认证，只需向目标主机发送伪造的 ICMP 路由器通告报文，即可篡改其默认网关路由表条目，将网络流量劫持至攻击者控制的路径上，导致中间人攻击、数据窃听或流量拦截。该漏洞利用门槛低，攻击者仅需与目标在同一广播域内即可实施。","severity":"HIGH","score":7.5,"aliases":["CVE-1999-0875"],"sources":["cve"],"published":"1999-08-11T04:00:00.000","updated":"2026-06-16T21:49:14.373","remediation":"Windows 98 系统通过修改注册表禁用 IRDP：在 HKEY_LOCAL_MACHINE\\System\\CurrentControlSet\\Services\\VxD\\MSTCP 下新建 DWORD 值 PerformRouterDiscovery=0。Solaris 2.6 系统执行 ndd -set /dev/ip ip_forward_directed_broadcasts 0 并修改 /etc/init.d/inetinit 添加 ndd -set /dev/ip ip_ignore_redirect 1。网络层可在边界防火墙上过滤 ICMP Router Advertisement（类型 9）和 Router Solicitation（类型 10）报文阻断攻击。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["http://support.microsoft.com/default.aspx?scid=kb%3B%5BLN%5D%3BQ216141","http://www.securityfocus.com/bid/578","https://www.exploit-db.com/exploits/19451"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-1100.toml"},{"ave_id":"AVE-1999-0577","file_name":"1999/AVE-1999-0577.toml","cve_id":"CVE-1999-0813","title":"Cfingerd ALLOW_EXECUTION 本地权限提升漏洞","description":"Cfingerd（finger协议守护进程实现）存在特权管理不当漏洞。当启用 ALLOW_EXECUTION 选项时，系统未能在代表用户执行程序前正确丢弃 root 权限，导致本地攻击者可通过请求服务执行任意程序来获取 root 权限，进而完全控制目标系统。该漏洞影响运行 Cfingerd 的各类 Unix/Linux 系统，CVSS 评分 7.2，危害等级高。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0813"],"sources":["cve"],"published":"1999-08-10T04:00:00.000","updated":"2026-06-16T21:49:06.607","remediation":"立即升级 cfingerd 至 1.4.0 或更高版本（当前最新为 1.4.3），该版本已修复执行外部程序时未正确丢弃 root 权限的安全缺陷。如无法升级，在 cfingerd.conf 中将 ALLOW_EXECUTION 设置为 false 以禁用该功能，作为临时缓解措施。","status":"completed","collected_at":"2026-07-13T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0813"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0577.toml"},{"ave_id":"AVE-1999-0216","file_name":"1999/AVE-1999-0216.toml","cve_id":"CVE-1999-0674","title":"BSD profil(2) 系统调用本地权限提升漏洞","description":"BSD profil(2) 系统调用存在设计缺陷，本地攻击者可通过结合 profiling 与 execve 机制，在程序执行过程中修改其内部数据空间，从而提升权限或执行任意代码。该漏洞影响 NetBSD 1.4、OpenBSD 2.5 及 Solaris 7.0 等操作系统，CVSS 评分 7.2，危害等级高。攻击者需拥有本地账户权限，利用门槛较低且已有公开利用代码。","severity":"HIGH","score":7.2,"aliases":["CVE-1999-0674"],"sources":["exploitdb"],"published":"1999-08-09T04:00:00.000","updated":"2026-06-16T21:48:49.237","remediation":"升级 NetBSD 至 1.4.1 及以上版本，升级 OpenBSD 至 2.6 及以上版本，升级 Solaris 至 7.0 对应补丁簇（如 Kernel Patch 107528-xx）。如无法升级，可通过禁用 setuid 二进制文件的 profiling 功能或限制 profil(2) 系统调用的访问权限作为临时缓解措施。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.ciac.org/ciac/bulletins/j-067.shtml","http://www.securityfocus.com/bid/570","https://www.exploit-db.com/exploits/19447","https://github.com/CVEProject/cvelistV5/blob/e7c7f7ae9af22de7901413e757a1767cf5623277/cves/1999/0xxx/CVE-1999-0674.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0674","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0674.md","https://github.com/Patrowl/PatrowlHearsData/blob/bc69cd1e5221f68ef56bd10c5c61adf76a19f0fc/CVE/data/1999/CVE-1999-0674.json","https://github.com/github/advisory-database/blob/18de81c56daca1c9e33223f0b95bdb8312a1ca75/advisories/unreviewed/2022/04/GHSA-q8cp-g8hf-5jjj/GHSA-q8cp-g8hf-5jjj.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153500_153600.json","https://github.com/andreafioraldi/ToolsForCyberChallenge/blob/197d3dfd204cf1b9d1af1451455c8831c3ff9948/generated/files_0.list.dict","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0674.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0216.toml"},{"ave_id":"AVE-1999-0220","file_name":"1999/AVE-1999-0220.toml","cve_id":"CVE-1999-0676","title":"Sun Solaris 2.6 sdtcm_convert 本地符号链接文件覆盖漏洞","description":"Solaris 2.6 系统中的 sdtcm_convert 工具在处理临时文件时未进行充分的路径安全检查，存在符号链接（symlink）竞争条件漏洞。本地攻击者可通过创建恶意的符号链接，诱使 sdtcm_convert 以特权进程身份覆写任意系统文件，从而导致敏感文件被破坏、权限提升或系统崩溃。该漏洞影响 Solaris 2.6 操作系统，攻击者需拥有本地用户账户权限，攻击复杂度较低，CVSS 评分 4.6，危害等级中危。","severity":"MEDIUM","score":4.6,"aliases":["CVE-1999-0676"],"sources":["avd"],"published":"1999-08-09T04:00:00.000","updated":"2026-06-16T21:48:49.510","remediation":"立即安装 Sun Security Bulletin #00151 提供的 Solaris 2.6 官方补丁：SPARC 平台安装 105868-xx 系列补丁（最终版 105868-24），x86 平台安装 105869-xx 系列补丁（最终版 105869-21）。由于 Solaris 2.6 已终止技术支持（EOL），强烈建议升级至受支持的 Oracle Solaris 11.x 或更高版本以获取持续安全更新。如无法立即打补丁或升级，可临时移除 sdtcm_convert 的 setuid 权限（`chmod -s /usr/dt/bin/sdtcm_convert`）并确保 /tmp 等临时目录设置 sticky bit，限制非授权本地用户的 CDE 工具集访问。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.securityfocus.com/bid/575","http://www.securityfocus.com/templates/archive.pike?list=1&msg=19990809134220.A1191%40hades.chaoz.org","https://github.com/CVEProject/cvelistV5/blob/77be9686a381151781bc75b69de578b4d9528aae/cves/1999/0xxx/CVE-1999-0676.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0676","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0676.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-0676.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-96rr-v4m6-cxx3/GHSA-96rr-v4m6-cxx3.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0676.json","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153500_153600.json","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--5088ae3b-1fe3-4296-b335-fed943d90602.json","https://github.com/VulnerabilityHistoryProject/mega-foss/blob/4829eeb7b0101570abbc87d2a697f2c0c2f4e5c3/src/cve/graphql/trial.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0220.toml"},{"ave_id":"AVE-1999-0233","file_name":"1999/AVE-1999-0233.toml","cve_id":"CVE-1999-0680","title":"Microsoft Windows NT 4.0 Terminal Server 认证前资源消耗拒绝服务漏洞","description":"Microsoft Windows NT 4.0 Terminal Server 在处理客户端新建连接请求时，在完成身份认证前会执行额外的资源分配操作，远程攻击者可通过发送大量未认证的连接请求消耗服务器资源，导致终端服务响应缓慢或完全停止响应，造成拒绝服务。该漏洞影响 Windows NT 4.0 Terminal Server 版本，CVSS 评分 5.0，危害等级中危。","severity":"MEDIUM","score":5,"aliases":["CVE-1999-0680"],"sources":["avd"],"published":"1999-08-09T04:00:00.000","updated":"2026-06-16T21:48:50.027","remediation":"立即安装 Microsoft 安全公告 MS99-028（KB Q238600）提供的补丁。Windows NT 4.0 Terminal Server 已停止技术支持，建议升级至受支持的 Windows Server 版本。临时缓解措施：在防火墙上限制对 TCP 3389 端口的访问，仅允许受信任 IP 连接，并启用终端服务连接认证。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://support.microsoft.com/default.aspx?scid=kb%3B%5BLN%5D%3BQ238600","http://www.ciac.org/ciac/bulletins/j-057.shtml","http://www.securityfocus.com/bid/571","https://docs.microsoft.com/en-us/security-updates/securitybulletins/1999/ms99-028","https://github.com/CVEProject/cvelistV5/blob/ead50dc12e50bdd7f50b53d9d01c9f9946862c44/cves/1999/0xxx/CVE-1999-0680.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0680","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0680.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-0680.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-65vm-7q8v-3p23/GHSA-65vm-7q8v-3p23.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/KTZgraph/sarenka/blob/f1fb931ab722d6c096d581ed6e3c5966d799fbaa/sarenka/feeds/cve_details/cve_all_details_153500_153600.json","https://github.com/olbat/nvdcve/blob/763b4dfa75aa1890a155aad1b583fdcab8111c49/nvdcve/CVE-1999-0680.json","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000723.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0233.toml"},{"ave_id":"AVE-1999-0218","file_name":"1999/AVE-1999-0218.toml","cve_id":"CVE-1999-0675","title":"Check Point FireWall-1 VPN-1 UDP 端口 0 拒绝服务漏洞","description":"Check Point FireWall-1 及 VPN-1 产品在处理目标端口号为 0 的 UDP 数据包时存在缺陷，攻击者只需向受保护网络发送特制的 UDP 端口 0 数据包，即可引发防火墙崩溃或拒绝服务，导致合法流量无法被正常过滤与转发。该漏洞利用条件简单，无需身份认证，远程攻击者可通过网络直接触发，对边界防护设备构成严重威胁，影响网络可用性。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0675"],"sources":["avd"],"published":"1999-08-09","updated":"2026-07-16","remediation":"升级到 Check Point FireWall-1 4.1 Service Pack 2 或更高版本，该版本已修复此 UDP 端口 0 拒绝服务漏洞。若无法立即升级，可在防火墙规则中添加丢弃目标端口为 0 的 UDP 数据包的规则作为临时缓解，并联系 Check Point 获取官方补丁。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.osvdb.org/1038","http://www.securityfocus.com/archive/1/23615","http://www.securityfocus.com/bid/576","https://github.com/CVEProject/cvelistV5/blob/main/cves/1999/0xxx/CVE-1999-0675.json","https://github.com/eldondev/Snort/blob/34bdcf6a7a638b55c7c04f77ef1efa526ad08e33/doc/signatures/525.txt"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0218.toml"},{"ave_id":"AVE-1999-0212","file_name":"1999/AVE-1999-0212.toml","cve_id":"CVE-1999-0673","title":"CREAR ALMail32 1.10 远程缓冲区溢出漏洞","description":"CREAR ALMail32 1.10 版本 POP3 邮件客户端存在缓冲区溢出漏洞。远程攻击者可通过向目标用户发送包含恶意构造的 From 或 To 邮件头部的特制邮件，在客户端接收并处理该邮件时触发缓冲区溢出，导致程序崩溃或执行任意代码。该漏洞影响 ALMail32 1.10 版本，攻击者无需身份认证即可利用，危害较高。","severity":"MEDIUM","score":5.1,"aliases":["CVE-1999-0673"],"sources":["exploitdb"],"published":"1999-08-08T04:00:00.000","updated":"2026-06-16T21:48:49.103","remediation":"该软件 CREAR ALMail32 1.10 已停止维护且不再有安全更新，建议立即卸载并迁移至受支持的现代邮件客户端（如 Mozilla Thunderbird、Microsoft Outlook）。如暂时无法替换，可在邮件客户端中禁用自动预览/解析邮件头功能，并在网络边界过滤可疑 POP3 流量作为临时缓解。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["http://www.securityfocus.com/bid/574","https://www.exploit-db.com/exploits/19450"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0212.toml"},{"ave_id":"AVE-1999-0409","file_name":"1999/AVE-1999-0409.toml","cve_id":"CVE-1999-0722","title":"Cobalt RaQ2 服务器默认配置远程代码执行漏洞","description":"Cobalt RaQ2 服务器默认配置存在安全缺陷，远程攻击者无需认证即可通过默认服务接口向服务器安装任意软件包，导致完全控制服务器，获取敏感信息或发起进一步攻击。攻击者利用该漏洞可完全控制受影响系统。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0722"],"sources":["cve","avd"],"published":"1999-08-08","updated":"2026-06-16","remediation":"限制对 RaQ2 服务器的网络访问权限，禁用不必要的默认服务，配置防火墙规则仅允许可信 IP 访问管理接口。该产品已停止维护，建议迁移至受支持的替代产品。","status":"completed","collected_at":"2026-07-16T13:30:07.920697003+00:00","references":["http://www.securityfocus.com/bid/558"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":["https://raw.githubusercontent.com/adysec/AVE/main/pocs/1999/POC-AVE-1999-0409.toml"],"repo_exp_urls":[],"has_poc":true,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0409.toml"}]