[{"ave_id":"AVE-2021-0016","file_name":"2021/AVE-2021-0016.toml","cve_id":"无","title":"网御星云 Leadsec VPN SSL VPN 任意文件读取漏洞","description":"北京网御星云信息技术有限公司的 Leadsec SSL VPN 存在任意文件读取漏洞。攻击者可通过向 /vpn/user/download/client 接口发送包含路径遍历 Payload 的特制请求，利用 ostype 参数中的 ../../ 序列读取服务器上的任意文件（如 /etc/passwd），导致系统敏感信息泄露。","severity":"HIGH","score":7.5,"aliases":["NUCLEI-HTTP-CNVD-2021-CNVD-2021-64035-YAML","CNVD-2021-64035","AVD-2021-888761"],"sources":["nuclei","cnvd"],"published":"2021-01-01","updated":"2021-01-01","remediation":"建议联系厂商获取修复补丁并升级 Leadsec SSL VPN 至最新版本；同时配置 Web 应用防火墙拦截路径遍历攻击，对 ostype 参数进行严格的输入校验，禁止包含 ../ 等危险字符序列。","status":"completed","collected_at":"2026-07-14T20:59:09.739411692+00:00","references":["https://avd.aliyun.com/detail?id=AVD-2021-888761","https://www.cnvd.org.cn/flaw/show/CNVD-2021-64035","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cnvd/2021/CNVD-2021-64035.yaml"],"poc_urls":["https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cnvd/2021/CNVD-2021-64035.yaml"],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2021/AVE-2021-0016.toml"}]