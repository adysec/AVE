/unreviewed/2022/04/GHSA-vhcr-j22h-735c/GHSA-vhcr-j22h-735c.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x83000/82092/info.html","https://github.com/intSpLoiT/intframework/blob/eabaa799d0260aa52b735fa9769266d1ce4b64ef/modules/cve_list.txt","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0248.json"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0433.toml"},{"ave_id":"AVE-1999-0440","file_name":"1999/AVE-1999-0440.toml","cve_id":"CVE-1999-0255","title":"IRC ircd 缓冲区溢出远程代码执行漏洞","description":"IRC 服务器守护进程（ircd）存在缓冲区溢出漏洞，远程攻击者无需身份认证即可向目标服务器发送特制的超长数据包触发缓冲区溢出，导致任意命令执行。攻击者可利用此漏洞完全控制目标服务器，影响范围广泛，CVSS 评分 10.0，危害等级严重。","severity":"CRITICAL","score":10,"aliases":["CVE-1999-0255"],"sources":["epss"],"published":"1999-01-01T05:00:00.000","updated":"2026-06-16T21:48:00.750","remediation":"升级 ircd 至 2.10.3 或更高版本以修复缓冲区溢出漏洞。如无法升级，可在 ircd.conf 中加强输入长度校验与连接限制；建议迁移至现代维护的 IRC 服务端软件（如 UnrealIRCd、InspIRCd）。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0255","https://github.com/CVEProject/cvelistV5/blob/5917e2b15694e167c1fd9ad85775b2bdfc5fe29c/cves/1999/0xxx/CVE-1999-0255.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0255","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0255.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0255.md","https://github.com/Patrowl/PatrowlHearsData/blob/a55bddfc5dd568e972e08b703ab596ed3580b7ba/CVE/data/1999/CVE-1999-0255.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad