[{"ave_id":"AVE-1999-0586","file_name":"1999/AVE-1999-0586.toml","cve_id":"CVE-1999-0355","title":"CA ControlIT 4.5 拒绝服务漏洞","description":"CA ControlIT 4.5 存在拒绝服务漏洞，本地或远程攻击者无需身份认证即可向目标系统的 ControlIT 服务发送特制请求，导致目标系统强制重启或强制已有用户会话注销，造成服务不可用。该漏洞影响 CA ControlIT 4.5 版本，攻击者可通过网络远程触发，无需复杂前置条件即可实现拒绝服务攻击。","severity":"MEDIUM","score":5.0,"aliases":["CVE-1999-0355"],"sources":["epss"],"published":"1999-01-01T05:00:00.000","updated":"2026-06-16T21:48:13.103","remediation":"CA ControlIT 4.5 已停止维护，建议迁移至厂商当前支持的远程管理解决方案。临时缓解措施：在防火墙上限制仅允许受信任 IP 访问 ControlIT 服务端口（默认 TCP 1499），并禁用不必要的远程控制功能。","status":"completed","collected_at":"2026-07-16T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0355","https://github.com/CVEProject/cvelistV5/blob/ead50dc12e50bdd7f50b53d9d01c9f9946862c44/cves/1999/0xxx/CVE-1999-0355.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0355","https://github.com/yarencheng/cve-devops-playground/blob/45be3b4afd9c4397ee32a5cbf6819a590220b0c1/content/CVE-1999-0355.md","https://github.com/Patrowl/PatrowlHearsData/blob/4ed191c1149de50e461e9a357f4a3a22e603f0d1/CVE/data/1999/CVE-1999-0355.json","https://github.com/github/advisory-database/blob/b7a93df7f7051799495805bc211adea8d202dae7/advisories/unreviewed/2022/04/GHSA-jqgq-vf46-2wc2/GHSA-jqgq-vf46-2wc2.json","https://github.com/nomi-sec/NVD-Database/blob/23dc120c34402aaa65883c51c1d03b3cb02c20cb/1999/CVE-1999-0355.json","https://github.com/SpeeDr00t/speedr00t.github.com/blob/0380f0c2190556fabe90257cb6c0034a42f68951/securityfocus/0x83000/82468/info.html","https://github.com/leego972/titanai/blob/afa5b2310463aae5781d3fd9408071bf38e79806/data/raw/corpus_D_cyber/nvd_cve_000419.txt","https://github.com/oasis-open/cti-stix-common-objects/blob/55ba7598cbd5a52577b6887871505d931d85cb61/objects/vulnerability/vulnerability--86340522-28cc-4ec8-9d76-b049bcd8b6d2.json","https://github.com/security-commits/security-patches-dataset/blob/e93fcdcc8c9b91785f962a06d66b7ee623780245/data/cve-details/year/1999.csv"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/1999/AVE-1999-0586.toml"},{"ave_id":"AVE-1999-0476","file_name":"1999/AVE-1999-0476.toml","cve_id":"CVE-1999-0286","title":"Microsoft Windows NT Web 服务器源代码泄露漏洞","description":"Windows NT 系统的 Web 服务器存在源代码泄露漏洞。远程攻击者通过在 URL 末尾添加一个空格字符，可绕过服务器对动态页面（如 ASP）的访问限制，从而读取活动页面的源代码。该漏洞允许攻击者获取数据库连接字符串、业务逻辑等敏感信息，为后续攻击提供信息基础，无需身份认证即可远程利用。","severity":"CRITICAL","score":10.0,"aliases":["CVE-1999-0286"],"sources":["epss"],"published":"1999-01-01T05:00:00.000","updated":"2026-06-16T21:48:04.477","remediation":"安装 Windows NT 4.0 Service Pack 4 (SP4) 或更高版本，该更新已修复 IIS 对 URL 末尾空格的解析问题。如无法升级，可在 IIS 管理器中禁用不必要的脚本映射（如 .htr），或使用 URLScan 工具过滤包含空格的请求作为临时缓解措施。","status":"completed","collected_at":"2026-07-14T00:00:00Z","references":["https://exchange.xforce.ibmcloud.com/vulnerabilities/CVE-1999-0286","https://github.com/CVEProject/cvelistV5/blob/1421f0a4349d5d46275cadd9c7c62349edf9c8bb/cves/1999/0xxx/CVE-1999-0286.json","https://github.com/LiuCan01/cve-list-pro/blob/78b55511cee3604c22d518e32822f0435d0cacc0/cve-list/CVE-1999/CVE-1999-0286","https://github.com/aquasecurity/vuln-list-redhat/blob/601a95d57be2a57306cd88389c2251f34b2fbcc1/csaf-vex/1999/cve-1999-0286.json","https://github.com/yarencheng/cve-devops-playground/blob/9074597bd191efd66c2a6bf1f5d8e60bc4801a90/content/CVE-1999-0286.md","https://github.com/Patrowl/PatrowlHearsData/blob/2f876a2c24d5ccd5bbd081f09e801e580536456a/CVE/data/1999/CVE-1999-0286.json","https://github.com/github/advisory-database/blob/49899a53e9c2e620c99e0234afe3c50e512ad851/advisories/unreviewed/2022/04/GHSA-mcjx-hw8r-r6gf/GHSA-mcjx-hw8r-r6gf.json","https://github.com/feng-li/tools-for-data-science-course/blob/8e62d47ee8ffbebe9a0e50aee193617f83883118/2019spring/2017312271/result.txt","https://github.com/olbat/nvdcve/blob/d21eb36f6164170df89