[{"ave_id":"AVE-2010-0075","file_name":"2010/AVE-2010-0075.toml","cve_id":"CVE-2010-1955","title":"Joomla! Deluxe Blog Factory 组件本地文件包含漏洞","description":"Joomla! Deluxe Blog Factory 1.1.2 组件存在本地文件包含漏洞，攻击者可利用此漏洞读取服务器上的敏感文件，如/etc/passwd等。漏洞源于 improper input sanitization，允许攻击者通过目录遍历攻击读取任意文件，可能导致信息泄露或进一步系统入侵。","severity":"HIGH","score":8.5,"aliases":["CVE-2010-1955"],"sources":["cve"],"published":"2010-04-15","updated":"2010-06-15","remediation":"升级 Joomla! 到最新版本（≥3.9.0），彻底修复受影响的 Deluxe Blog Factory 组件。","status":"completed","collected_at":"2026-07-15T15:18:49.780232661+00:00","references":["https://nvd.nist.gov/vuln/detail/CVE-2010-1955","https://www.exploit-db.com/exploits/12868"],"poc_urls":["https://www.exploit-db.com/exploits/12868"],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0075.toml"},{"ave_id":"AVE-2010-0068","file_name":"2010/AVE-2010-0068.toml","cve_id":"CVE-2010-1858","title":"Joomla! SMEStorage 组件目录遍历漏洞","description":"Joomla! 的 SMEStorage 组件（com_smestorage）1.1 之前版本存在目录遍历漏洞。该漏洞源于组件对 index.php 的 controller 参数未充分过滤路径遍历序列（如 ../），远程未认证攻击者可构造包含目录遍历序列的请求（如 index.php?option=com_smestorage&controller=../../../../etc/passwd）读取服务器上的任意文件，包括系统敏感文件、配置文件及数据库凭据等，从而导致敏感信息泄露。漏洞对应 CWE-22（路径遍历），CVSS v2 评分 5.0（中危），攻击向量为网络、无需认证、仅影响机密性。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2010-1858"],"sources":["nuclei"],"published":"2010-05-07","updated":"2026-06-16","remediation":"将 Joomla! 的 SMEStorage 组件（com_smestorage）升级至 1.1 或更高版本以彻底修复该漏洞。若暂时无法升级，应在服务端对 controller 等用户可控参数进行严格白名单校验，拒绝包含 ../、..\\ 或空字节等路径遍历字符的输入，并使用规范化后的绝对路径进行文件访问限制，避免直接将用户输入拼接到文件路径中。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://packetstormsecurity.org/1003-exploits/joomlasmestorage-lfi.txt","http://secunia.com/advisories/39071","http://www.exploit-db.com/exploits/11853","http://www.securityfocus.com/bid/38911","https://exchange.xforce.ibmcloud.com/vulnerabilities/57108","https://nvd.nist.gov/vuln/detail/CVE-2010-1858","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2010/CVE-2010-1858.yaml"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0068.toml"},{"ave_id":"AVE-2010-0063","file_name":"2010/AVE-2010-0063.toml","cve_id":"CVE-2010-1717","title":"Joomla! iF surfALERT 组件 1.2 目录遍历漏洞","description":"Joomla! 的 iF surfALERT 组件 1.2 版本中存在目录遍历漏洞，远程攻击者可通过向 index.php 的 controller 参数传递包含 .. 的路径实现目录穿越，读取服务器上任意文件，导致敏感信息泄露。","severity":"HIGH","score":7.5,"aliases":["CVE-2010-1717"],"sources":["cve","exploitdb","nuclei"],"published":"2010-05-04","updated":"2026-07-15","remediation":"移除或禁用 iF surfALERT 组件 1.2 版本，该组件已停止维护，建议卸载此组件或使用替代产品。","status":"completed","collected_at":"2026-07-15T13:08:02.176320917+00:00","references":["http://secunia.com/advisories/39526","http://www.exploit-db.com/exploits/12291","http://www.vupen.com/english/advisories/2010/0924"],"poc_urls":["http://www.exploit-db.com/exploits/12291"],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0063.toml"},{"ave_id":"AVE-2010-0058","file_name":"2010/AVE-2010-0058.toml","cve_id":"CVE-2010-1657","title":"Joomla! SmartSite组件1.0.0 - 目录穿越漏洞","description":"Joomla!中的SmartSite（com_smartsite）组件1.0.0存在目录穿越漏洞，攻击者通过在index.php的controller参数中嵌入../序列可读任意服务器文件。此漏洞影响Joomla!网站，可能导致敏感信息泄露，信息安全风险等级为中危。攻击者无需认证即可发起攻击， exploited路径简单，主要针对部署了SmartSite1.0.0版本的网站。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2010-1657"],"sources":["nuclei"],"published":"2010-05-03","updated":"2010-05-27","remediation":"立即升级Joomla!核心程序至最新版本，或卸载不再使用的Smartsite组件。如果必须保留Smartsite，请确保使用受信任的来源安装，并定期更新至最新安全版本。","status":"completed","collected_at":"2026-07-15T11:59:04.620207017+00:00","references":["http://packetstormsecurity.org/1004-exploits/joomlasmartsite-lfi.txt","http://secunia.com/advisories/39592","http://www.exploit-db.com/exploits/12428","http://www.securityfocus.com/bid/39740","http://www.vupen.com/english/advisories/2010/1006","https://exchange.xforce.ibmcloud.com/vulnerabilities/58175"],"poc_urls":["http://www.exploit-db.com/exploits/12428"],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0058.toml"},{"ave_id":"AVE-2010-0056","file_name":"2010/AVE-2010-0056.toml","cve_id":"CVE-2010-1607","title":"Joomla! WMI (com_wmi) 组件 目录遍历本地文件包含漏洞","description":"Joomla! 的 Webmoney Web Merchant Interface（WMI，组件名 com_wmi）1.5.0 版本 wmi.php 中存在目录遍历漏洞（CWE-22）。攻击者通过向 index.php 的 controller 参数注入包含 ../ 的路径遍历序列，可包含并执行目标服务器上的任意本地文件，进而实现远程代码执行。该漏洞无需身份认证即可被远程利用，攻击条件仅需网络可达且目标启用了存在缺陷的 WMI 组件，CVSS 2.0 基础评分 6.8（中危）。成功利用后可读取敏感配置、执行恶意代码，严重威胁服务器安全。","severity":"MEDIUM","score":6.8,"aliases":["CVE-2010-1607"],"sources":["cve"],"published":"2010-04-29","updated":"2026-07-15","remediation":"建议立即卸载或禁用以存在缺陷的 com_wmi（Webmoney Web Merchant Interface）组件，或在 wmi.php/index.php 中对 controller 参数进行严格的白名单校验，过滤 ../ 等路径遍历字符；通过 .htaccess 限制对该组件脚本的访问，并关注 Joomla! 官方安全更新以升级至修复版本。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://osvdb.org/63979","http://secunia.com/advisories/39539","http://www.exploit-db.com/exploits/12316","http://www.securityfocus.com/bid/39608","https://exchange.xforce.ibmcloud.com/vulnerabilities/58032"],"poc_urls":["http://www.exploit-db.com/exploits/12316"],"exp_urls":["http://www.exploit-db.com/exploits/12316"],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0056.toml"},{"ave_id":"AVE-2010-0054","file_name":"2010/AVE-2010-0054.toml","cve_id":"CVE-2010-1602","title":"Joomla! ZiMB Comment 0.8.1 目录遍历漏洞","description":"Joomla! 的 ZiMB Comment（com_zimbcomment）组件 0.8.1 版本存在目录遍历漏洞。该漏洞源于程序对 index.php 的 controller 参数未进行充分过滤，攻击者可通过在该参数中注入 '../' 序列进行路径穿越，从而读取服务器上的任意文件，可能导致敏感信息泄露。此漏洞 CVSS 评分为 7.5 危害等级为高，攻击者无需身份验证即可利用。","severity":"HIGH","score":7.5,"aliases":["CVE-2010-1602"],"sources":["cve","nuclei"],"published":"2010-04-29","updated":"2026-06-16","remediation":"升级 Joomla! ZiMB Comment 组件至 0.8.2 或更高版本以修复目录遍历漏洞。如需立即缓解，可在后台禁用 com_zimbcomment 组件，或在 WAF 层面拦截包含 '../' 的 controller 参数请求。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://packetstormsecurity.org/1004-exploits/joomlazimbcomment-lfi.txt","http://www.exploit-db.com/exploits/12283","http://www.securityfocus.com/bid/39548","http://www.vupen.com/english/advisories/2010/0932","https://www.exploit-db.com/exploits/12283","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2010/CVE-2010-1602.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2010/CVE-2010-1602.md","https://github.com/projectdiscovery/nuclei-templates/blob/1482f62c613998b0fe0690591034b732c0bb2e0a/http/cves/2010/CVE-2010-1602.yaml","https://github.com/sepehrdaddev/zap-scripts/blob/2b63b02ca79cc7f0023cdbab72c5c6c774354b07/active/CVE-2010-1602.js","https://github.com/0xKayala/Custom-Nuclei-Templates/blob/1940dfd29577590f076c89dec5c30d809d68f210/5001-to-6000-templates/cve-2010-1602-1742.yaml","https://github.com/ExpLangcn/NucleiTP/blob/2b7ecb9031a6eda4f272793045f29b339d8e0cce/CVES/high/cve-2010-1602-1741.yaml","https://github.com/adampielak/nuclei-templates/blob/ac9605f5a915670fd80cb4e1904f4435f1835b65/nuclei-v2/C/CVE-2010-1602_9.yaml","https://github.com/patrickmpalmer/exploit-prediction-calculator/blob/a048424e68e6b5ea7f4d32bf29dddd4eda342b01/data_gathering/data/exploited_cves.csv","https://github.com/amad3us47/amad3us47.github.io/blob/07cfc0edf465277028554b47198f6f186d3215b6/data/cve-2010-1602-1740.yaml","https://github.com/TheMirkin/CVE-List-Public-Exploits/blob/f496d51148a2b151f14fe6d0bef5b42ee27f6ccb/CVE%20List/2010/1xxx/CVE-2010-1602.json","https://www.exploit-db.com/exploits/12283"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0054.toml"},{"ave_id":"AVE-2010-0053","file_name":"2010/AVE-2010-0053.toml","cve_id":"CVE-2010-1601","title":"Joomla! JA Comment 组件 目录遍历漏洞","description":"Joomla! 的 JA Comment（com_jacomment）组件存在目录遍历漏洞，其 index.php 在处理 view 参数时未对用户输入做充分校验与过滤。远程攻击者无需身份认证，只需在请求 index.php 的 view 参数中构造包含 ..（点-点）的恶意路径序列，即可越权读取目标服务器上的任意文件（如配置文件、源码、密码等敏感信息）。该漏洞影响所有安装了存在缺陷版本 JA Comment 组件的 Joomla! 站点，攻击条件仅需网络可达目标 Web 服务并发送特制 HTTP 请求即可，CVSS 评分 5.0，危害等级为中。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2010-1601"],"sources":["nuclei"],"published":"2010-04-29","updated":"2026-07-15","remediation":"建议立即升级 JA Comment 组件到官方发布的最新修复版本；若暂无法升级，可在后台扩展管理中停用或卸载 com_jacomment 组件以彻底消除风险。同时应在组件控制器中对 view 参数进行白名单校验，过滤 ../ 与空字节等非法字符，并在 Web 服务器层（如 Apache 的 .htaccess）限制对敏感路径参数的访问。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://packetstormsecurity.org/1004-exploits/joomlajacomment-lfi.txt","http://secunia.com/advisories/39472","http://www.exploit-db.com/exploits/12236","http://www.osvdb.org/63802","http://www.securityfocus.com/bid/39516","https://exchange.xforce.ibmcloud.com/vulnerabilities/57848","https://www.exploit-db.com/exploits/12236","https://github.com/projectdiscovery/nuclei-templates/blob/main/http/cves/2010/CVE-2010-1601.yaml","https://github.com/trickest/cve/blob/a90de4f84b4783951362f491671e1e9decfc17cb/2010/CVE-2010-1601.md","https://github.com/projectdiscovery/nuclei-templates/blob/1482f62c613998b0fe0690591034b732c0bb2e0a/http/cves/2010/CVE-2010-1601.yaml","https://github.com/sepehrdaddev/zap-scripts/blob/2b63b02ca79cc7f0023cdbab72c5c6c774354b07/active/CVE-2010-1601.js","https://github.com/0xKayala/Custom-Nuclei-Templates/blob/1940dfd29577590f076c89dec5c30d809d68f210/5001-to-6000-templates/cve-2010-1601-1737.yaml","https://github.com/1in9e/gosint/blob/bdda4461515c4398c08638676bbbfe451b73ff95/client/vuln_scan/nuclei/tools/nuclei-templates/cves/2010/CVE-2010-1601.yaml","https://github.com/linuxadi/40k-nuclei-templates/blob/542be6820c801c02a33aee60f1c05ca7b0b5005f/aditya/folder5/cve-2010-1601-1736.yaml","https://github.com/patrickmpalmer/exploit-prediction-calculator/blob/a048424e68e6b5ea7f4d32bf29dddd4eda342b01/data_gathering/data/exploited_cves.csv","https://github.com/foreztgump/cve_json/blob/b5f345eafeb97dce3fe03de3869b187e0574a5c0/2010/CVE-2010-1601.json","https://github.com/amad3us47/amad3us47.github.io/blob/07cfc0edf465277028554b47198f6f186d3215b6/data/cve-2010-1601-1735.yaml","https://github.com/rix4uni/nucleihub-templates/blob/579a0234551b9e0e322460a62dc77bd6109e4aff/nucleihub-templates/CVE-2010-1601_2.yaml"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0053.toml"},{"ave_id":"AVE-2010-0052","file_name":"2010/AVE-2010-0052.toml","cve_id":"CVE-2010-1586","title":"惠普系统管理主页 - 'RedirectUrl' 参数 URL 重定向漏洞","description":"惠普系统管理主页（System Management Homepage）是一款为服务器管理的IT管理员提供的综合工具，可预测、诊断和快速响应潜在或实际的系统故障。攻击者可通过SMH的可信URL漏洞利用RedirectUrl参数劫持受害者跳转到任意恶意网站，进而利用浏览器漏洞进一步攻击受害者操作系统并实现远程代码执行。","severity":"MEDIUM","score":4.3,"aliases":["CVE-2010-1586"],"sources":["cve","exploitdb","hp","nuclei"],"published":"2010-04-28","updated":"2026-06-16","remediation":"升级到惠普系统管理主页v6.2或更高版本以修复漏洞，建议安装供应商发布的最新补丁和安全更新。","status":"completed","collected_at":"2026-07-15T11:00:54.047473758+00:00","references":["http://yehg.net/lab/pr0js/advisories/hp_system_management_homepage_url_redirection_abuse","http://www.securityfocus.com/bid/39676","https://exchange.xforce.ibmcloud.com/vulnerabilities/58107","http://h20000.www2.hp.com/bizsupport/TechSupport/Document.jsp?objectID=c02518794&lang=en&cc=us&taskId=101&prodSeriesId=344313&prodTypeId=18964","http://yehg.net/lab/pr0js/advisories/hp_system_management_homepage_url_redirection_abuse"],"poc_urls":["http://x.x.x.x:2301/red2301.html?RedirectUrl=evil@attacker.com"],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0052.toml"},{"ave_id":"AVE-2010-0051","file_name":"2010/AVE-2010-0051.toml","cve_id":"CVE-2010-1540","title":"Joomla! com_myblog 组件目录遍历漏洞","description":"Joomla! com_myblog 组件 3.0.329 版本的 index.php 存在目录遍历漏洞，远程未认证攻击者可通过 task 参数传入目录遍历序列（../）读取服务器任意文件。该漏洞源于对用户输入的 task 参数未进行路径规范化校验，攻击者可构造恶意路径遍历序列读取敏感系统文件（如 /etc/passwd、配置文件等），影响使用该组件的 Joomla! 站点，CVSS 评分 5.0（中危），属路径遍历类漏洞（CWE-22）。","severity":"MEDIUM","score":5.0,"aliases":["CVE-2010-1540"],"sources":["cve","exploitdb","nuclei"],"published":"2010-04-26","updated":"2026-07-15","remediation":"卸载存在目录遍历漏洞的 com_myblog 组件 3.0.329，替换为官方维护的安全替代组件；升级 Joomla! 至最新受支持版本；对 task 参数进行路径规范化校验，拒绝包含 '../' 或空字节编码的恶意输入。","status":"completed","collected_at":"2026-07-15T00:00:00Z","references":["http://secunia.com/advisories/38777","http://www.exploit-db.com/exploits/11625","http://www.securityfocus.com/bid/38530"],"poc_urls":[],"exp_urls":[],"repo_poc_urls":[],"repo_exp_urls":[],"has_poc":false,"has_exp":false,"raw_url":"https://github.com/adysec/AVE/blob/main/vulns/2010/AVE-2010-0051.toml"}]